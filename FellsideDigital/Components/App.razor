<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["css/tailwind.css"]" />
    <link rel="stylesheet" href="@Assets["FellsideDigital.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.2/anime.min.js"></script>
    <script src="@Assets["js/animations/anime-interop.js"]"></script>
    <script src="@Assets["js/animations/app-loader.js"]"></script>
    <script src="@Assets["js/app.js"]"></script>

    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="PageRenderMode" />

    <div id="components-reconnect-modal">
        <div class="fixed inset-0 z-50 flex items-end justify-center pb-8 pointer-events-none">
            <div class="pointer-events-auto flex items-center gap-3 px-5 py-3 rounded-2xl
                        bg-white dark:bg-neutral-900
                        ring-1 ring-slate-200 dark:ring-white/10
                        shadow-lg text-sm text-slate-500 dark:text-neutral-400">
                <span id="reconnect-spinner"
                      class="w-3.5 h-3.5 rounded-full border-2
                             border-slate-200 dark:border-neutral-700
                             border-t-indigo-400 dark:border-t-orange-400
                             animate-spin flex-shrink-0">
                </span>
                <span id="reconnect-message"></span>
            </div>
        </div>
    </div>

    <style>
        #components-reconnect-modal                          { display: none; }
        #components-reconnect-modal.components-reconnect-show    { display: block; }

        #components-reconnect-modal.components-reconnect-show #reconnect-message::after {
            content: "Reconnecting\2026";
        }
        #components-reconnect-modal.components-reconnect-failed #reconnect-message::after {
            content: "Connection lost — retrying\2026";
        }
        #components-reconnect-modal.components-reconnect-rejected #reconnect-message::after {
            content: "Could not reconnect.";
        }

        #components-reconnect-modal.components-reconnect-failed #reconnect-spinner,
        #components-reconnect-modal.components-reconnect-rejected #reconnect-spinner {
            animation: none;
            border: none;
            width: 0.5rem;
            height: 0.5rem;
            background-color: #f87171;
            border-radius: 9999px;
        }
    </style>

    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}