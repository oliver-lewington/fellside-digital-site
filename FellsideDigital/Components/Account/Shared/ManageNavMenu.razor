@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data

@inject SignInManager<ApplicationUser> SignInManager

<nav class="space-y-1">
    <NavLink href="Account/Manage" 
             Match="NavLinkMatch.All"
             class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
             ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
        Profile
    </NavLink>

    <NavLink href="Account/Manage/Email"
             class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
             ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
        Email
    </NavLink>

    <NavLink href="Account/Manage/ChangePassword"
             class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
             ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
        </svg>
        Password
    </NavLink>

    @if (hasExternalLogins)
    {
        <NavLink href="Account/Manage/ExternalLogins"
                 class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
                 ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
            <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            External logins
        </NavLink>
    }

    <NavLink href="Account/Manage/TwoFactorAuthentication"
             class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
             ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
        Two-factor authentication
    </NavLink>

    <NavLink href="Account/Manage/PersonalData"
             class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors"
             ActiveClass="bg-slate-100 text-indigo-400 hover:bg-slate-100 dark:bg-white/10 dark:text-orange-400 dark:hover:bg-white/10">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
        </svg>
        Personal data
    </NavLink>
</nav>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
