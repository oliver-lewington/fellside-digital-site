@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor

<PageTitle>Personal Data — Fellside Digital</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
            Personal Data
        </h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">
            Download or delete your personal information
        </p>
    </div>

    <StatusMessage />

    <div class="rounded-lg bg-blue-50 p-4 dark:bg-blue-900/20">
        <div class="flex items-start gap-3">
            <svg class="h-5 w-5 flex-shrink-0 text-blue-700 dark:text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
            </svg>
            <div class="text-sm text-blue-700 dark:text-blue-400">
                <p>Your account contains personal data that you have given us. 
                    <br />This page allows you to download or delete that data.</p>
            </div>
        </div>
    </div>

    <div class="space-y-4">
        <div>
            <h3 class="text-base font-semibold text-slate-900 dark:text-white">
                Download your data
            </h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">
                Get a copy of all your personal information
            </p>
            <form action="Account/Manage/DownloadPersonalData" method="post" class="mt-3">
                <AntiforgeryToken />
                <button type="submit" class="inline-flex justify-center rounded-md bg-indigo-400 px-4 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 dark:bg-orange-400 dark:hover:bg-orange-400/80 dark:focus-visible:outline-orange-400">
                    Download
                </button>
            </form>
        </div>

        <div class="border-t border-gray-200 dark:border-white/10 pt-4">
            <h3 class="text-base font-semibold text-slate-900 dark:text-white">
                Delete your account
            </h3>
            <div class="mt-1 rounded-md bg-red-50 p-3 dark:bg-red-900/20">
                <p class="text-sm text-red-700 dark:text-red-400">
                    <strong>Warning:</strong> Deleting your account will permanently remove all your data. This action cannot be undone.
                </p>
            </div>
            <div class="mt-3">
                <a href="Account/Manage/DeletePersonalData" class="inline-flex justify-center rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-xs hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 dark:bg-red-500 dark:hover:bg-red-400">
                    Delete Account
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}
