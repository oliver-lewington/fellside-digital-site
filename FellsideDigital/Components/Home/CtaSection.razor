@inject IJSRuntime JS
<section class="py-32 px-6 relative overflow-hidden
                bg-slate-50 dark:bg-neutral-950 transition-colors duration-300">
    <div class="hero-glow opacity-30" aria-hidden="true"></div>
    <div class="max-w-2xl mx-auto text-center space-y-8 relative z-10">
        <p id="cta-label"
           class="text-sm uppercase tracking-widest
                  text-slate-400 dark:text-neutral-500">
            Ready to get started?
        </p>
        <h2 id="cta-heading"
            class="animated text-4xl md:text-5xl font-bold tracking-tight text-pretty
                   text-slate-900 dark:text-white">
            Whether you need a stunning website, intelligent automation, or both,
            we would love to work with you.
        </h2>
        <a href="/contact"
           class="inline-block rounded-md bg-indigo-400 dark:bg-orange-400 px-6 py-3 text-sm font-semibold
                  text-white hover:bg-indigo-400/80 dark:hover:bg-orange-400/80 transition-colors shadow-lg">
            Start the conversation
        </a>
    </div>
</section>
@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("fellsideAnime.fadeUpOnScroll", "#cta-label");
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsOnScroll", "#cta-heading");
    }
}
