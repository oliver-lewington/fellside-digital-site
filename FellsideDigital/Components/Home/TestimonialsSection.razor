@using FellsideDigital.Components.Home

<section id="testimonials"
         class="py-32 px-6 bg-slate-50 dark:bg-neutral-950 transition-colors duration-300">
    <div class="max-w-7xl mx-auto space-y-16">

        <div class="text-center">
            <p id="testimonials-label"
               class="animated text-sm font-medium uppercase tracking-widest
                      text-slate-400 dark:text-neutral-500">
                Testimonials
            </p>
            <h2 id="testimonials-heading"
                class="animated mt-2 text-3xl font-semibold
                       text-slate-900 dark:text-neutral-100">
                What our clients say.
            </h2>
        </div>

        <div id="testimonials-grid" class="grid md:grid-cols-3 gap-6">
            @foreach (var t in HomeData.Testimonials)
            {
                <div class="rounded-2xl p-6 space-y-5
                            bg-white ring-1 ring-slate-200
                            dark:bg-neutral-900 dark:ring-white/5">
                    <p class="text-sm leading-relaxed text-slate-600 dark:text-neutral-300">
                        "@t.Quote"
                    </p>
                    <div class="flex items-center gap-3 pt-4
                                border-t border-slate-100 dark:border-white/5">
                        <div class="w-9 h-9 rounded-full shrink-0 overflow-hidden
                                    bg-slate-200 dark:bg-neutral-700">
                            @if (!string.IsNullOrEmpty(t.AvatarUrl))
                            {
                                <img src="@t.AvatarUrl" alt="@t.Name"
                                     class="w-full h-full object-cover" />
                            }
                        </div>
                        <div>
                            <p class="text-sm font-semibold
                                      text-slate-900 dark:text-neutral-100">@t.Name</p>
                            <p class="text-xs text-slate-400 dark:text-neutral-500">@t.Role</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center">
            <a href="/contact"
               class="inline-block rounded-md px-5 py-2.5 text-sm font-semibold
                      transition ring-1
                      bg-slate-100 text-slate-700 ring-slate-200 hover:bg-slate-200
                      dark:bg-neutral-800 dark:text-neutral-200 dark:ring-white/10
                      dark:hover:bg-neutral-700">
                Start your project →
            </a>
        </div>

    </div>
</section>
