                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400 opacity-40" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400 opacity-60" style="width:8px;height:8px;"></div>
