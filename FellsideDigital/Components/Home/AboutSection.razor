                    </div>
                </div>

                <div style="padding:2rem;">
                    <p class="text-xs font-medium uppercase tracking-widest text-indigo-400 dark:text-orange-400">How it works</p>
                    <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-neutral-100">
                        End-to-end pipelines
                    </p>
                    <p class="mt-2 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">
                        From trigger to outcome, we design and build every step.
                    </p>
                </div>

            </div>

        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await JS.InvokeVoidAsync("fellsideAnime.fadeUpOnScroll", "#about-label");
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsOnScroll", "#about-heading");
        await JS.InvokeVoidAsync("fellsideAnime.staggeredRevealOnScroll", "#about-bento");

        // Count up to 100 when the percentage card scrolls into view
        await JS.InvokeVoidAsync("fellsideAnime.countUpOnScroll", "#about-percent", 100);
    }
}
