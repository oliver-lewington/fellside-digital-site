                     style="height:300px; display:flex; flex-direction:column;
                    align-items:center; justify-content:center;
                    gap:24px; padding:2rem;">

                    <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:7px;">
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400 opacity-40" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
