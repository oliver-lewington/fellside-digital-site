@inject IJSRuntime JS

<section id="about"
         class="py-16 px-6 bg-white dark:bg-neutral-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">

        <div class="mb-12">
            <p id="about-label"
               class="animated text-sm font-medium uppercase tracking-widest
