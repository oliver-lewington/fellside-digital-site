                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                                </svg>
                            </div>
                            <span class="text-sm text-slate-500 dark:text-neutral-400">Pull from source</span>
                        </div>
                        <div class="bg-slate-200 dark:bg-neutral-700"
                             style="width:1px; height:16px; margin-left:17px;"></div>

                        <div style="display:flex; align-items:center; gap:12px;">
                            <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5"
                                 style="width:36px; height:36px; border-radius:10px; flex-shrink:0;
                                display:flex; align-items:center; justify-content:center;">
                                <svg class="w-4 h-4 text-indigo-400 dark:text-orange-400" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                                </svg>
                            </div>
                            <span class="text-sm text-slate-500 dark:text-neutral-400">AI decision layer</span>
                        </div>
                        <div class="bg-slate-200 dark:bg-neutral-700"
                             style="width:1px; height:16px; margin-left:17px;"></div>

                        <div style="display:flex; align-items:center; gap:12px;">
                            <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5"
                                 style="width:36px; height:36px; border-radius:10px; flex-shrink:0;
                                display:flex; align-items:center; justify-content:center;">
                                <svg class="w-4 h-4 text-indigo-400 dark:text-orange-400" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <span class="text-sm text-slate-500 dark:text-neutral-400">Schedule or route</span>
                        </div>
                        <div class="bg-slate-200 dark:bg-neutral-700"
                             style="width:1px; height:16px; margin-left:17px;"></div>

                        <div style="display:flex; align-items:center; gap:12px;">
                            <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5"
                                 style="width:36px; height:36px; border-radius:10px; flex-shrink:0;
                                display:flex; align-items:center; justify-content:center;">
