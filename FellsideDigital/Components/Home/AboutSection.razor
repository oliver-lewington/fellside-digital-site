                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-indigo-400 dark:bg-orange-400 opacity-20" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                        <div class="rounded-full bg-slate-200 dark:bg-neutral-600" style="width:8px;height:8px;"></div>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:10px; width:100%;">
                        <div style="display:flex; flex-direction:column; gap:4px;">
                            <span class="text-xs text-slate-400 dark:text-neutral-500">Workflow automation</span>
                            <div class="bg-slate-200 dark:bg-neutral-700"
                                 style="height:4px; border-radius:100px; overflow:hidden;">
                                <div class="bg-indigo-400 dark:bg-orange-400" style="height:100%; width:90%; border-radius:100px;"></div>
                            </div>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px;">
                            <span class="text-xs text-slate-400 dark:text-neutral-500">API integration</span>
                            <div class="bg-slate-200 dark:bg-neutral-700"
                                 style="height:4px; border-radius:100px; overflow:hidden;">
                                <div class="bg-indigo-400 dark:bg-orange-400" style="height:100%; width:74%; border-radius:100px;"></div>
                            </div>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px;">
                            <span class="text-xs text-slate-400 dark:text-neutral-500">AI automation</span>
                            <div class="bg-slate-200 dark:bg-neutral-700"
                                 style="height:4px; border-radius:100px; overflow:hidden;">
                                <div class="bg-indigo-400 dark:bg-orange-400" style="height:100%; width:82%; border-radius:100px;"></div>
                            </div>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px;">
                            <span class="text-xs text-slate-400 dark:text-neutral-500">Data and reporting</span>
                            <div class="bg-slate-200 dark:bg-neutral-700"
