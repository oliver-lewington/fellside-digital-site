@using FellsideDigital.Components.Account.Pages.Forms
@if (IsOpen)
{
    <div class="sm:hidden">

        <NavLinks Links="Links"
                  LinkClass="block border-l-4 border-transparent py-2 pr-4 pl-3 text-base font-medium text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-white/5"
                  ActiveClass="!border-l-indigo-500 bg-gray-50 dark:bg-white/5 text-gray-900 dark:text-white"
                  OnClick="Close" />

        <div class="border-t pt-4 pb-3">
            <AuthorizeView>
                <Authorized>
                    <LogoutForm ReturnUrl="CurrentUrl" />
                </Authorized>

                <NotAuthorized>
                    <NavLink href="/Account/Login"
                             class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700 dark:text-neutral-200 hover:text-indigo-400 dark:hover:text-orange-400">
                        Login →
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public (string Label, string Href)[] Links { get; set; } = [];
    [Parameter] public EventCallback Close { get; set; }
    [Parameter] public string? CurrentUrl { get; set; }
}