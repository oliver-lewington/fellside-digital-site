@page "/not-found"
@inject IJSRuntime JS
<PageTitle>404 · Fellside Digital</PageTitle>

<div class="grid min-h-screen grid-cols-1 grid-rows-[auto_1fr_auto]
            bg-white dark:bg-gray-900
            lg:grid-cols-[max(50%,36rem)_1fr]">

    <!-- Header -->
    <header class="mx-auto w-full max-w-7xl px-6 pt-6 sm:pt-10
                   lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:px-8">
        <a href="/">
            <span class="sr-only">Fellside Digital</span>
            <img src="@Assets["imgs/logo-automation-black.svg"]"
                 alt="Fellside Digital"
                 class="h-10 w-auto sm:h-12 dark:hidden" />
            <img src="@Assets["imgs/logo-automation-white.svg"]"
                 alt="Fellside Digital"
                 class="h-10 w-auto sm:h-12 not-dark:hidden" />
        </a>
    </header>

    <!-- Main -->
    <main class="mx-auto w-full max-w-7xl px-6 py-24 sm:py-32
                 lg:col-span-2 lg:col-start-1 lg:row-start-2 lg:px-8">
        <div class="max-w-lg">

            <p id="not-found-label"
               class="text-base/8 font-semibold text-indigo-400 dark:text-orange-400">
                404
            </p>

            <h1 id="not-found-title"
                class="mt-4 text-5xl font-semibold tracking-tight text-pretty
                       text-gray-900 dark:text-white sm:text-6xl">
                Page not found
            </h1>

            <p id="not-found-body"
               class="mt-6 text-lg font-medium text-pretty
                      text-gray-500 dark:text-gray-400 sm:text-xl/8">
                Sorry, we couldn't find the page you're looking for.
            </p>

            <div id="not-found-cta" class="mt-10">
                <a href="/"
                   class="text-sm/7 font-semibold
                          text-indigo-400 dark:text-orange-400
                          hover:text-indigo-400/70 dark:hover:text-orange-400/70
                          transition-colors">
                    <span aria-hidden="true">←</span> Back to home
                </a>
            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer class="self-end lg:col-span-2 lg:col-start-1 lg:row-start-3">
        <div class="border-t border-gray-100 dark:border-white/10
                    bg-gray-50 dark:bg-gray-800/50 py-10">
            <nav class="mx-auto flex w-full max-w-7xl items-center gap-x-4 px-6 lg:px-8
                        text-sm/7 text-gray-600 dark:text-gray-400">
                <a href="/contact"
                   class="hover:text-indigo-400 dark:hover:text-orange-400 transition-colors">
                    Contact us
                </a>
                <svg viewBox="0 0 2 2" aria-hidden="true"
                     class="size-0.5 fill-gray-300 dark:fill-gray-600">
                    <circle r="1" cx="1" cy="1" />
                </svg>
                <a href="/"
                   class="hover:text-indigo-400 dark:hover:text-orange-400 transition-colors">
                    Home
                </a>
            </nav>
        </div>
    </footer>

    <!-- Right-hand image panel -->
    <div class="hidden lg:relative lg:col-start-2 lg:row-start-1 lg:row-end-4 lg:block">
        <img src="https://images.unsplash.com/photo-1470847355775-e0e3c35a9a2c?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=1825&q=80"
             alt=""
             class="absolute inset-0 size-full object-cover dark:hidden" />
        <img src="https://images.unsplash.com/photo-1583585635793-0e1894c169bd?ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&ixlib=rb-1.2.1&auto=format&fit=crop&w=1825&q=80"
             alt=""
             class="absolute inset-0 size-full object-cover not-dark:hidden" />
    </div>

</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#not-found-label",
            new { distance = 16, duration = 500, startDelay = 0 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWords", "#not-found-title",
            new { distance = 24, duration = 600, stagger = 80, startDelay = 150 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#not-found-body",
            new { distance = 16, duration = 500, startDelay = 500 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#not-found-cta",
            new { distance = 12, duration = 400, startDelay = 700 });
    }
}
