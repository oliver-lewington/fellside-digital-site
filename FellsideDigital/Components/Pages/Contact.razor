@page "/contact"
@using FellsideDigital.Components.Layout
@using System.ComponentModel.DataAnnotations

<PageTitle>Contact Us | Fellside Digital</PageTitle>

<div class="bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300">

    <Navbar />

    <!-- ═══════════════════════════════════════════════════════════
         HERO — centered, white / neutral-950
    ════════════════════════════════════════════════════════════ -->
    <section class="pt-40 pb-24 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-3xl mx-auto text-center space-y-6">
            <p class="text-sm font-medium uppercase tracking-widest
                      text-slate-400 dark:text-neutral-500">
                Get in touch
            </p>
            <h1 class="text-4xl sm:text-5xl font-semibold leading-tight
                       text-slate-900 dark:text-neutral-100">
                Let's work together.
            </h1>
            <p class="text-base sm:text-lg leading-relaxed
                      text-slate-500 dark:text-neutral-400 max-w-xl mx-auto">
                Every great project starts with a conversation. Tell us what you're looking
                to achieve and we'll come back with a clear plan and a no-obligation quote.
            </p>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         CONTACT CARDS — slate-50 / neutral-950
    ════════════════════════════════════════════════════════════ -->
    <section class="py-20 px-6 bg-slate-50 dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

                <!-- Phone -->
                <div class="group rounded-2xl p-6 space-y-4
                            bg-white ring-1 ring-slate-200
                            dark:bg-neutral-900 dark:ring-white/5
                            hover:ring-indigo-400/40 dark:hover:ring-orange-400/40 hover:shadow-md
                            transition-all duration-200">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center
                                bg-indigo-400/10 dark:bg-orange-400/10 text-indigo-400 dark:text-orange-400
                                group-hover:bg-indigo-400/20 dark:group-hover:bg-orange-400/20 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07
                                     19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67
                                     A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72
                                     c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91
                                     a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45
                                     c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-neutral-100">Give us a call</h3>
                        <p class="mt-1 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">
                            Prefer to talk things through? Give us a ring.
                        </p>
                    </div>
                    <a href="tel:+447484323505"
                       class="inline-flex items-center gap-1.5 text-sm font-medium
                              text-indigo-400 dark:text-orange-400
                              hover:underline underline-offset-4 transition">
                        +44 (0) 7484 323 505
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>

                <!-- WhatsApp -->
                <div class="group rounded-2xl p-6 space-y-4
                            bg-white ring-1 ring-slate-200
                            dark:bg-neutral-900 dark:ring-white/5
                            hover:ring-indigo-400/40 dark:hover:ring-orange-400/40 hover:shadow-md
                            transition-all duration-200">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center
                                bg-indigo-400/10 dark:bg-orange-400/10 text-indigo-400 dark:text-orange-400
                                group-hover:bg-indigo-400/20 dark:group-hover:bg-orange-400/20 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7
                                     8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8
                                     8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5
                                     a8.48 8.48 0 0 1 8 8v.5z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-neutral-100">Chat on WhatsApp</h3>
                        <p class="mt-1 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">
                            Send us a message and we'll get back to you quickly.
                        </p>
                    </div>
                    <a href="https://wa.me/447484323505"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-1.5 text-sm font-medium
                              text-indigo-400 dark:text-orange-400
                              hover:underline underline-offset-4 transition">
                        Open WhatsApp
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>

                <!-- Location -->
                <div class="group rounded-2xl p-6 space-y-4
                            bg-white ring-1 ring-slate-200
                            dark:bg-neutral-900 dark:ring-white/5
                            hover:ring-indigo-400/40 dark:hover:ring-orange-400/40 hover:shadow-md
                            transition-all duration-200">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center
                                bg-indigo-400/10 dark:bg-orange-400/10 text-indigo-400 dark:text-orange-400
                                group-hover:bg-indigo-400/20 dark:group-hover:bg-orange-400/20 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-neutral-100">Based in Cumbria</h3>
                        <p class="mt-1 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">
                            Serving clients across the UK. Happy to meet in person or over
                            video call — whatever works best.
                        </p>
                    </div>
                    <a href="https://maps.google.com/?q=Cumbria,+England"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-1.5 text-sm font-medium
                              text-indigo-400 dark:text-orange-400
                              hover:underline underline-offset-4 transition">
                        View on Google
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>

            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         FORM — white / neutral-900, centered, no card wrapper
    ════════════════════════════════════════════════════════════ -->
    <section class="py-32 px-6 bg-white dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-2xl mx-auto space-y-10">

            <!-- Heading -->
            <div class="space-y-3">
                <p class="text-sm font-medium uppercase tracking-widest
                          text-slate-400 dark:text-neutral-500">
                    Tell us about your project
                </p>
                <h2 id="form-heading"
                    class="text-3xl font-semibold text-slate-900 dark:text-neutral-100">
                    Fill in the short form below.
                </h2>
                <p class="text-base leading-relaxed text-slate-500 dark:text-neutral-400">
                    We'll get back to you within one working day with ideas and a no-obligation quote.
                </p>
            </div>

            <!-- Step indicator -->
            <div class="flex items-center">
                @for (int i = 0; i < _steps.Length; i++)
                {
                    var stepIndex = i;
                    bool isActive = stepIndex == _currentStep;
                    bool isDone = stepIndex < _currentStep;

                    <button type="button"
                            @onclick="() => TryGoToStep(stepIndex)"
                            disabled="@(stepIndex > _currentStep)"
                            class="@($"flex items-center gap-2 px-4 py-2 text-sm font-medium transition-colors " +
                                                                 $"{(isActive ? "text-indigo-400 dark:text-orange-400" : isDone ? "text-slate-900 dark:text-neutral-100 hover:text-indigo-400 dark:hover:text-orange-400" : "text-slate-400 dark:text-neutral-600 cursor-not-allowed")}")">
                    <span class="@($"w-6 h-6 rounded-full flex items-center justify-center text-xs font-semibold transition-colors " +
                                                                 $"{(isActive ? "bg-indigo-400 dark:bg-orange-400 text-white" : isDone ? "bg-indigo-400/20 dark:bg-orange-400/20 text-indigo-400 dark:text-orange-400" : "bg-slate-200 dark:bg-neutral-800 text-slate-400 dark:text-neutral-600")}")">
                        @if (isDone)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2.5"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 6 9 17l-5-5" />
                                </svg>
                            }
                            else
                            {
                                @(stepIndex + 1)
                            }
                        </span>
                        @_steps[stepIndex]
                    </button>

                    @if (stepIndex < _steps.Length - 1)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-4 h-4 text-slate-300 dark:text-neutral-700 shrink-0"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 18l6-6-6-6" />
                        </svg>
                    }
                }
            </div>

            <div class="border-t border-slate-100 dark:border-white/5"></div>

            <!-- Form fields — open layout, no card -->
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <!-- ── Step 1: Your details ─────────────────── -->
                @if (_currentStep == 0)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Your name
                            </label>
                            <InputText @bind-Value="_model.Name"
                                       placeholder="Jane Smith"
                                       class="@InputClass" />
                            <ValidationMessage For="() => _model.Name" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Email address
                            </label>
                            <InputText @bind-Value="_model.Email"
                                       type="email"
                                       placeholder="jane@example.com"
                                       class="@InputClass" />
                            <ValidationMessage For="() => _model.Email" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Phone
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputText @bind-Value="_model.Phone"
                                       type="tel"
                                       placeholder="+44 7700 000000"
                                       class="@InputClass" />
                        </div>
                    </div>
                }

                <!-- ── Step 2: About you ───────────────────── -->
                @if (_currentStep == 1)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Company or organisation
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputText @bind-Value="_model.Company"
                                       placeholder="Acme Ltd"
                                       class="@InputClass" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                What are you looking for?
                            </label>
                            <InputSelect @bind-Value="_model.ServiceType"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select a service…</option>
                                <option>Custom Web Application</option>
                                <option>Client Portal / Dashboard</option>
                                <option>E-Commerce Solution</option>
                                <option>API Integration</option>
                                <option>Maintenance &amp; Support</option>
                                <option>Something else</option>
                            </InputSelect>
                            <ValidationMessage For="() => _model.ServiceType" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Approximate budget
                            </label>
                            <InputSelect @bind-Value="_model.Budget"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select a range…</option>
                                <option>Under £2,000</option>
                                <option>£2,000 – £5,000</option>
                                <option>£5,000 – £10,000</option>
                                <option>£10,000 – £25,000</option>
                                <option>£25,000+</option>
                                <option>Not sure yet</option>
                            </InputSelect>
                        </div>
                    </div>
                }

                <!-- ── Step 3: Your message ────────────────── -->
                @if (_currentStep == 2)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Tell us about your project
                            </label>
                            <InputTextArea @bind-Value="_model.Message"
                                           rows="6"
                                           placeholder="Describe your idea, goals, timeline, or any questions you have…"
                                           class="@(InputClass + " resize-none")" />
                            <ValidationMessage For="() => _model.Message" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                How did you hear about us?
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputSelect @bind-Value="_model.HowHeard"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select…</option>
                                <option>Google search</option>
                                <option>Social media</option>
                                <option>Word of mouth</option>
                                <option>Returning client</option>
                                <option>Other</option>
                            </InputSelect>
                        </div>
                    </div>
                }

                <div class="border-t border-slate-100 dark:border-white/5 mt-8"></div>

                <!-- Nav buttons -->
                <div class="flex items-center justify-between pt-6">
                    @if (_currentStep > 0)
                    {
                        <button type="button" @onclick="PreviousStep"
                                class="inline-flex items-center gap-2 text-sm font-medium
                                               text-slate-500 dark:text-neutral-400
                                               hover:text-slate-900 dark:hover:text-neutral-100 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 12H5M12 19l-7-7 7-7" />
                            </svg>
                            Back
                        </button>
                    }
                    else
                    {
                        <span></span>
                    }

                    @if (_submitted)
                    {
                        <div class="flex items-center gap-2 rounded-xl px-5 py-2.5
                                             bg-indigo-400/10 dark:bg-orange-400/10
                                             text-indigo-400 dark:text-orange-400 text-sm font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6 9 17l-5-5" />
                            </svg>
                            Sent! We'll be in touch within one working day.
                        </div>
                    }
                    else if (_currentStep < _steps.Length - 1)
                    {
                        <button type="button" @onclick="NextStep"
                                class="inline-flex items-center gap-2 rounded-xl px-6 py-2.5
                                               text-sm font-semibold
                                               bg-indigo-400 dark:bg-orange-400 text-white
                                               hover:opacity-90 active:scale-95 transition-all shadow-sm">
                            Next
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </button>
                    }
                    else
                    {
                        <button type="submit" disabled="@_sending"
                                class="inline-flex items-center gap-2 rounded-xl px-6 py-2.5
                                               text-sm font-semibold
                                               bg-indigo-400 dark:bg-orange-400 text-white
                                               hover:opacity-90 active:scale-95
                                               disabled:opacity-50 disabled:cursor-not-allowed
                                               transition-all shadow-sm">
                            @if (_sending)
                            {
                                <svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg"
                                     fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10"
                                            stroke="currentColor" stroke-width="4" />
                                    <path class="opacity-75" fill="currentColor"
                                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                                </svg>
                                <span>Sending…</span>
                            }
                            else
                            {
                                <span>Send message</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            }
                        </button>
                    }
                </div>

            </EditForm>
        </div>
    </section>

</div>

@code {

    private readonly string[] _steps = ["Your details", "About you", "Your message"];
    private int _currentStep = 0;

    private void NextStep() { if (_currentStep < _steps.Length - 1) _currentStep++; }
    private void PreviousStep() { if (_currentStep > 0) _currentStep--; }
    private void TryGoToStep(int index) { if (index <= _currentStep) _currentStep = index; }

    private ContactFormModel _model = new();
    private bool _sending;
    private bool _submitted;

    private async Task HandleSubmit()
    {
        _sending = true;
        StateHasChanged();
        await Task.Delay(1200); // TODO: replace with real email service call
        _sending = false;
        _submitted = true;
    }

    private const string InputClass =
        "w-full rounded-xl px-4 py-2.5 text-sm " +
        "bg-slate-50 dark:bg-neutral-800 " +
        "ring-1 ring-slate-200 dark:ring-white/10 " +
        "text-slate-900 dark:text-neutral-100 " +
        "placeholder:text-slate-400 dark:placeholder:text-neutral-500 " +
        "focus:outline-none focus:ring-2 focus:ring-indigo-400/50 dark:focus:ring-orange-400/50 transition";

    private class ContactFormModel
    {
        [Required(ErrorMessage = "Please enter your name.")]
        [MaxLength(100)]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please enter your email address.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        public string? Phone { get; set; }
        public string? Company { get; set; }
        public string? Budget { get; set; }
        public string? HowHeard { get; set; }

        [Required(ErrorMessage = "Please select a service.")]
        public string ServiceType { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please tell us about your project.")]
        [MinLength(10, ErrorMessage = "Please give us a bit more detail (min 10 characters).")]
        public string Message { get; set; } = string.Empty;
    }
}
