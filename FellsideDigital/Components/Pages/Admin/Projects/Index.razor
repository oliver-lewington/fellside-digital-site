@page "/Admin/Projects"
@attribute [Authorize(Roles = "SiteAdmin")]

@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Data
@using FellsideDigital.Services

<PageTitle>Projects — Fellside Digital Admin</PageTitle>

<div class="min-h-screen bg-slate-50 dark:bg-neutral-950 pt-24 pb-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="sm:flex sm:items-center sm:justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-neutral-100">Client Projects</h1>
                <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">
                    Create and manage projects for your clients.
                </p>
            </div>
            <div class="mt-4 sm:mt-0 flex items-center gap-3">
                <NavLink href="/Admin/Invitations"
                         class="inline-flex items-center gap-2 rounded-md bg-white dark:bg-white/5 px-4 py-2 text-sm font-semibold text-slate-700 dark:text-neutral-200 ring-1 ring-slate-200 dark:ring-white/10 hover:bg-slate-50 dark:hover:bg-white/10 transition">
                    Invitations
                </NavLink>
                <NavLink href="/Admin/Projects/Create"
                         class="inline-flex items-center gap-2 rounded-md bg-indigo-400 dark:bg-orange-400 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-90 transition">
                    + New project
                </NavLink>
            </div>
        </div>

        @if (_projects is null)
        {
            <p class="text-sm text-slate-500 dark:text-neutral-400">Loading…</p>
        }
        else if (_projects.Count == 0)
        {
            <div class="rounded-xl border border-dashed border-slate-300 dark:border-white/10 p-12 text-center bg-white dark:bg-neutral-900">
                <p class="text-sm text-slate-500 dark:text-neutral-400">No projects yet.</p>
                <NavLink href="/Admin/Projects/Create"
                         class="mt-4 inline-flex items-center text-sm font-semibold text-indigo-400 dark:text-orange-400 hover:underline">
                    Create your first project →
                </NavLink>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm">
                <table class="min-w-full divide-y divide-slate-200 dark:divide-white/10">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-white/5">
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Project</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider hidden sm:table-cell">Client</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider hidden md:table-cell">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider hidden lg:table-cell">Invoices</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-white/5">
                        @foreach (var project in _projects)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-slate-900 dark:text-neutral-100">@project.Name</div>
                                    <div class="text-xs text-slate-500 dark:text-neutral-400 truncate max-w-xs">@project.Description</div>
                                </td>
                                <td class="px-6 py-4 hidden sm:table-cell">
                                    <div class="text-sm text-slate-700 dark:text-neutral-300">@project.Client?.CompanyName</div>
                                    <div class="text-xs text-slate-500 dark:text-neutral-400">@project.Client?.Email</div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-700 dark:text-neutral-300 hidden md:table-cell">@project.Type</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @StatusBadgeClass(project.Status)">
                                        @StatusLabel(project.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-500 dark:text-neutral-400 hidden lg:table-cell">
                                    @project.Invoices.Count invoice@(project.Invoices.Count == 1 ? "" : "s")
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <NavLink href="@($"/Admin/Projects/{project.Id}")"
                                                 class="text-xs font-medium text-indigo-400 dark:text-orange-400 hover:underline">
                                            Manage
                                        </NavLink>
                                        <NavLink href="@($"/Admin/Projects/{project.Id}/Edit")"
                                                 class="text-xs font-medium text-slate-500 dark:text-neutral-400 hover:underline">
                                            Edit
                                        </NavLink>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

