@page "/Admin/Projects/{Id:guid}"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services
@using FellsideDigital.Components.Layout
@using FellsideDigital.Components.Shared
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@(_project?.Name ?? "Project") — Fellside Digital Admin</PageTitle>

@if (_project is null)
{
    <div class="animate-pulse space-y-6">
        <div class="h-4 w-24 rounded-md bg-gray-200 dark:bg-white/10"></div>
        <div class="h-8 w-64 rounded-lg bg-gray-200 dark:bg-white/10"></div>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <div class="lg:col-span-2 space-y-4">
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-48"></div>
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-64"></div>
            </div>
            <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-80"></div>
        </div>
    </div>
}
else
{
    <!-- Header -->
    <div class="mb-6">
        <NavLink href="/Admin/Projects"
                 class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-3">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            Projects
        </NavLink>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-3 mb-1">
                    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">@_project.Name</h1>
                    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium @BadgeHelpers.ProjectStatusBadge(_project.Status)">
                        <span class="size-1.5 rounded-full @BadgeHelpers.ProjectStatusDotColor(_project.Status)"></span>
                        @BadgeHelpers.StatusLabel(_project.Status)
                    </span>
                </div>
                <p class="text-sm text-gray-500 dark:text-neutral-400">
                    @_project.Client?.CompanyName · @_project.Client?.Email
                </p>
            </div>
            <NavLink href="@($"/Admin/Projects/{Id}/Edit")"
                     class="inline-flex items-center gap-2 rounded-xl bg-white dark:bg-white/5 px-4 py-2 text-sm font-semibold text-gray-700 dark:text-neutral-200 ring-1 ring-gray-200 dark:ring-white/10 hover:bg-gray-50 dark:hover:bg-white/10 transition-all shrink-0">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                </svg>
                Edit project
            </NavLink>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

        <!-- Left column: details + status update + activity -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Project details -->
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/5">
                    <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Project details</h2>
                </div>
                <dl class="divide-y divide-gray-100 dark:divide-white/5">
                    <div class="grid grid-cols-2">
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Type</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.Type</dd>
                        </div>
                        <div class="px-6 py-4 border-l border-gray-100 dark:border-white/5">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Created</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</dd>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_project.PreviewUrl))
                    {
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Preview URL</dt>
                            <dd class="text-sm">
                                <a href="@_project.PreviewUrl" target="_blank" rel="noopener"
                                   class="text-indigo-500 dark:text-orange-400 hover:underline break-all">@_project.PreviewUrl</a>
                            </dd>
                        </div>
                    }
                    <div class="px-6 py-4">
                        <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Description</dt>
                        <dd class="text-sm text-gray-700 dark:text-neutral-300 leading-relaxed">@_project.Description</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(_project.DeploymentNotes))
                    {
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Deployment notes</dt>
                            <dd class="text-sm text-gray-700 dark:text-neutral-300 leading-relaxed">@_project.DeploymentNotes</dd>
                        </div>
                    }
                </dl>
            </div>

            <!-- Post status update -->
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm p-6">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-5">Post update to client</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1.5">
                            Change status
                            <span class="ml-1 text-xs font-normal text-gray-400 dark:text-neutral-500">(optional)</span>
                        </label>
                        <select @bind="_newStatus" class="@InputClass">
                            <option value="">— Keep current status —</option>
                            @foreach (var s in Enum.GetValues<ProjectStatus>())
                            {
                                <option value="@s">@BadgeHelpers.StatusLabel(s)</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1.5">
                            Message <span class="text-red-500">*</span>
                        </label>
                        <textarea @bind="_updateMessage" rows="3"
                                  placeholder="What's the latest update for this client?"
                                  class="@($"{InputClass} resize-none")"></textarea>
                    </div>
                    <div class="flex justify-end">
                        <button @onclick="PostUpdateAsync"
                                disabled="@(_postingUpdate || string.IsNullOrWhiteSpace(_updateMessage))"
                                class="inline-flex items-center gap-2 rounded-xl bg-indigo-400 dark:bg-orange-400 px-4 py-2.5 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                            @if (_postingUpdate)
                            {
                                <svg class="size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <span>Posting…</span>
                            }
                            else
                            {
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                                </svg>
                                <span>Post update</span>
                            }
                        </button>
                    </div>
                </div>
            </div>

            <!-- Activity timeline -->
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm p-6">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-5">Activity</h2>
                @if (!_project.StatusUpdates.Any())
                {
                    <div class="py-4 text-center">
                        <p class="text-sm text-gray-400 dark:text-neutral-500">No updates posted yet.</p>
                    </div>
                }
                else
                {
                    <ul role="list" class="space-y-5">
                        @foreach (var update in _project.StatusUpdates.OrderByDescending(u => u.CreatedAt))
                        {
                            <li class="relative flex gap-x-4">
                                <div class="absolute top-6 left-[11px] bottom-0 w-px bg-gray-200 dark:bg-white/10 last:hidden"></div>
                                <div class="relative flex size-6 flex-none items-center justify-center">
                                    @if (update.NewStatus.HasValue)
                                    {
                                        <div class="size-6 rounded-full bg-indigo-50 dark:bg-orange-400/10 flex items-center justify-center ring-1 ring-indigo-200 dark:ring-orange-400/20">
                                            <div class="size-2 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="size-6 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center">
                                            <div class="size-1.5 rounded-full bg-gray-300 dark:bg-white/20"></div>
                                        </div>
                                    }
                                </div>
                                <div class="flex-auto pb-5">
                                    @if (update.NewStatus.HasValue)
                                    {
                                        <p class="text-xs text-gray-500 dark:text-neutral-400 mb-0.5">
                                            Status →
                                            <span class="font-semibold text-gray-900 dark:text-white">@BadgeHelpers.StatusLabel(update.NewStatus.Value)</span>
                                        </p>
                                    }
                                    <p class="text-sm text-gray-700 dark:text-neutral-300">@update.Message</p>
                                    <time class="block mt-1 text-xs text-gray-400 dark:text-neutral-500">
                                        @update.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm")
                                    </time>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Right column: invoices -->
        <div class="space-y-6">
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/5">
                    <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Invoices</h2>
                </div>

                @if (!_project.Invoices.Any())
                {
                    <div class="px-6 py-8 text-center">
                        <p class="text-sm text-gray-400 dark:text-neutral-500">No invoices yet.</p>
                    </div>
                }
                else
                {
                    <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                        @foreach (var inv in _project.Invoices.OrderByDescending(i => i.IssuedAt))
                        {
                            <li class="px-6 py-4">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                        <p class="text-xs text-gray-500 dark:text-neutral-400">
                                            @inv.Currency @inv.Amount.ToString("N2") · @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                        </p>
                                    </div>
                                    <span class="inline-flex shrink-0 items-center rounded-full px-2 py-0.5 text-xs font-medium @BadgeHelpers.InvoiceStatusBadge(inv.Status)">
                                        @inv.Status
                                    </span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <select value="@inv.Status"
                                            @onchange="e => ChangeInvoiceStatusAsync(inv.Id, e)"
                                            class="flex-1 text-xs rounded-lg border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-neutral-300 px-2 py-1.5 focus:ring-1 focus:ring-indigo-400 dark:focus:ring-orange-400 outline-none">
                                        @foreach (var s in Enum.GetValues<InvoiceStatus>())
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                    <button @onclick="() => DeleteInvoiceAsync(inv.Id)"
                                            class="text-xs font-medium text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors">
                                        Delete
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                }

                <!-- Upload invoice -->
                <div class="border-t border-gray-100 dark:border-white/5 px-6 py-5">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Upload invoice</h3>
                    @if (!string.IsNullOrEmpty(_invoiceError))
                    {
                        <div class="mb-3 rounded-xl bg-red-50 dark:bg-red-400/10 px-3 py-2 text-xs text-red-600 dark:text-red-400 ring-1 ring-red-200 dark:ring-red-400/20">
                            @_invoiceError
                        </div>
                    }
                    <div class="space-y-3">
                        <input @bind="_invoiceTitle" placeholder="Invoice title *"
                               class="@InputClass" />
                        <div class="grid grid-cols-2 gap-2">
                            <input @bind="_invoiceAmount" type="number" step="0.01" min="0" placeholder="Amount *"
                                   class="@InputClass" />
                            <select @bind="_invoiceCurrency" class="@InputClass">
                                <option value="GBP">GBP £</option>
                                <option value="USD">USD $</option>
                                <option value="EUR">EUR €</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Due date (optional)</label>
                            <input @bind="_invoiceDueDate" type="date" class="@InputClass" />
                        </div>
                        <div class="rounded-xl border-2 border-dashed border-gray-200 dark:border-white/10 p-4 text-center hover:border-indigo-300 dark:hover:border-orange-400/30 transition-colors">
                            <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg"
                                       class="block w-full text-xs text-gray-500 dark:text-neutral-400
                                              file:mr-3 file:rounded-lg file:border-0
                                              file:bg-indigo-50 dark:file:bg-orange-400/10
                                              file:px-3 file:py-1.5 file:text-xs file:font-semibold
                                              file:text-indigo-500 dark:file:text-orange-400
                                              hover:file:opacity-90 cursor-pointer" />
                            <p class="mt-2 text-xs text-gray-400 dark:text-neutral-500">PDF, PNG or JPG — max 10 MB</p>
                        </div>
                        <button @onclick="UploadInvoiceAsync"
                                disabled="@(_uploadingInvoice || _selectedFile is null || string.IsNullOrWhiteSpace(_invoiceTitle))"
                                class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-400 dark:bg-orange-400 px-4 py-2.5 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                            @if (_uploadingInvoice)
                            {
                                <svg class="size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <span>Uploading…</span>
                            }
                            else
                            {
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                                </svg>
                                <span>Upload invoice</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
