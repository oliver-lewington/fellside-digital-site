@page "/Admin/Projects/{Id:guid}"
@attribute [Authorize(Roles = "SiteAdmin")]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services
@using Microsoft.AspNetCore.Components.Forms

@inject IProjectService ProjectService
@inject IInvoiceService InvoiceService
@inject AuthenticationStateProvider AuthState
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Project Detail — Fellside Digital Admin</PageTitle>

<div class="min-h-screen bg-slate-50 dark:bg-neutral-950 pt-24 pb-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        @if (_project is null)
        {
            <p class="text-sm text-slate-500 dark:text-neutral-400">Loading…</p>
        }
        else
        {
            <!-- Header -->
            <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                    <NavLink href="/Admin/Projects"
                             class="text-sm font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-neutral-100">
                        ← Back to projects
                    </NavLink>
                    <h1 class="mt-2 text-2xl font-bold text-slate-900 dark:text-neutral-100">@_project.Name</h1>
                    <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">
                        @_project.Client?.CompanyName · @_project.Client?.Email
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium @StatusBadgeClass(_project.Status)">
                        @StatusLabel(_project.Status)
                    </span>
                    <NavLink href="@($"/Admin/Projects/{Id}/Edit")"
                             class="inline-flex items-center gap-2 rounded-md bg-white dark:bg-white/5 px-4 py-2 text-sm font-semibold text-slate-700 dark:text-neutral-200 ring-1 ring-slate-200 dark:ring-white/10 hover:bg-slate-50 dark:hover:bg-white/10 transition">
                        Edit
                    </NavLink>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">

                <!-- Left column: details + status updates -->
                <div class="lg:col-span-2 space-y-8">

                    <!-- Project details description list -->
                    <div class="rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-100 dark:border-white/10">
                            <h2 class="text-sm font-semibold text-slate-900 dark:text-neutral-100">Project details</h2>
                        </div>
                        <dl class="grid grid-cols-1 sm:grid-cols-2">
                            <div class="border-t border-gray-100 px-6 py-4 sm:col-span-1 dark:border-white/10">
                                <dt class="text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Type</dt>
                                <dd class="mt-1 text-sm text-slate-900 dark:text-neutral-100">@_project.Type</dd>
                            </div>
                            <div class="border-t border-gray-100 px-6 py-4 sm:col-span-1 dark:border-white/10">
                                <dt class="text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Created</dt>
                                <dd class="mt-1 text-sm text-slate-900 dark:text-neutral-100">@_project.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</dd>
                            </div>
                            @if (!string.IsNullOrEmpty(_project.PreviewUrl))
                            {
                                <div class="border-t border-gray-100 px-6 py-4 sm:col-span-2 dark:border-white/10">
                                    <dt class="text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Preview URL</dt>
                                    <dd class="mt-1 text-sm text-indigo-400 dark:text-orange-400 break-all">
                                        <a href="@_project.PreviewUrl" target="_blank" rel="noopener">@_project.PreviewUrl</a>
                                    </dd>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_project.DeploymentNotes))
                            {
                                <div class="border-t border-gray-100 px-6 py-4 sm:col-span-2 dark:border-white/10">
                                    <dt class="text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Deployment notes</dt>
                                    <dd class="mt-1 text-sm text-slate-700 dark:text-neutral-300">@_project.DeploymentNotes</dd>
                                </div>
                            }
                            <div class="border-t border-gray-100 px-6 py-4 sm:col-span-2 dark:border-white/10">
                                <dt class="text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Description</dt>
                                <dd class="mt-1 text-sm text-slate-700 dark:text-neutral-300">@_project.Description</dd>
                            </div>
                        </dl>
                    </div>

                    <!-- Post status update -->
                    <div class="rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm p-6">
                        <h2 class="text-sm font-semibold text-slate-900 dark:text-neutral-100 mb-4">Post status update</h2>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 dark:text-neutral-300 mb-1.5">
                                    Change status
                                    <span class="ml-1 text-xs font-normal text-slate-400">(optional)</span>
                                </label>
                                <select @bind="_newStatus" class="@InputClass">
                                    <option value="">— Keep current status —</option>
                                    @foreach (var s in Enum.GetValues<ProjectStatus>())
                                    {
                                        <option value="@s">@StatusLabel(s)</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 dark:text-neutral-300 mb-1.5">
                                    Message <span class="text-red-500">*</span>
                                </label>
                                <textarea @bind="_updateMessage" rows="3" placeholder="What's the latest update for this client?"
                                          class="@InputClass"></textarea>
                            </div>
                            <div class="flex justify-end">
                                <button @onclick="PostUpdateAsync" disabled="@(_postingUpdate || string.IsNullOrWhiteSpace(_updateMessage))"
                                        class="inline-flex items-center gap-2 rounded-md bg-indigo-400 dark:bg-orange-400 px-4 py-2 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed transition">
                                    @(_postingUpdate ? "Posting…" : "Post update")
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Activity feed -->
                    <div class="rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm p-6">
                        <h2 class="text-sm font-semibold text-slate-900 dark:text-neutral-100 mb-6">Activity</h2>
                        @if (!_project.StatusUpdates.Any())
                        {
                            <p class="text-sm text-slate-400 dark:text-neutral-500">No updates yet.</p>
                        }
                        else
                        {
                            <ul role="list" class="space-y-6">
                                @foreach (var update in _project.StatusUpdates.OrderByDescending(u => u.CreatedAt))
                                {
                                    <li class="relative flex gap-x-4">
                                        <div class="absolute top-0 -bottom-6 left-0 flex w-6 justify-center">
                                            <div class="w-px bg-gray-200 dark:bg-white/10"></div>
                                        </div>
                                        <div class="relative flex size-6 flex-none items-center justify-center bg-white dark:bg-neutral-900">
                                            @if (update.NewStatus.HasValue)
                                            {
                                                <div class="size-2 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                            }
                                            else
                                            {
                                                <div class="size-1.5 rounded-full bg-gray-100 ring-1 ring-gray-300 dark:bg-white/10 dark:ring-white/20"></div>
                                            }
                                        </div>
                                        <div class="flex-auto py-0.5">
                                            @if (update.NewStatus.HasValue)
                                            {
                                                <p class="text-xs text-slate-500 dark:text-neutral-400">
                                                    Status changed to
                                                    <span class="font-medium text-slate-900 dark:text-white">@StatusLabel(update.NewStatus.Value)</span>
                                                </p>
                                            }
                                            <p class="text-sm text-slate-700 dark:text-neutral-300 mt-0.5">@update.Message</p>
                                            <p class="text-xs text-slate-400 dark:text-neutral-500 mt-1">
                                                @update.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm")
                                            </p>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <!-- Right column: invoices -->
                <div class="space-y-6">
                    <div class="rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-100 dark:border-white/10 flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-slate-900 dark:text-neutral-100">Invoices</h2>
                        </div>

                        @if (!_project.Invoices.Any())
                        {
                            <div class="px-6 py-8 text-center">
                                <p class="text-sm text-slate-400 dark:text-neutral-500">No invoices yet.</p>
                            </div>
                        }
                        else
                        {
                            <ul role="list" class="divide-y divide-slate-100 dark:divide-white/5">
                                @foreach (var inv in _project.Invoices.OrderByDescending(i => i.IssuedAt))
                                {
                                    <li class="px-6 py-4 flex items-center justify-between gap-4">
                                        <div class="min-w-0">
                                            <p class="text-sm font-medium text-slate-900 dark:text-neutral-100 truncate">@inv.Title</p>
                                            <p class="text-xs text-slate-500 dark:text-neutral-400">
                                                @inv.Currency @inv.Amount.ToString("N2") · @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                            </p>
                                        </div>
                                        <div class="flex items-center gap-2 shrink-0">
                                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @InvoiceBadgeClass(inv.Status)">
                                                @inv.Status
                                            </span>
                                            <select value="@inv.Status"
                                                    @onchange="e => ChangeInvoiceStatusAsync(inv.Id, e)"
                                                    class="text-xs rounded border border-slate-200 dark:border-white/10 bg-white dark:bg-white/5 text-slate-700 dark:text-neutral-300 px-1 py-0.5">
                                                @foreach (var s in Enum.GetValues<InvoiceStatus>())
                                                {
                                                    <option value="@s">@s</option>
                                                }
                                            </select>
                                            <button @onclick="() => DeleteInvoiceAsync(inv.Id)"
                                                    class="text-xs text-red-500 hover:underline">
                                                Delete
                                            </button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }

                        <!-- Upload invoice form -->
                        <div class="border-t border-slate-100 dark:border-white/10 px-6 py-5">
                            <h3 class="text-sm font-semibold text-slate-900 dark:text-neutral-100 mb-4">Upload invoice</h3>
                            @if (!string.IsNullOrEmpty(_invoiceError))
                            {
                                <p class="mb-3 text-xs text-red-600 dark:text-red-400">@_invoiceError</p>
                            }
                            <div class="space-y-3">
                                <input @bind="_invoiceTitle" placeholder="Invoice title *"
                                       class="@InputClass" />
                                <div class="grid grid-cols-2 gap-2">
                                    <input @bind="_invoiceAmount" type="number" step="0.01" min="0" placeholder="Amount *"
                                           class="@InputClass" />
                                    <select @bind="_invoiceCurrency" class="@InputClass">
                                        <option value="GBP">GBP £</option>
                                        <option value="USD">USD $</option>
                                        <option value="EUR">EUR €</option>
                                    </select>
                                </div>
                                <input @bind="_invoiceDueDate" type="date" class="@InputClass" />
                                <div class="rounded-lg border-2 border-dashed border-slate-200 dark:border-white/10 p-4 text-center">
                                    <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg"
                                               class="block w-full text-xs text-slate-500 dark:text-neutral-400 file:mr-3 file:rounded file:border-0 file:bg-indigo-50 dark:file:bg-orange-400/10 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-indigo-400 dark:file:text-orange-400 hover:file:opacity-90" />
                                    <p class="mt-2 text-xs text-slate-400 dark:text-neutral-500">PDF, PNG or JPG — max 10 MB</p>
                                </div>
                                <button @onclick="UploadInvoiceAsync"
                                        disabled="@(_uploadingInvoice || _selectedFile is null || string.IsNullOrWhiteSpace(_invoiceTitle))"
                                        class="w-full rounded-md bg-indigo-400 dark:bg-orange-400 px-4 py-2 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed transition">
                                    @(_uploadingInvoice ? "Uploading…" : "Upload invoice")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private ClientProject? _project;
    private string _updateMessage = "";
    private string _newStatus = "";
    private bool _postingUpdate;

    private string _invoiceTitle = "";
    private decimal _invoiceAmount;
    private string _invoiceCurrency = "GBP";
    private DateTime? _invoiceDueDate;
    private IBrowserFile? _selectedFile;
    private bool _uploadingInvoice;
    private string? _invoiceError;

    private const string InputClass = "block w-full rounded-md bg-white px-3 py-1.5 text-sm text-slate-900 outline-1 -outline-offset-1 outline-slate-300 placeholder:text-slate-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-400 dark:bg-white/5 dark:text-neutral-100 dark:outline-white/10 dark:placeholder:text-neutral-500 dark:focus:outline-orange-400";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _project = await ProjectService.GetByIdAsync(Id);
    }

    private async Task PostUpdateAsync()
    {
        if (string.IsNullOrWhiteSpace(_updateMessage)) return;
        _postingUpdate = true;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var admin = await UserManager.GetUserAsync(authState.User);
        ProjectStatus? status = Enum.TryParse<ProjectStatus>(_newStatus, out var parsed) ? parsed : null;
        await ProjectService.AddStatusUpdateAsync(Id, _updateMessage.Trim(), status, admin!.Id);
        _updateMessage = "";
        _newStatus = "";
        _postingUpdate = false;
        await LoadAsync();
    }

    private void OnFileSelected(InputFileChangeEventArgs e) => _selectedFile = e.File;

    private async Task UploadInvoiceAsync()
    {
        if (_selectedFile is null || string.IsNullOrWhiteSpace(_invoiceTitle)) return;
        _uploadingInvoice = true;
        _invoiceError = null;
        try
        {
            await InvoiceService.UploadAsync(Id, _invoiceTitle.Trim(), null, _invoiceAmount,
                _invoiceCurrency, _invoiceDueDate, _selectedFile);
            _invoiceTitle = "";
            _invoiceAmount = 0;
            _invoiceDueDate = null;
            _selectedFile = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _invoiceError = ex.Message;
        }
        finally
        {
            _uploadingInvoice = false;
        }
    }

    private async Task ChangeInvoiceStatusAsync(Guid invoiceId, ChangeEventArgs e)
    {
        if (Enum.TryParse<InvoiceStatus>(e.Value?.ToString(), out var status))
            await InvoiceService.UpdateStatusAsync(invoiceId, status);
        await LoadAsync();
    }

    private async Task DeleteInvoiceAsync(Guid invoiceId)
    {
        await InvoiceService.DeleteAsync(invoiceId);
        await LoadAsync();
    }

    private static string StatusLabel(ProjectStatus s) => s switch
    {
        ProjectStatus.InProgress => "In Progress",
        ProjectStatus.OnHold => "On Hold",
        _ => s.ToString()
    };

    private static string StatusBadgeClass(ProjectStatus s) => s switch
    {
        ProjectStatus.InProgress => "bg-blue-50 text-blue-700 ring-1 ring-blue-600/20 dark:bg-blue-400/10 dark:text-blue-400",
        ProjectStatus.Completed  => "bg-green-50 text-green-700 ring-1 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400",
        ProjectStatus.Blocked    => "bg-red-50 text-red-700 ring-1 ring-red-600/20 dark:bg-red-400/10 dark:text-red-400",
        ProjectStatus.OnHold     => "bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20 dark:bg-yellow-400/10 dark:text-yellow-400",
        ProjectStatus.Pending    => "bg-slate-100 text-slate-600 ring-1 ring-slate-500/20 dark:bg-white/5 dark:text-neutral-400",
        _ => ""
    };

    private static string InvoiceBadgeClass(InvoiceStatus s) => s switch
    {
        InvoiceStatus.Paid    => "bg-green-50 text-green-700 ring-1 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400",
        InvoiceStatus.Sent    => "bg-blue-50 text-blue-700 ring-1 ring-blue-600/20 dark:bg-blue-400/10 dark:text-blue-400",
        InvoiceStatus.Overdue => "bg-red-50 text-red-700 ring-1 ring-red-600/20 dark:bg-red-400/10 dark:text-red-400",
        InvoiceStatus.Draft   => "bg-slate-100 text-slate-600 ring-1 ring-slate-500/20 dark:bg-white/5 dark:text-neutral-400",
        _ => ""
    };
}
