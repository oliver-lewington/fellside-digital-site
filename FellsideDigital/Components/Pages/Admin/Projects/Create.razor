@page "/Admin/Projects/Create"
@attribute [Authorize(Roles = "SiteAdmin")]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services

<PageTitle>New Project — Fellside Digital Admin</PageTitle>

<div class="min-h-screen bg-slate-50 dark:bg-neutral-950 pt-24 pb-12">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">

        <div class="mb-8">
            <NavLink href="/Admin/Projects"
                     class="text-sm font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-neutral-100">
                ← Back to projects
            </NavLink>
            <h1 class="mt-4 text-2xl font-bold text-slate-900 dark:text-neutral-100">New client project</h1>
            <p class="mt-1 text-sm text-slate-500 dark:text-neutral-400">
                Assign a project to a client so they can track progress in their portal.
            </p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-6 rounded-md bg-red-50 p-4 dark:bg-red-900/20">
                <p class="text-sm text-red-700 dark:text-red-400">@_errorMessage</p>
            </div>
        }

        <div class="rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-neutral-900 shadow-sm p-6 sm:p-8">
            <EditForm Model="Input" OnValidSubmit="CreateAsync" class="space-y-6">
                <DataAnnotationsValidator />

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Client <span class="text-red-500">*</span>
                    </label>
                    <InputSelect @bind-Value="Input.ClientId" class="@InputClass">
                        <option value="">Select a client…</option>
                        @foreach (var client in _clients)
                        {
                            <option value="@client.Id">@client.CompanyName — @client.Email</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Input.ClientId" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Project name <span class="text-red-500">*</span>
                    </label>
                    <InputText @bind-Value="Input.Name" placeholder="Client Portal v1.0" class="@InputClass" />
                    <ValidationMessage For="() => Input.Name" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Description <span class="text-red-500">*</span>
                    </label>
                    <InputTextArea @bind-Value="Input.Description" rows="3"
                                   placeholder="Brief summary of what is being built…" class="@InputClass" />
                    <ValidationMessage For="() => Input.Description" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                    <div>
                        <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                            Type <span class="text-red-500">*</span>
                        </label>
                        <InputSelect @bind-Value="Input.Type" class="@InputClass">
                            <option value="@ProjectType.Website">Website</option>
                            <option value="@ProjectType.Automation">Automation</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">Status</label>
                        <InputSelect @bind-Value="Input.Status" class="@InputClass">
                            @foreach (var s in Enum.GetValues<ProjectStatus>())
                            {
                                <option value="@s">@StatusLabel(s)</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Railway preview URL
                        <span class="ml-1 text-xs font-normal text-slate-400 dark:text-neutral-500">(iframe embed for client)</span>
                    </label>
                    <InputText @bind-Value="Input.PreviewUrl" placeholder="https://myapp.up.railway.app" class="@InputClass" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Railway project URL
                        <span class="ml-1 text-xs font-normal text-slate-400 dark:text-neutral-500">(external link)</span>
                    </label>
                    <InputText @bind-Value="Input.ProjectUrl" placeholder="https://railway.app/project/..." class="@InputClass" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-900 dark:text-neutral-100 mb-1.5">
                        Deployment notes
                        <span class="ml-1 text-xs font-normal text-slate-400 dark:text-neutral-500">(shown to client)</span>
                    </label>
                    <InputTextArea @bind-Value="Input.DeploymentNotes" rows="2"
                                   placeholder="Any notes about the current deployment…" class="@InputClass" />
                </div>

                <div class="flex items-center justify-end gap-4 pt-2">
                    <NavLink href="/Admin/Projects"
                             class="text-sm font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-neutral-100">
                        Cancel
                    </NavLink>
                    <button type="submit" disabled="@_submitting"
                            class="inline-flex items-center gap-2 rounded-md bg-indigo-400 dark:bg-orange-400 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-90 disabled:opacity-60 disabled:cursor-not-allowed transition">
                        @(_submitting ? "Creating…" : "Create project")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

