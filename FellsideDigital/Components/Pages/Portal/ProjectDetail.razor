@page "/Portal/Projects/{Id:guid}"
@attribute [Authorize]
@layout PortalLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services
@using FellsideDigital.Components.Layout
@using FellsideDigital.Components.Shared

<PageTitle>@(_project?.Name ?? "Project") — Fellside Digital Portal</PageTitle>

@if (_project is null && !_notFound)
{
    <!-- Skeleton loader -->
    <div class="animate-pulse space-y-6">
        <div class="h-4 w-24 rounded-md bg-gray-200 dark:bg-white/10"></div>
        <div class="h-8 w-64 rounded-lg bg-gray-200 dark:bg-white/10"></div>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <div class="lg:col-span-2 space-y-4">
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-48"></div>
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-64"></div>
            </div>
            <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-80"></div>
        </div>
    </div>
}
else if (_notFound)
{
    <div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 p-14 text-center bg-white dark:bg-neutral-900">
        <p class="text-sm font-semibold text-gray-900 dark:text-white">Project not found</p>
        <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">This project doesn't exist or you don't have access to it.</p>
        <NavLink href="/Portal/Projects" class="mt-4 inline-flex text-sm font-medium text-indigo-500 dark:text-orange-400 hover:underline">
            ← Back to projects
        </NavLink>
    </div>
}
else if (_project is not null)
{
    <!-- Back + Page header -->
    <div class="mb-6">
        <NavLink href="/Portal/Projects"
                 class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-3">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            My projects
        </NavLink>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-3">
                    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">@_project.Name</h1>
                    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium @BadgeHelpers.ProjectStatusBadge(_project.Status)">
                        <span class="size-1.5 rounded-full @BadgeHelpers.ProjectStatusDotColor(_project.Status)"></span>
                        @BadgeHelpers.StatusLabel(_project.Status)
                    </span>
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-gray-100 text-gray-600 dark:bg-white/5 dark:text-neutral-400">
                        @_project.Type
                    </span>
                </div>
                <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">
                    Started @_project.CreatedAt.ToLocalTime().ToString("d MMMM yyyy")
                </p>
            </div>
            @if (!string.IsNullOrEmpty(_project.ProjectUrl))
            {
                <a href="@_project.ProjectUrl" target="_blank" rel="noopener"
                   class="inline-flex items-center gap-2 rounded-xl bg-indigo-400 dark:bg-orange-400 px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition shrink-0 shadow-sm">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                    View live site
                </a>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 space-y-6">

            <!-- Railway preview iframe -->
            @if (!string.IsNullOrEmpty(_project.PreviewUrl))
            {
                <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 overflow-hidden bg-white dark:bg-neutral-900 shadow-sm">
                    <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-100 dark:border-white/5 bg-gray-50 dark:bg-white/[0.02]">
                        <div class="flex items-center gap-1.5">
                            <div class="size-2.5 rounded-full bg-red-400"></div>
                            <div class="size-2.5 rounded-full bg-amber-400"></div>
                            <div class="size-2.5 rounded-full bg-emerald-400"></div>
                        </div>
                        <span class="text-xs text-gray-400 dark:text-neutral-500 truncate max-w-[200px] sm:max-w-xs">@_project.PreviewUrl</span>
                        <a href="@_project.PreviewUrl" target="_blank" rel="noopener"
                           class="text-xs font-medium text-indigo-500 dark:text-orange-400 hover:underline flex items-center gap-1">
                            Open
                            <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                            </svg>
                        </a>
                    </div>
                    <iframe src="@_project.PreviewUrl"
                            class="w-full h-[75vh]"
                            title="@_project.Name preview"
                            loading="lazy"
                            sandbox="allow-scripts allow-same-origin allow-forms allow-popups">
                    </iframe>
                </div>
            }

            <!-- Invoices card -->
            @if (_project.Invoices.Any())
            {
                <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-white/5">
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Invoices</h2>
                    </div>
                    <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                        @foreach (var inv in _project.Invoices.OrderByDescending(i => i.IssuedAt))
                        {
                            <li class="flex items-center gap-4 px-6 py-4">
                                <div class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5">
                                    <svg class="size-4 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                    </svg>
                                </div>
                                <div class="min-w-0 flex-1">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                    <p class="text-xs text-gray-500 dark:text-neutral-400">@inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")</p>
                                </div>
                                <div class="flex items-center gap-3 shrink-0">
                                    <span class="text-sm font-semibold text-gray-900 dark:text-white">@inv.Currency @inv.Amount.ToString("N2")</span>
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @BadgeHelpers.InvoiceStatusBadge(inv.Status)">
                                        @inv.Status
                                    </span>
                                    @if (!string.IsNullOrEmpty(inv.FilePath))
                                    {
                                        <a href="@inv.FilePath" download="@inv.FileName"
                                           class="inline-flex items-center gap-1 text-xs font-medium text-indigo-500 dark:text-orange-400 hover:text-indigo-600 dark:hover:text-orange-300 transition-colors">
                                            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                            </svg>
                                            Download
                                        </a>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>



        <!-- Right: activity timeline -->
        <div>
            <!-- Project details card -->
            <div class="mb-6 rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/5">
                    <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Project details</h2>
                </div>
                <dl class="divide-y divide-gray-100 dark:divide-white/5">
                    <div class="grid grid-cols-1 sm:grid-cols-2">
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Service type</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.Type</dd>
                        </div>
                        <div class="px-6 py-4 border-t sm:border-t-0 sm:border-l border-gray-100 dark:border-white/5">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Started</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.CreatedAt.ToLocalTime().ToString("d MMMM yyyy")</dd>
                        </div>
                    </div>
                    <div class="px-6 py-4">
                        <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Description</dt>
                        <dd class="text-sm text-gray-600 dark:text-neutral-300 leading-relaxed">@_project.Description</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(_project.DeploymentNotes))
                    {
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Deployment notes</dt>
                            <dd class="text-sm text-gray-600 dark:text-neutral-300 leading-relaxed">@_project.DeploymentNotes</dd>
                        </div>
                    }
                </dl>
            </div>
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/5">
                    <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Project updates</h2>
                </div>
                <div class="px-6 py-5">
                    @if (!_project.StatusUpdates.Any())
                    {
                        <div class="py-6 text-center">
                            <div class="mx-auto mb-3 flex size-9 items-center justify-center rounded-xl bg-gray-100 dark:bg-white/5">
                                <svg class="size-4 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
                                </svg>
                            </div>
                            <p class="text-xs text-gray-500 dark:text-neutral-400">No updates yet.</p>
                        </div>
                    }
                    else
                    {
                        <ul role="list" class="space-y-5">
                            @{
                                var updates = _project.StatusUpdates.OrderByDescending(u => u.CreatedAt).ToList();
                            }
                            @for (int i = 0; i < updates.Count; i++)
                            {
                                var update = updates[i];
                                var isLast = i == updates.Count - 1;
                                <li class="relative flex gap-x-4">
                                    @if (!isLast)
                                    {
                                        <div class="absolute top-6 left-[11px] bottom-0 w-px bg-gray-200 dark:bg-white/10"></div>
                                    }
                                    <div class="relative flex size-6 flex-none items-center justify-center">
                                        @if (update.NewStatus.HasValue)
                                        {
                                            <div class="size-6 rounded-full bg-indigo-50 dark:bg-orange-400/10 flex items-center justify-center ring-1 ring-indigo-200 dark:ring-orange-400/20">
                                                <div class="size-2 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="size-6 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center">
                                                <div class="size-1.5 rounded-full bg-gray-300 dark:bg-white/20"></div>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-auto min-w-0 pb-5">
                                        @if (update.NewStatus.HasValue)
                                        {
                                            <p class="text-xs text-gray-500 dark:text-neutral-400 mb-0.5">
                                                Status →
                                                <span class="font-semibold text-gray-900 dark:text-white">@BadgeHelpers.StatusLabel(update.NewStatus.Value)</span>
                                            </p>
                                        }
                                        <p class="text-sm text-gray-700 dark:text-neutral-300 leading-relaxed">@update.Message</p>
                                        <time class="block mt-1 text-xs text-gray-400 dark:text-neutral-500">
                                            @update.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm")
                                        </time>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}
