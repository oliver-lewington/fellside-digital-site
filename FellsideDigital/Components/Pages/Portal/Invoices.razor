@page "/Portal/Invoices"
@attribute [Authorize]
@layout PortalLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services
@using FellsideDigital.Components.Layout
@using FellsideDigital.Components.Shared

<PageTitle>Invoices — Fellside Digital Portal</PageTitle>

<!-- Page header -->
<div class="mb-8">
    <p class="text-xs font-semibold text-indigo-500 dark:text-orange-400 uppercase tracking-widest mb-1">Billing</p>
    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Invoices</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">All invoices raised against your projects.</p>
</div>

@if (_invoices is null)
{
    <!-- Skeleton loader -->
    <div class="animate-pulse space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 p-5 h-24"></div>
            }
        </div>
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-64"></div>
    </div>
}
else if (!_invoices.Any())
{
    <div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 p-14 text-center bg-white dark:bg-neutral-900">
        <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-2xl bg-gray-100 dark:bg-white/5">
            <svg class="size-6 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
        </div>
        <p class="text-sm font-semibold text-gray-900 dark:text-white">No invoices yet</p>
        <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">Invoices will appear here once your project manager raises them.</p>
    </div>
}
else
{
    <!-- Stats row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">

        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Outstanding</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-amber-50 dark:bg-amber-400/10">
                    <svg class="size-4 text-amber-500 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </span>
            </div>
            <p class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                £@_invoices.Where(i => i.Status is InvoiceStatus.Sent or InvoiceStatus.Overdue).Sum(i => i.Amount).ToString("N2")
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Awaiting payment</p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Paid</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-emerald-50 dark:bg-emerald-400/10">
                    <svg class="size-4 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </span>
            </div>
            <p class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                £@_invoices.Where(i => i.Status == InvoiceStatus.Paid).Sum(i => i.Amount).ToString("N2")
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Total paid to date</p>
        </div>

        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Total</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-indigo-50 dark:bg-orange-400/10">
                    <svg class="size-4 text-indigo-500 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                    </svg>
                </span>
            </div>
            <p class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                £@_invoices.Sum(i => i.Amount).ToString("N2")
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Total invoiced</p>
        </div>

    </div>

    <!-- Invoice table -->
    <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-100 dark:divide-white/5">
            <thead>
                <tr class="bg-gray-50/80 dark:bg-white/[0.02]">
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Invoice</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden sm:table-cell">Project</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden md:table-cell">Due</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Amount</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">File</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                @foreach (var inv in _invoices)
                {
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-white/[0.02] transition-colors">
                        <td class="px-6 py-4">
                            <p class="text-sm font-medium text-gray-900 dark:text-white">@inv.Title</p>
                            <p class="text-xs text-gray-500 dark:text-neutral-400 mt-0.5">@inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")</p>
                        </td>
                        <td class="px-6 py-4 hidden sm:table-cell">
                            <span class="text-sm text-gray-700 dark:text-neutral-300">@inv.Project?.Name</span>
                        </td>
                        <td class="px-6 py-4 hidden md:table-cell">
                            <span class="text-sm text-gray-500 dark:text-neutral-400">
                                @(inv.DueAt.HasValue ? inv.DueAt.Value.ToLocalTime().ToString("d MMM yyyy") : "—")
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">@inv.Currency @inv.Amount.ToString("N2")</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @BadgeHelpers.InvoiceStatusBadge(inv.Status)">
                                @inv.Status
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            @if (!string.IsNullOrEmpty(inv.FilePath))
                            {
                                <a href="@inv.FilePath" download="@inv.FileName"
                                   class="inline-flex items-center gap-1 text-xs font-medium text-indigo-500 dark:text-orange-400 hover:text-indigo-600 dark:hover:text-orange-300 transition-colors">
                                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                    </svg>
                                    PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-xs text-gray-400 dark:text-neutral-500">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
