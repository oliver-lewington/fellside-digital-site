@page "/Portal"
@attribute [Authorize]
@layout PortalLayout

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Data
@using FellsideDigital.Services
@using FellsideDigital.Components.Layout
@using FellsideDigital.Components.Shared

<PageTitle>Overview — Fellside Digital Portal</PageTitle>

@if (!string.IsNullOrEmpty(_userId))
{
    <!-- Page header -->
    <div class="mb-8">
        <p class="text-xs font-semibold text-indigo-500 dark:text-orange-400 uppercase tracking-widest mb-1">Dashboard</p>
        <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
            Welcome back, @_displayName
        </h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">
            Here's everything happening with your account.
        </p>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4 mb-8">

        <div class="col-span-1 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Active</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-400/10">
                    <svg class="size-4 text-blue-500 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                    </svg>
                </span>
            </div>
            <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
                @_projects.Count(p => p.Status == ProjectStatus.InProgress)
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Projects in progress</p>
        </div>

        <div class="col-span-1 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Projects</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-indigo-50 dark:bg-orange-400/10">
                    <svg class="size-4 text-indigo-500 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
                    </svg>
                </span>
            </div>
            <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">@_projects.Count</p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Total projects</p>
        </div>

        <div class="col-span-1 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Outstanding</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-amber-50 dark:bg-amber-400/10">
                    <svg class="size-4 text-amber-500 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </span>
            </div>
            <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
                £@_invoices.Where(i => i.Status is InvoiceStatus.Sent or InvoiceStatus.Overdue).Sum(i => i.Amount).ToString("N0")
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Awaiting payment</p>
        </div>

        <div class="col-span-1 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Paid</span>
                <span class="flex size-7 items-center justify-center rounded-lg bg-emerald-50 dark:bg-emerald-400/10">
                    <svg class="size-4 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                </span>
            </div>
            <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
                £@_invoices.Where(i => i.Status == InvoiceStatus.Paid).Sum(i => i.Amount).ToString("N0")
            </p>
            <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Total paid</p>
        </div>

    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-5">

        <!-- Projects column (wider) -->
        <div class="lg:col-span-3 space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white">My projects</h2>
                <NavLink href="/Portal/Projects"
                         class="flex items-center gap-1 text-xs font-medium text-indigo-500 dark:text-orange-400 hover:text-indigo-600 dark:hover:text-orange-300 transition-colors">
                    View all
                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                </NavLink>
            </div>

            @if (!_projects.Any())
            {
                <div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 p-10 text-center bg-white dark:bg-neutral-900">
                    <div class="mx-auto mb-3 flex size-10 items-center justify-center rounded-xl bg-gray-100 dark:bg-white/5">
                        <svg class="size-5 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900 dark:text-white">No projects yet</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Your project manager will set this up shortly.</p>
                </div>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var project in _projects.Take(4))
                    {
                        <NavLink href="@($"/Portal/Projects/{project.Id}")"
                                 class="group flex items-center justify-between rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 p-4 hover:border-indigo-200 dark:hover:border-orange-400/20 hover:shadow-sm transition-all">
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="flex size-9 shrink-0 items-center justify-center rounded-xl bg-gray-100 dark:bg-white/5 group-hover:bg-indigo-50 dark:group-hover:bg-orange-400/10 transition-colors">
                                    <svg class="size-4 text-gray-400 dark:text-neutral-500 group-hover:text-indigo-500 dark:group-hover:text-orange-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white truncate group-hover:text-indigo-600 dark:group-hover:text-orange-400 transition-colors">
                                        @project.Name
                                    </p>
                                    <p class="text-xs text-gray-500 dark:text-neutral-400 truncate">@project.Type</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 shrink-0 ml-3">
                                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @BadgeHelpers.ProjectStatusBadge(project.Status)">
                                    @BadgeHelpers.StatusLabel(project.Status)
                                </span>
                                <svg class="size-4 text-gray-300 dark:text-neutral-600 group-hover:text-indigo-400 dark:group-hover:text-orange-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                            </div>
                        </NavLink>
                    }
                </div>
            }
        </div>

        <!-- Invoices column (narrower) -->
        <div class="lg:col-span-2 space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Recent invoices</h2>
                <NavLink href="/Portal/Invoices"
                         class="flex items-center gap-1 text-xs font-medium text-indigo-500 dark:text-orange-400 hover:text-indigo-600 dark:hover:text-orange-300 transition-colors">
                    View all
                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                </NavLink>
            </div>

            @if (!_invoices.Any())
            {
                <div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 p-10 text-center bg-white dark:bg-neutral-900">
                    <div class="mx-auto mb-3 flex size-10 items-center justify-center rounded-xl bg-gray-100 dark:bg-white/5">
                        <svg class="size-5 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900 dark:text-white">No invoices yet</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Invoices will appear here once raised.</p>
                </div>
            }
            else
            {
                <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 overflow-hidden shadow-sm">
                    <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                        @foreach (var inv in _invoices.Take(5))
                        {
                            <li class="flex items-center gap-3 px-4 py-3.5 hover:bg-gray-50 dark:hover:bg-white/[0.02] transition-colors">
                                <div class="min-w-0 flex-1">
                                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                    <p class="text-xs text-gray-500 dark:text-neutral-400 truncate">
                                        @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                    </p>
                                </div>
                                <div class="shrink-0 text-right">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">£@inv.Amount.ToString("N0")</p>
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @BadgeHelpers.InvoiceStatusBadge(inv.Status)">
                                        @inv.Status
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

    </div>
}
