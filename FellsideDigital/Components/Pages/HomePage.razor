@code {
    private List<Offering> offerings = new()
    {
        new Offering("Foundational Websites",
            "Clean, fast, well-engineered websites for organisations that need a professional presence without unnecessary complexity.",
            "From £450", new[] { "1–3 page builds", "Mobile-first", "SEO-ready", "High performance" }, "/foundational"),
        new Offering("Software-Driven Websites",
            "More advanced builds with dynamic content, and maintainable architectures designed to evolve with your business.",
            "Project-based", new[] { "CMS & content modelling", "Integrations & APIs", "Analytics & monitoring", "Scalable foundations" }, "/software"),
        new Offering("Bespoke Software Systems",
            "Fully custom applications and internal systems built around your workflows, data, and long-term operational needs.",
            "Custom", new[] { "Architecture & system design", "Backend & API development", "Performance & reliability", "Ongoing support" }, "/bespoke")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Any async data fetching would go here before FinishLoading()

        // Dismiss the loader — page becomes visible
        await FinishLoading();

        await JS.InvokeVoidAsync("fellsideScroll.init");

        // ── HERO SEQUENCE ──────────────────────────────────────
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#auth-links",    new { distance = -16, duration = 600, startDelay = 200 });
        await JS.InvokeVoidAsync("fellsideAnime.blurClear", "#hero-heading", new { duration = 1000, stagger = 80, distance = 12, startDelay = 150 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWords", "#hero-sub",  new { distance = 24, duration = 700, stagger = 60, startDelay = 900 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#hero-cta",       new { distance = 20, duration = 600, startDelay = 1400 });

        // ── OFFERINGS SEQUENCE ─────────────────────────────────
        await JS.InvokeVoidAsync("fellsideAnime.flipInWordsOnScroll", "#offerings-title",   new { duration = 700, stagger = 120 });
        await JS.InvokeVoidAsync("fellsideAnime.drawUnderline", "#offerings-underline",     new { duration = 600, startDelay = 1000 });
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#offerings-cards > div", new { from = 0.90, duration = 700, stagger = 150 });

        // ── WHY PILLARS ────────────────────────────────────────
        await JS.InvokeVoidAsync("fellsideAnime.elasticPopOnScroll", "#why-pillars > div", new { stagger = 120, startDelay = 100 });
    }

    private async Task OnClickTest()
    {
        await Task.Delay(800);
    }

    private async Task OnToggleTest()
    {
        await Task.Delay(800);
    }

    private async Task OnCardClick(string link)
    {
        await Task.Delay(800);
        NavigationManager.NavigateTo(link);
    }

    private async Task ScrollToOfferings() =>
        await JS.InvokeVoidAsync("fellsideScroll.toOfferings", "offerings");

    public record Offering(string Title, string Description, string Price, string[] Features, string Link);
}