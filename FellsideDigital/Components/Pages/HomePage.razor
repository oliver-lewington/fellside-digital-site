            <div class="hero-glow" aria-hidden="true"></div>

                <div id="auth-links" class="animated absolute top-6 right-6 text-sm text-neutral-400 space-x-4">
                <a href="/login" class="hover:text-accent transition">Existing customer login</a>
                <span class="text-neutral-600">|</span>
                <a href="/admin" class="hover:text-accent transition">Admin login</a>
