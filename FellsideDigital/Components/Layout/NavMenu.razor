@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Nav

<nav class="fixed inset-x-0 top-0 z-50
            border-b border-gray-200 dark:border-white/10
            bg-white/80 dark:bg-gray-900/80
            backdrop-blur-2xl backdrop-saturate-200
            supports-[backdrop-filter]:bg-white/70
            dark:supports-[backdrop-filter]:bg-gray-900/70">

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 justify-between">

            @* ── Left: logo + nav links ────────────────────────────── *@
            <div class="flex">

                @* Logo *@
                <div class="flex shrink-0 items-center">
                    <img src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600"
                         alt="Your Company"
                         class="h-8 w-auto dark:hidden" />
                    <img src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500"
                         alt="Your Company"
                         class="h-8 w-auto not-dark:hidden" />
                </div>

                @* Desktop nav links *@
                <div class="hidden sm:-my-px sm:ml-6 sm:flex sm:space-x-8">
                    @* Mark the current page link with aria-current="page" and the active classes *@
                    <a href="#"
                       aria-current="page"
                       class="inline-flex items-center border-b-2 border-indigo-600
                              px-1 pt-1 text-sm font-medium text-gray-900
                              dark:border-indigo-500 dark:text-white">
                        Dashboard
                    </a>
                    @foreach (var (label, href) in _navLinks)
                    {
                        <a href="@href"
                           class="inline-flex items-center border-b-2 border-transparent
                                      px-1 pt-1 text-sm font-medium
                                      text-gray-500 dark:text-gray-400
                                      hover:border-gray-300 dark:hover:border-white/20
                                      hover:text-gray-700 dark:hover:text-gray-200
                                      transition-colors duration-150">
                            @label
                        </a>
                    }
                </div>
            </div>

            @* ── Right: bell + auth ────────────────────────────────── *@
            <div class="hidden sm:ml-6 sm:flex sm:items-center">

                <AuthorizeView>

                    @* ── Authenticated ─────────────────────────────── *@
                    <Authorized>

                        @* Notification bell *@
                        <button type="button"
                                class="relative rounded-full p-1
                                       text-gray-400 hover:text-gray-500
                                       dark:text-gray-400 dark:hover:text-white
                                       focus:outline-2 focus:outline-offset-2
                                       focus:outline-indigo-600 dark:focus:outline-indigo-500">
                            <span class="absolute -inset-1.5"></span>
                            <span class="sr-only">View notifications</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.5" aria-hidden="true" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0
                                         0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312
                                         6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255
                                         0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                            </svg>
                            @if (_hasNotifications)
                            {
                                <span class="absolute top-0.5 right-0.5 block h-2 w-2 rounded-full
                                                 bg-indigo-500 ring-2 ring-white dark:ring-gray-900"></span>
                            }
                        </button>

                        @* Profile dropdown *@
                        <div class="relative ml-3">
                            <button type="button"
                                    @onclick="ToggleDropdown"
                                    class="relative flex max-w-xs items-center rounded-full
                                           focus-visible:outline-2 focus-visible:outline-offset-2
                                           focus-visible:outline-indigo-600
                                           dark:focus-visible:outline-indigo-500">
                                <span class="absolute -inset-1.5"></span>
                                <span class="sr-only">Open user menu</span>
                                @if (!string.IsNullOrEmpty(context.User.FindFirst("picture")?.Value))
                                {
                                    <img src="@context.User.FindFirst("picture")!.Value"
                                         alt=""
                                         class="size-8 rounded-full outline -outline-offset-1
                                                    outline-black/5 dark:outline-white/10" />
                                }
                                else
                                {
                                    @* Initials fallback *@
                                    <div class="size-8 rounded-full bg-indigo-600 dark:bg-indigo-500
                                                    flex items-center justify-center
                                                    outline -outline-offset-1 outline-black/5 dark:outline-white/10">
                                        <span class="text-xs font-semibold text-white leading-none">
                                            @GetInitials(context.User.Identity?.Name)
                                        </span>
                                    </div>
                                }
                            </button>

                            @* Dropdown panel *@
                            @if (_dropdownOpen)
                            {
                                <div class="absolute right-0 z-10 mt-2 w-48 origin-top-right
                                                rounded-md bg-white dark:bg-gray-800
                                                py-1 shadow-lg
                                                outline outline-black/5 dark:outline-white/10
                                                dark:-outline-offset-1
                                                transition"
                                     @onclick:stopPropagation="true">

                                    @* Optional: user name/email header *@
                                    <div class="border-b border-gray-100 dark:border-white/10 px-4 py-2">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                                            @context.User.Identity?.Name
                                        </p>
                                        <p class="text-xs text-gray-500 dark:text-gray-400 truncate mt-0.5">
                                            @context.User.FindFirst("email")?.Value
                                        </p>
                                    </div>

                                    <a href="/portal/profile"
                                       class="block px-4 py-2 text-sm
                                                  text-gray-700 dark:text-gray-300
                                                  hover:bg-gray-100 dark:hover:bg-white/5
                                                  focus:bg-gray-100 dark:focus:bg-white/5
                                                  focus:outline-hidden">
                                        Your profile
                                    </a>
                                    <a href="/portal/settings"
                                       class="block px-4 py-2 text-sm
                                                  text-gray-700 dark:text-gray-300
                                                  hover:bg-gray-100 dark:hover:bg-white/5
                                                  focus:bg-gray-100 dark:focus:bg-white/5
                                                  focus:outline-hidden">
                                        Settings
                                    </a>
                                    <form method="post" action="/Account/Logout">
                                        <AntiforgeryToken />
                                        <button type="submit"
                                                class="block w-full text-left px-4 py-2 text-sm
                                                           text-gray-700 dark:text-gray-300
                                                           hover:bg-gray-100 dark:hover:bg-white/5
                                                           focus:bg-gray-100 dark:focus:bg-white/5
                                                           focus:outline-hidden">
                                            Sign out
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                    </Authorized>

                    @* ── Not authenticated: Login → ─────────────────── *@
                    <NotAuthorized>
                        <a href="/Account/Login"
                           class="group inline-flex items-center gap-2
                                  text-sm font-semibold
                                  text-slate-700 dark:text-neutral-200
                                  hover:text-accent
                                  transition-colors">
                            Login

                            <span class="transition-transform duration-200 group-hover:translate-x-0.5">
                                →
                            </span>
                        </a>
                    </NotAuthorized>

                </AuthorizeView>
            </div>

            @* ── Mobile hamburger ──────────────────────────────────── *@
            <div class="-mr-2 flex items-center sm:hidden">
                <button type="button"
                        @onclick="() => _mobileMenuOpen = !_mobileMenuOpen"
                        class="relative inline-flex items-center justify-center rounded-md
                               bg-white dark:bg-gray-900 p-2
                               text-gray-400 dark:text-gray-400
                               hover:bg-gray-100 dark:hover:bg-white/5
                               hover:text-gray-500 dark:hover:text-white
                               focus:outline-2 focus:outline-offset-2
                               focus:outline-indigo-600 dark:focus:outline-indigo-500">
                    <span class="absolute -inset-0.5"></span>
                    <span class="sr-only">Open main menu</span>
                    @if (_mobileMenuOpen)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.5" aria-hidden="true" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.5" aria-hidden="true" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                        </svg>
                    }
                </button>
            </div>

        </div>
    </div>

    @* ── Mobile menu panel ─────────────────────────────────────────── *@
    @if (_mobileMenuOpen)
    {
        <div class="sm:hidden">

            @* Nav links *@
            <div class="space-y-1 pt-2 pb-3">
                <a href="#"
                   aria-current="page"
                   class="block border-l-4 border-indigo-600 dark:border-indigo-500
                              bg-indigo-50 dark:bg-indigo-600/10
                              py-2 pr-4 pl-3 text-base font-medium
                              text-indigo-700 dark:text-indigo-300">
                    Dashboard
                </a>
                @foreach (var (label, href) in _navLinks)
                {
                    <a href="@href"
                       @onclick="() => _mobileMenuOpen = false"
                       class="block border-l-4 border-transparent
                                      py-2 pr-4 pl-3 text-base font-medium
                                      text-gray-600 dark:text-gray-400
                                      hover:border-gray-300 dark:hover:border-gray-500
                                      hover:bg-gray-50 dark:hover:bg-white/5
                                      hover:text-gray-800 dark:hover:text-gray-200
                                      transition-colors duration-150">
                        @label
                    </a>
                }
            </div>

            @* User section *@
            <div class="border-t border-gray-200 dark:border-gray-700 pt-4 pb-3">
                <AuthorizeView>
                    <Authorized>
                        <div class="flex items-center px-4">
                            <div class="shrink-0">
                                @if (!string.IsNullOrEmpty(context.User.FindFirst("picture")?.Value))
                                {
                                    <img src="@context.User.FindFirst("picture")!.Value"
                                         alt=""
                                         class="size-10 rounded-full outline -outline-offset-1
                                                        outline-black/5 dark:outline-white/10" />
                                }
                                else
                                {
                                    <div class="size-10 rounded-full bg-indigo-600 dark:bg-indigo-500
                                                        flex items-center justify-center">
                                        <span class="text-sm font-semibold text-white">
                                            @GetInitials(context.User.Identity?.Name)
                                        </span>
                                    </div>
                                }
                            </div>
                            <div class="ml-3">
                                <div class="text-base font-medium
                                                text-gray-800 dark:text-white">
                                    @context.User.Identity?.Name
                                </div>
                                <div class="text-sm font-medium
                                                text-gray-500 dark:text-gray-400">
                                    @context.User.FindFirst("email")?.Value
                                </div>
                            </div>
                            @* Bell *@
                            <button type="button"
                                    class="relative ml-auto shrink-0 rounded-full p-1
                                               text-gray-400 hover:text-gray-500
                                               dark:text-gray-400 dark:hover:text-white
                                               focus:outline-2 focus:outline-offset-2
                                               focus:outline-indigo-600 dark:focus:outline-indigo-500">
                                <span class="absolute -inset-1.5"></span>
                                <span class="sr-only">View notifications</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.5" aria-hidden="true" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967
                                                 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0
                                                 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714
                                                 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                                </svg>
                            </button>
                        </div>
                        <div class="mt-3 space-y-1">
                            <a href="/portal/profile"
                               class="block px-4 py-2 text-base font-medium
                                          text-gray-500 dark:text-gray-400
                                          hover:bg-gray-100 dark:hover:bg-white/5
                                          hover:text-gray-800 dark:hover:text-gray-200">
                                Your profile
                            </a>
                            <a href="/portal/settings"
                               class="block px-4 py-2 text-base font-medium
                                          text-gray-500 dark:text-gray-400
                                          hover:bg-gray-100 dark:hover:bg-white/5
                                          hover:text-gray-800 dark:hover:text-gray-200">
                                Settings
                            </a>
                            <form method="post" action="/Account/Logout">
                                <AntiforgeryToken />
                                <button type="submit"
                                        class="block w-full text-left px-4 py-2 text-base font-medium
                                                   text-gray-500 dark:text-gray-400
                                                   hover:bg-gray-100 dark:hover:bg-white/5
                                                   hover:text-gray-800 dark:hover:text-gray-200">
                                    Sign out
                                </button>
                            </form>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="px-4 py-3">
                            <a href="/Account/Login"
                               class="group inline-flex items-center gap-1
                                          text-base font-medium
                                          text-gray-500 dark:text-gray-400
                                          hover:text-gray-800 dark:hover:text-gray-200
                                          transition-colors duration-150">
                                Login
                                <span class="inline-block transition-transform duration-200
                                                 group-hover:translate-x-0.5">→</span>
                            </a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

        </div>
    }

</nav>

@* ── Click-outside to close dropdown ─────────────────────────────────── *@
@if (_dropdownOpen)
{
    <div class="fixed inset-0 z-40" @onclick="CloseDropdown"></div>
}

@code {
    private bool _mobileMenuOpen;
    private bool _dropdownOpen;
    private bool _hasNotifications = true;

    private static readonly (string Label, string Href)[] _navLinks =
    {
        ("Team",      "#team"),
        ("Projects",  "#projects"),
        ("Calendar",  "#calendar"),
    };

    private void ToggleDropdown() => _dropdownOpen = !_dropdownOpen;
    private void CloseDropdown() => _dropdownOpen = false;

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private async Task ToggleDarkMode() =>
        await JS.InvokeVoidAsync("fellsideTheme.toggle");
}
