@using FellsideDigital.Components.Home
@using FellsideDigital.Components.Shared
@inject IJSRuntime JS
@inherits LayoutComponentBase
<div class="flex flex-col min-h-screen
            bg-white dark:bg-black
            text-gray-900 dark:text-gray-100">
    <main class="flex flex-col flex-1 w-full">
        @Body
    </main>
    <!-- FOOTER -->
    <footer class="py-6 px-6 border-t border-gray-200 dark:border-gray-800">
        <div class="max-w-6xl mx-auto flex flex-row flex-wrap justify-between items-center gap-4">
            <!-- COPYRIGHT -->
            <p class="text-sm text-gray-500 dark:text-gray-400">
                © @DateTime.Now.Year Fellside Digital Ltd · Cumbria, UK
            </p>
            <!-- SOCIAL ICONS & TOGGLE -->
            <div class="flex items-center gap-4 flex-wrap">
                <!-- Instagram -->
                <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-indigo-400 dark:hover:text-orange-400 transition">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm5 5.3a4.7 4.7 0 100 9.4 4.7 4.7 0 000-9.4zM17.5 6.5a1 1 0 100 2 1 1 0 000-2z" />
                    </svg>
                </a>
                <!-- LinkedIn -->
                <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-indigo-400 dark:hover:text-orange-400 transition">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M4.98 3.5a2.5 2.5 0 110 5 2.5 2.5 0 010-5zM3 9h4v12H3zM9 9h4v1.7h.1a4.4 4.4 0 014-2.2c4.3 0 5.1 2.8 5.1 6.5V21h-4v-5.2c0-1.2 0-2.8-1.7-2.8-1.7 0-2 1.3-2 2.7V21H9z" />
                    </svg>
                </a>
                <!-- GitHub -->
                <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-indigo-400 dark:hover:text-orange-400 transition">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.3 6.8 9.6.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.4-3.4-1.4-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1.8 2.1 2.8 1.5.1-.7.4-1.2.7-1.5-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.2-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.3 9.3 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.4.1 2.6.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .4.3.8 1 .8 2v3c0 .3.2.6.7.5A10.2 10.2 0 0022 12.2C22 6.6 17.5 2 12 2z" />
                    </svg>
                </a>
                <span class="text-gray-400 dark:text-gray-500">|</span>
                <!-- Dark mode toggle -->
                <DarkModeToggle />
            </div>
        </div>
    </footer>
</div>
