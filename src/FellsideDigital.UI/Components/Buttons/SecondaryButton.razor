@if (!string.IsNullOrEmpty(Href))
{
    <a href="@Href" class="@_classes">@ChildContent</a>
}
else
{
    <button type="@Type" @onclick="OnClick" disabled="@Disabled" class="@_classes">
        @ChildContent
    </button>
}

@code {
    [Parameter] public string? Href { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string _classes =>
        $"inline-flex items-center gap-2 rounded-xl bg-white dark:bg-white/5 px-4 py-2.5 " +
        $"text-sm font-semibold text-gray-700 dark:text-neutral-200 " +
        $"ring-1 ring-gray-200 dark:ring-white/10 hover:bg-gray-50 dark:hover:bg-white/10 " +
        $"disabled:opacity-50 disabled:cursor-not-allowed transition-all {Class}".TrimEnd();
}
