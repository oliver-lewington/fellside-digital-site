@using FellsideDigital.UI.Enums

<button type="@Type"
        @onclick="OnClick"
        disabled="@(IsLoading || Disabled)"
        class="@_classes">
    @if (IsLoading)
    {
        <svg class="size-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>@LoadingText</span>
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Loading…";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Type { get; set; } = "submit";
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool FullWidth { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public ButtonColor Color { get; set; } = ButtonColor.Accent;
    [Parameter] public ButtonStyle Style { get; set; } = ButtonStyle.Solid;

    private string _classes => ButtonStyles.Get(Color, Style, FullWidth, Class);
}
