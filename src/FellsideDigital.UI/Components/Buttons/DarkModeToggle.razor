<button onclick="fellsideTheme.toggle()"
        aria-label="Toggle colour scheme"
        class="group hover:bg-accent/10
            inline-flex items-center justify-center
            rounded-full
            ring-1 ring-black/10 dark:ring-white/10
            text-slate-400 dark:text-neutral-500
            hover:ring-accent/40
            hover:text-accent
            active:scale-95"
        style="width:@($"{Size}px"); height:@($"{Size}px");">

    <!-- Sun (visible in dark mode) -->
    <svg class="hidden dark:block"
         style="width:@($"{IconSize}px"); height:@($"{IconSize}px");"
         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
    </svg>

    <!-- Moon (visible in light mode) -->
    <svg class="block dark:hidden"
         style="width:@($"{IconSize}px"); height:@($"{IconSize}px");"
         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
    </svg>
</button>

@code {
    [Parameter]
    public int Size { get; set; } = 24;

    private int IconSize => (int)(Size * 0.58);
}