@if (!string.IsNullOrEmpty(Href))
{
    <a href="@Href" class="@_classes">@ChildContent</a>
}
else
{
    <button type="@Type" @onclick="OnClick" disabled="@Disabled" class="@_classes">
        @ChildContent
    </button>
}

@code {
    [Parameter] public string? Href { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string _classes =>
        $"inline-flex items-center justify-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-white " +
        $"bg-indigo-600 hover:bg-indigo-700 dark:bg-orange-500 dark:hover:bg-orange-600 " +
        $"disabled:opacity-50 transition-colors {Class}".TrimEnd();
}
