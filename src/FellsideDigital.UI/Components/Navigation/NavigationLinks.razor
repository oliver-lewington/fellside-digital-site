@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager NavigationManager

<div class="@BaseClass">
    @foreach (var (label, href) in Links)
    {
        var isActive = IsLinkActive(href);
        var cssClass = isActive ? ActiveClass : LinkClass;

        <a href="@href"
           @onclick="HandleClick"
           @onclick:preventDefault="false"
           class="@cssClass">
            @label
        </a>
    }
</div>

@code {
    [Parameter] public (string Label, string Href)[] Links { get; set; } = [];
    [Parameter] public string BaseClass { get; set; } = "";
    [Parameter] public string LinkClass { get; set; } = "";
    [Parameter] public string ActiveClass { get; set; } = "";
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
    [Parameter] public EventCallback OnClick { get; set; }

    private bool IsLinkActive(string href)
    {
        var currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

        if (Match == NavLinkMatch.All)
        {
            // Exact match
            return string.Equals(currentUrl, href.TrimStart('/'), StringComparison.OrdinalIgnoreCase) ||
                   (string.IsNullOrEmpty(currentUrl) && href == "/");
        }
        else
        {
            // Prefix match
            return currentUrl.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
        }
    }

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
    }
}