@inject NavigationManager NavigationManager

<div class="group relative hidden sm:flex items-stretch self-stretch">

    <span class="absolute inset-x-0 bottom-0 h-0.5 transition-colors duration-150
                 @(IsAnyChildActive() ? "bg-accent" : "bg-transparent group-hover:bg-gray-300 dark:group-hover:bg-white/20")"></span>

    <button type="button"
            class="@(IsAnyChildActive() ? ActiveTriggerClass : TriggerClass)
                   inline-flex h-full items-center gap-1">
        @Label
        <svg class="h-3.5 w-3.5 transition-transform duration-150 group-hover:rotate-180"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
    </button>

    <div class="absolute left-1/2 top-full z-50 w-44 -translate-x-1/2 pt-1
                opacity-0 pointer-events-none translate-y-1
                group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0
                transition-all duration-150 ease-out">
        <div class="rounded-xl border border-gray-200 dark:border-white/10
                    bg-white dark:bg-gray-900
                    shadow-lg ring-1 ring-black/5 dark:ring-white/5
                    overflow-hidden">
            @foreach (var (label, href) in Items)
            {
                var active = IsActive(href);
                <a href="@href"
                   class="@(active ? ActiveItemClass : ItemClass) flex items-center px-4 py-2.5 text-sm">
                    @label
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Services";
    [Parameter] public (string Label, string Href)[] Items { get; set; } = [];
    [Parameter] public string TriggerClass { get; set; } = "";
    [Parameter] public string ActiveTriggerClass { get; set; } = "";
    [Parameter] public string ItemClass { get; set; } = "";
    [Parameter] public string ActiveItemClass { get; set; } = "";

    private bool IsActive(string href)
    {
        var current = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return current.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private bool IsAnyChildActive() => Items.Any(i => IsActive(i.Href));
}
