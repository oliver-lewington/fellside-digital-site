@if (!string.IsNullOrEmpty(Message))
{
    <div class="flex items-center gap-3 rounded-xl @_bg px-4 py-3 ring-1 @_ring @Class">
        <svg class="size-4 shrink-0 @_icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="@_path" />
        </svg>
        <p class="text-sm @_text">@Message</p>
    </div>
}

@code {
    [Parameter] public string? Message { get; set; }

    /// <summary>success | error | warning | accent</summary>
    [Parameter] public string Variant { get; set; } = "success";

    [Parameter] public string? Class { get; set; }

    private string _bg => Variant switch
    {
        "error"   => "bg-red-50 dark:bg-red-400/10",
        "warning" => "bg-amber-50 dark:bg-amber-400/10",
        "accent"  => "bg-indigo-50 dark:bg-orange-400/10",
        _         => "bg-emerald-50 dark:bg-emerald-400/10"
    };

    private string _ring => Variant switch
    {
        "error"   => "ring-red-200 dark:ring-red-400/20",
        "warning" => "ring-amber-200 dark:ring-amber-400/20",
        "accent"  => "ring-indigo-200 dark:ring-orange-400/20",
        _         => "ring-emerald-200 dark:ring-emerald-400/20"
    };

    private string _icon => Variant switch
    {
        "error"   => "text-red-500 dark:text-red-400",
        "warning" => "text-amber-500 dark:text-amber-400",
        "accent"  => "text-indigo-500 dark:text-orange-400",
        _         => "text-emerald-500 dark:text-emerald-400"
    };

    private string _text => Variant switch
    {
        "error"   => "text-red-700 dark:text-red-400",
        "warning" => "text-amber-700 dark:text-amber-400",
        "accent"  => "text-indigo-600 dark:text-orange-400",
        _         => "text-emerald-700 dark:text-emerald-400"
    };

    private string _path => Variant switch
    {
        "error" or "warning" =>
            "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z",
        _ =>
            "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
    };
}
