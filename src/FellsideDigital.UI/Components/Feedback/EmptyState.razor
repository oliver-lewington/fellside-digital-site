<div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 @Padding text-center bg-white dark:bg-neutral-900">
    <div class="mx-auto flex items-center justify-center bg-gray-100 dark:bg-white/5 @IconContainerClass">
        @Icon
    </div>
    <p class="text-sm font-semibold text-gray-900 dark:text-white">@Title</p>
    <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">@Subtitle</p>
    @if (Actions is not null)
    {
        <div class="mt-4">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string Padding { get; set; } = "p-10";
    [Parameter] public string IconContainerClass { get; set; } = "size-10 rounded-xl mb-3";
    [Parameter] public RenderFragment? Actions { get; set; }
}
