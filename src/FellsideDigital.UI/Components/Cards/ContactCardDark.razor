<div class="group relative overflow-hidden rounded-2xl p-6 space-y-4
            bg-slate-900 ring-1 ring-white/10
            hover:ring-accent/40 hover:shadow-md
            transition-all duration-200">

    <!-- Aura -->
    <div class="pointer-events-none absolute -top-10 -right-10
                w-40 h-40 rounded-full
                bg-accent-hover0/30 blur-2xl
                group-hover:bg-accent-hover0/40
                transition-colors duration-300"></div>

    <div class="relative w-10 h-10 rounded-xl flex items-center justify-center
                bg-white/10 text-accent-hover dark:text-orange-300
                group-hover:bg-white/20 transition-colors">
        @Icon
    </div>

    <div class="relative">
        <h3 class="font-semibold text-white">@Title</h3>
        <p class="mt-1 text-sm leading-relaxed text-slate-400">@Description</p>
    </div>

    <a href="@Href"
       target="@Target"
       rel="@(Target == "_blank" ? "noopener noreferrer" : null)"
       class="relative inline-flex items-center gap-1.5 text-sm font-medium
              text-accent-hover dark:text-orange-300
              hover:underline underline-offset-4 transition">
        @LinkText
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
    </a>
</div>

@code {
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Href { get; set; } = "#";
    [Parameter] public string LinkText { get; set; } = "";
    [Parameter] public string Target { get; set; } = "_blank";
}
