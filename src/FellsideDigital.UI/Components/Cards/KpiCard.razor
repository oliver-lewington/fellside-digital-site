<div class="rounded-2xl bg-white dark:bg-neutral-900 ring-1 ring-gray-200/80 dark:ring-white/5
            shadow-sm p-[18px] transition-all duration-150 hover:ring-accent/40">
    <div class="flex items-center justify-between mb-2">
        <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-400 dark:text-neutral-500">
            @Eyebrow
        </span>
        <span class="flex size-[30px] items-center justify-center rounded-lg @IconBgClass">
            <svg class="size-4 @IconFgClass" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.75" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="@IconPath" />
            </svg>
        </span>
    </div>
    <div class="text-[28px] font-bold tracking-tight text-gray-900 dark:text-white leading-none">@Value</div>
    <div class="mt-1.5 text-xs text-gray-400 dark:text-neutral-500 flex items-center gap-2">
        <span>@Sub</span>
        @if (!string.IsNullOrEmpty(TrendLabel))
        {
            <span class="text-[11px] font-semibold px-1.5 py-0.5 rounded @TrendClass">@TrendLabel</span>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Eyebrow  { get; set; } = "";
    [Parameter, EditorRequired] public string Value    { get; set; } = "";
    [Parameter, EditorRequired] public string Sub      { get; set; } = "";
    [Parameter, EditorRequired] public string IconPath { get; set; } = "";
    [Parameter] public string Tone       { get; set; } = "accent";
    [Parameter] public string TrendLabel { get; set; } = "";
    [Parameter] public string TrendDir   { get; set; } = "";

    private string IconBgClass => Tone switch
    {
        "blue"    => "bg-blue-50 dark:bg-blue-400/10",
        "amber"   => "bg-amber-50 dark:bg-amber-400/10",
        "emerald" => "bg-emerald-50 dark:bg-emerald-400/10",
        "rose"    => "bg-rose-50 dark:bg-rose-400/10",
        _         => "bg-accent/10",
    };

    private string IconFgClass => Tone switch
    {
        "blue"    => "text-blue-500 dark:text-blue-400",
        "amber"   => "text-amber-500 dark:text-amber-400",
        "emerald" => "text-emerald-500 dark:text-emerald-400",
        "rose"    => "text-rose-500 dark:text-rose-400",
        _         => "text-accent",
    };

    private string TrendClass => TrendDir == "up"
        ? "bg-emerald-50 dark:bg-emerald-400/10 text-emerald-700 dark:text-emerald-400"
        : "bg-rose-50 dark:bg-rose-400/10 text-rose-700 dark:text-rose-400";
}
