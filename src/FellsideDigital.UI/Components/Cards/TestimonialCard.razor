<div class="card rounded-2xl p-6 space-y-5 cursor-pointer
            bg-white dark:bg-neutral-900
            ring-1 ring-slate-200 dark:ring-white/5">
    <div class="flex gap-0.5 text-accent">
        @for (int i = 0; i < 5; i++)
        {
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
        }
    </div>
    <p class="text-sm leading-relaxed text-slate-600 dark:text-neutral-300">
        "@Quote"
    </p>
    <div class="flex items-center gap-3 pt-4 border-t border-slate-100 dark:border-white/5">
        <div class="flex size-9 shrink-0 items-center justify-center rounded-full
                    bg-accent/10
                    text-xs font-semibold text-accent">
            @_initial
        </div>
        <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-neutral-100">@Name</p>
            <p class="text-xs text-slate-400 dark:text-neutral-500">@Role</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Quote { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Role { get; set; } = "";

    private string _initial => Name.Length > 0 ? Name[0].ToString() : "?";
}
