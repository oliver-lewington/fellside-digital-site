@using Microsoft.AspNetCore.Components.Routing

<div class="flex h-full min-h-0 flex-col">
    <!-- Brand header -->
    <div class="flex h-16 shrink-0 items-center gap-3 border-b border-gray-200/80 dark:border-white/5 mt-1 mb-1">
        <NavLink href="/" class="flex items-center gap-3">
            <img src="/favicon.ico" class="h-7 w-auto dark:hidden" alt="Fellside Digital" />
            <img src="/favicon-dark.ico" class="h-7 w-auto not-dark:hidden" alt="Fellside Digital" />
            <span class="text-sm font-semibold text-gray-900 dark:text-white leading-none">Fellside Digital</span>
        </NavLink>
    </div>

    <nav class="flex min-h-0 flex-1 flex-col py-2 overflow-y-auto">
        <ul role="list" class="flex flex-1 flex-col gap-y-1">

            <!-- Overview -->
            <li>
                <NavLink href="/Portal"
                         Match="NavLinkMatch.All"
                         class="group flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                         ActiveClass="bg-accent-hover text-accent font-semibold">
                    <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                    </svg>
                    Overview
                </NavLink>
            </li>

            <!-- Websites section -->
            <li class="mt-3">
                <p class="px-3 py-1 text-xs font-semibold text-gray-400 dark:text-neutral-500 uppercase tracking-widest">Websites</p>
            </li>
            <li>
                <NavLink href="/Portal/Websites"
                         class="group flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                         ActiveClass="bg-accent-hover text-accent font-semibold">
                    <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3 12a8.959 8.959 0 0 0 .284 2.253" />
                    </svg>
                    My Websites
                </NavLink>
            </li>

            <!-- Automation section -->
            <li class="mt-3">
                <p class="px-3 py-1 text-xs font-semibold text-gray-400 dark:text-neutral-500 uppercase tracking-widest">Automation</p>
            </li>
            <li>
                <NavLink href="/Portal/Automations"
                         class="group flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                         ActiveClass="bg-accent-hover text-accent font-semibold">
                    <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                    </svg>
                    My Automations
                </NavLink>
            </li>

            <!-- Billing -->
            <li class="mt-3">
                <p class="px-3 py-1 text-xs font-semibold text-gray-400 dark:text-neutral-500 uppercase tracking-widest">Billing</p>
            </li>
            <li>
                <NavLink href="/Portal/Invoices"
                         class="group flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                         ActiveClass="bg-accent-hover text-accent font-semibold">
                    <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                    </svg>
                    Invoices
                </NavLink>
            </li>

            <!-- Account -->
            <li class="mt-3">
                <p class="px-3 py-1 text-xs font-semibold text-gray-400 dark:text-neutral-500 uppercase tracking-widest">Account</p>
            </li>
            <li>
                <NavLink href="/Portal/Settings"
                         class="group flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                         ActiveClass="bg-accent-hover text-accent font-semibold">
                    <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    Settings
                </NavLink>
            </li>

        </ul>

        <!-- User footer -->
        <div class="border-t border-gray-200/80 dark:border-white/5 pt-4 pb-2">
            <NavLink href="/Portal/Settings" class="flex items-center gap-3 px-2 rounded-lg py-2 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors">
                <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-accent text-xs font-bold text-white">
                    @(UserInitials.Length > 0 ? UserInitials : "?")
                </div>
                <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@UserName</p>
                    <p class="text-xs text-gray-500 dark:text-neutral-400 truncate">@CompanyName</p>
                </div>
                <svg class="size-4 text-gray-400 dark:text-neutral-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter] public string UserName { get; set; } = "";
    [Parameter] public string UserInitials { get; set; } = "";
    [Parameter] public string CompanyName { get; set; } = "";
}
