@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@inherits LayoutComponentBase

<Navbar LayoutMode="NavbarLayoutMode.Wide" />

<div class="pt-16">
    @if (_sidebarOpen)
    {
        <div class="relative z-50 xl:hidden" role="dialog" aria-modal="true">
            <div class="fixed inset-0 bg-gray-900/80 backdrop-blur-sm transition-opacity duration-300 ease-linear"
                 @onclick="CloseSidebar"></div>
            <div class="fixed inset-0 flex">
                <div class="relative mr-16 flex w-full max-w-xs flex-1">
                    <div class="absolute top-0 left-full flex w-16 justify-center pt-5">
                        <button type="button" class="-m-2.5 p-2.5 rounded-lg hover:bg-white/10 transition-colors" @onclick="CloseSidebar">
                            <span class="sr-only">Close sidebar</span>
                            <svg class="size-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                    <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-white dark:bg-neutral-950 px-6 shadow-2xl">
                        <PortalSidebarContent UserName="@_displayName" UserInitials="@_initials" />
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Static sidebar for desktop -->
    <div class="hidden xl:fixed xl:top-16 xl:bottom-0 xl:z-50 xl:flex xl:w-72 xl:flex-col">
        <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-white dark:bg-neutral-950 border-r border-gray-200/80 dark:border-white/5 px-6">
            <PortalSidebarContent UserName="@_displayName" UserInitials="@_initials" />
        </div>
    </div>

    <!-- Mobile top bar (below global Navbar) -->
    <div class="sticky top-16 z-40 flex h-12 shrink-0 items-center gap-x-4 border-b border-gray-200 dark:border-white/5 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-sm px-4 sm:gap-x-6 sm:px-6 xl:hidden">
        <button type="button" class="-m-2.5 p-2.5 text-gray-700 dark:text-neutral-300" @onclick="OpenSidebar">
            <span class="sr-only">Open sidebar</span>
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>
        <div class="h-4 w-px bg-gray-200 dark:bg-white/10"></div>
        <span class="text-sm font-semibold text-gray-900 dark:text-white">My Portal</span>
    </div>

    <div class="xl:pl-72">
        <main class="py-8">
            <div class="px-4 sm:px-6 lg:px-8">
                @Body
            </div>
        </main>
    </div>
</div>
