@using Microsoft.AspNetCore.Components.Authorization

<nav id="site-nav"
     class="fixed inset-x-0 top-0 z-50
    border-b border-gray-200 dark:border-white/10
    bg-white/80 dark:bg-gray-900/80
    backdrop-blur-2xl backdrop-saturate-200
    supports-[backdrop-filter]:bg-white/70
    dark:supports-[backdrop-filter]:bg-gray-900/70">

    <div class="@ContainerClass">
        <div class="relative flex h-16 justify-between">

            <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
                <MobileToggle IsOpen="_mobileMenuOpen" Toggle="ToggleMobileMenu"/>
            </div>

            <div class="flex flex-1 items-center justify-center sm:items-stretch sm:justify-start">
                
                <NavLink href="/" class="flex items-center">
                    <!-- Logo Icon -->
                    <img src="@Assets["favicon.ico"]"
                         class="h-16 w-auto dark:hidden" />
                    <img src="@Assets["favicon-dark.ico"]"
                         class="h-16 w-auto not-dark:hidden" />

                    <!-- Wordmark with margin -->
                    <span class="ml-3 text-lg font-semibold text-gray-900 dark:text-white select-none hidden sm:inline">
                        Fellside Digital
                    </span>
                </NavLink>

                <NavLinks Links="_navLinks"
                          BaseClass="hidden sm:ml-6 sm:flex sm:space-x-8"
                          LinkClass="inline-flex items-center px-1 pt-1 border-b-2 border-transparent text-sm font-medium text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-white/20 hover:text-gray-700 dark:hover:text-gray-200 transition-all duration-150"
                          ActiveClass="inline-flex items-center px-1 pt-1 border-b-2 border-indigo-400 dark:border-orange-400 text-sm font-medium text-gray-900 dark:text-white transition-all duration-150"
                          Match="NavLinkMatch.All" />
            </div>

            <div class="absolute inset-y-0 right-0 flex items-center pr-2 sm:static sm:inset-auto sm:ml-6 sm:pr-0">
                <AuthorizeView>
                    <Authorized>
                        <AuthorizeView Roles="SiteAdmin">
                            <Authorized Context="adminCtx">
                                <NavLink href="/Admin/Invitations"
                                         class="mr-2 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-xs font-semibold text-indigo-600 ring-1 ring-indigo-300 hover:bg-indigo-50 dark:text-orange-400 dark:ring-orange-400/40 dark:hover:bg-orange-400/10 transition-colors">
                                    Admin
                                </NavLink>
                            </Authorized>
                            <NotAuthorized Context="nonAdminCtx">
                                <NavLink href="/Portal"
                                         class="mr-2 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-xs font-semibold text-indigo-600 ring-1 ring-indigo-300 hover:bg-indigo-50 dark:text-orange-400 dark:ring-orange-400/40 dark:hover:bg-orange-400/10 transition-colors">
                                    My Portal
                                </NavLink>
                            </NotAuthorized>
                        </AuthorizeView>
                        <NotificationBell HasNotifications="_hasNotifications" />
                        <UserMenu CurrentUrl="@currentUrl" />
                    </Authorized>

                    <NotAuthorized>
                        <NavLink href="/Account/Login"
                                 class="ml-3 inline-flex items-center gap-2 text-sm font-semibold text-slate-700 dark:text-neutral-200 hover:text-indigo-400 dark:hover:text-orange-400">
                            Login →
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

    <MobileMenu Links="_navLinks"
                IsOpen="_mobileMenuOpen"
                Close="CloseMobileMenu"
                CurrentUrl="currentUrl" />
</nav>