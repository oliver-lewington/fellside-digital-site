@using System.Security.Claims
@using FellsideDigital.UI.Enums
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@inherits LayoutComponentBase

@if (_sidebarOpen)
{
    <div class="relative z-50 lg:hidden" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-gray-900/80 transition-opacity duration-300 ease-linear" @onclick="CloseSidebar"></div>

        <div tabindex="0" class="fixed inset-0 flex focus:outline-none">
            <div class="relative mr-16 flex w-full max-w-xs flex-1 transform transition duration-300 ease-in-out">
                <div class="absolute top-0 left-full flex w-16 justify-center pt-5 duration-300 ease-in-out">
                    <button type="button" class="-m-2.5 p-2.5" @onclick="CloseSidebar">
                        <span class="sr-only">Close sidebar</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 text-white">
                            <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>

                <div class="relative flex grow flex-col gap-y-5 overflow-y-auto bg-white px-6 pb-2 dark:bg-gray-900 dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:border-r dark:before:border-white/10 dark:before:bg-black/10">
                    <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
                </div>
            </div>
        </div>
    </div>
}

<!-- Static sidebar for desktop -->
<div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-72 lg:flex-col">
    <div class="relative flex grow flex-col gap-y-5 overflow-y-auto border-r border-gray-200 bg-white px-6 dark:border-white/10 dark:bg-gray-900 dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:bg-black/10">
        <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
    </div>
</div>

<!-- Mobile top bar -->
<div class="sticky top-0 z-40 flex items-center gap-x-6 bg-white px-4 py-4 shadow-xs sm:px-6 lg:hidden dark:bg-gray-900 dark:shadow-none dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:border-b dark:before:border-white/10 dark:before:bg-black/10">
    <button type="button" class="relative -m-2.5 p-2.5 text-gray-700 lg:hidden dark:text-gray-400" @onclick="OpenSidebar">
        <span class="sr-only">Open sidebar</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
            <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </button>
    <div class="relative flex-1 text-sm/6 font-semibold text-gray-900 dark:text-white">Admin</div>
</div>

<main class="lg:pl-72">
    <div class="px-4 py-10 sm:px-6 lg:px-8 lg:py-6">
        @Body
    </div>
</main>
