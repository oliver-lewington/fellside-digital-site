@inherits LayoutComponentBase

<div class="flex flex-col min-h-screen
            bg-white dark:bg-neutral-950
            text-gray-900 dark:text-gray-100">

    @if (LayoutState.ShowNavbar)
    {
        <MainNavbar />
    }

    <main class="flex flex-col flex-1 w-full">
        @Body
    </main>

    <footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-neutral-950 pt-16 pb-8 px-6">
        <div class="max-w-7xl mx-auto">

            <!-- 4-column grid -->
            <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

                <!-- Brand -->
                <div class="lg:col-span-1">
                    <div class="flex items-center gap-2.5 mb-5">
                        <img src="/imgs/svgs/fellside-tarn-indigo.svg" class="h-7 w-auto dark:hidden" alt="Fellside Digital" />
                        <img src="/imgs/svgs/fellside-tarn-orange.svg" class="h-7 w-auto hidden dark:block" alt="Fellside Digital" />
                        <span class="font-semibold text-slate-900 dark:text-white">Fellside Digital</span>
                    </div>
                    <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed max-w-xs">
                        Bespoke websites and intelligent automation, built with intent. <br>Based in Keswick, Cumbria&nbsp;·&nbsp;Working UK-wide.
                    </p>
                </div>

                <!-- Services -->
                <div>
                    <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Services</h4>
                    <ul class="space-y-1">
                        <li><a href="/websites" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Website design</a></li>
                        <li><a href="/websites" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Web applications</a></li>
                        <li><a href="/automation" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Workflow automation</a></li>
                        <li><a href="/automation" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">AI integration</a></li>
                    </ul>
                </div>

                <!-- Studio -->
                <div>
                    <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Studio</h4>
                    <ul class="space-y-1">
                        <li><a href="/" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">About</a></li>
                        <li><a href="/#practices" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Process</a></li>
                        <li><a href="/#testimonials" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Work</a></li>
                        <li><a href="/#faq" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">FAQ</a></li>
                    </ul>
                </div>

                <!-- Get in touch -->
                <div>
                    <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Get in touch</h4>
                    <ul class="space-y-1">
                        <li><a href="mailto:hello@fellsidedigital.co.uk" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">hello@fellsidedigital.co.uk</a></li>
                        <li><a href="/contact" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">Book a call</a></li>
                        <li><a href="/contact" class="text-sm text-slate-500 dark:text-neutral-400 hover:text-accent transition-colors">WhatsApp →</a></li>
                    </ul>
                </div>

            </div>

            <!-- Bottom bar -->
            <div class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4">
                <span class="text-xs text-slate-400 dark:text-neutral-500">
                    © @DateTime.Now.Year Fellside Digital Ltd · Registered in England
                </span>
                <div class="flex items-center gap-4">
                    <span class="text-xs text-slate-400 dark:text-neutral-500">Built with intent · in Cumbria</span>
                </div>
            </div>

        </div>
    </footer>
</div>
