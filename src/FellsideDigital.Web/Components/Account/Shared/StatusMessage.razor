@if (!string.IsNullOrEmpty(DisplayMessage))
{
    var isError = DisplayMessage.StartsWith("Error");
    var bgClass = isError ? "bg-red-50 dark:bg-red-900/20" : "bg-green-50 dark:bg-green-900/20";
    var textClass = isError ? "text-red-700 dark:text-red-400" : "text-green-700 dark:text-green-400";
    var iconPath = isError 
        ? "M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z"
        : "M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z";

    <div class="rounded-md @bgClass p-4" role="alert">
        <div class="flex items-start gap-3">
            <svg class="h-5 w-5 flex-shrink-0 @textClass" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="@iconPath" clip-rule="evenodd" />
            </svg>
            <p class="text-sm @textClass">
                @DisplayMessage
            </p>
        </div>
    </div>
}

@code {
    private string? messageFromCookie;

    [Parameter]
    public string? Message { get; set; }

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private string? DisplayMessage => Message ?? messageFromCookie;

    protected override void OnInitialized()
    {
        messageFromCookie = HttpContext.Request.Cookies[IdentityRedirectManager.StatusCookieName];

        if (messageFromCookie is not null)
        {
            HttpContext.Response.Cookies.Delete(IdentityRedirectManager.StatusCookieName);
        }
    }
}
