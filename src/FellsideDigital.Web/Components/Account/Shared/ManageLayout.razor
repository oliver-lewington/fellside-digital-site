@using FellsideDigital.Web.Components.Layout
@inherits LayoutComponentBase
@layout FellsideDigital.Web.Components.Layout.MainLayout

<div class="flex flex-col w-full max-w-full overflow-x-hidden
            bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300 relative">

    <Navbar />

    <!-- Main Content Container - Add top padding to account for fixed navbar (h-16 = 64px) -->
    <div class="mx-auto max-w-7xl px-4 pt-20 pb-8 sm:px-6 sm:pb-12 lg:px-8 lg:pb-16">

        <!-- Header -->
        <div class="mb-8 sm:mb-12">
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
                Manage your account
            </h1>
            <p class="mt-2 text-sm/6 text-slate-500 dark:text-neutral-400 sm:text-base">
                Update your account settings and preferences
            </p>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-8">

            <!-- Sidebar Navigation -->
            <aside class="lg:col-span-3">
                <div class="lg:sticky lg:top-20">
                    <ManageNavMenu />
                </div>
            </aside>

            <!-- Main Content Area -->
            <main class="lg:col-span-9">
                <div class="w-full rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 dark:bg-white/5 dark:ring-white/10 overflow-hidden">
                    <div class="h-full p-6 sm:p-8 overflow-y-auto">
                        @Body
                    </div>
                </div>
            </main>

        </div>
    </div>
</div>

