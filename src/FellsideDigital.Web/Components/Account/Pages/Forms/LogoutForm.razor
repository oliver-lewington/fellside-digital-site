<form method="post" action="/Account/Logout">
    <AntiforgeryToken />
    <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

    <button type="submit"
            class="block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/5">
        Sign out
    </button>
</form>

@code {
    [Parameter] public string? ReturnUrl { get; set; }
}