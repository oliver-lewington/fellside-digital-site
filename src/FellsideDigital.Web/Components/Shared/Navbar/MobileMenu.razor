@using FellsideDigital.Web.Components.Account.Pages.Forms
@if (IsOpen)
{
    <div class="sm:hidden">

        <NavLinks Links="Links"
                  Match="NavLinkMatch.All"
                  LinkClass="block py-2 pr-4 pl-3 text-base font-medium text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-white/20 hover:bg-gray-50 dark:hover:bg-white/5 hover:text-gray-700 dark:hover:text-gray-200"
                  ActiveClass="block border-l-4 border-indigo-600 dark:border-orange-400 bg-indigo-50 dark:bg-orange-400/10 py-2 pr-4 pl-3 text-base font-medium text-indigo-700 dark:text-orange-400"
                  OnClick="Close" />
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public (string Label, string Href)[] Links { get; set; } = [];
    [Parameter] public EventCallback Close { get; set; }
    [Parameter] public string? CurrentUrl { get; set; }
}