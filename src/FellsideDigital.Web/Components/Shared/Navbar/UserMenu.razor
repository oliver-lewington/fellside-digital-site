@using FellsideDigital.Web.Components.Account.Pages.Forms
@using Microsoft.AspNetCore.Components.Authorization

@rendermode InteractiveServer

<AuthorizeView Context="context">
    <Authorized>
        <div class="relative ml-3">
            <button @onclick="Toggle"
                    class="relative flex max-w-xs items-center rounded-full">

                @if (!string.IsNullOrEmpty(context.User.FindFirst("picture")?.Value))
                {
                    <img src="@context.User.FindFirst("picture")!.Value"
                         class="size-8 rounded-full" />
                }
                else
                {
                    <div class="size-8 rounded-full bg-indigo-400 flex items-center justify-center">
                        <span class="text-xs text-white">
                            @GetInitials(context.User.Identity?.Name)
                        </span>
                    </div>
                }
            </button>

            @if (_open)
            {
                <div class="absolute right-0 z-10 mt-2 w-48 rounded-md bg-white dark:bg-gray-800 py-1 shadow-lg">

                    <div class="px-4 py-2 border-b">
                        <p class="text-sm font-medium truncate">@context.User.Identity?.Name</p>
                        <p class="text-xs truncate">@context.User.FindFirst("email")?.Value</p>
                    </div>

                    <NavMenuLink Href="/account/manage" Label="Your profile" />
                    <NavMenuLink Href="/portal/settings" Label="Settings" />

                    <LogoutForm ReturnUrl="@CurrentUrl" />
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public string? CurrentUrl { get; set; }

    private bool _open;

    private void Toggle() => _open = !_open;

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ');
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }
}