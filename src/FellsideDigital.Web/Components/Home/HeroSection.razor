@inject IJSRuntime JS

<section class="relative overflow-hidden bg-white dark:bg-neutral-950">

    <!-- FULL WIDTH AURA -->
    <div class="hero-aura" aria-hidden="true">
        <div class="hero-aura-blob"></div>
    </div>

    <!-- CONTENT CONTAINER -->
    <div class="relative mx-auto max-w-7xl">

        <div class="relative z-10 pt-14 lg:w-full lg:max-w-2xl">

            <div class="relative px-6 py-32 sm:py-40 lg:px-8 lg:py-56 lg:pr-0">
                <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">

                    <!-- Announcement -->
                    <div id="hero-eyebrow" class="animated hidden sm:mb-10 sm:flex">
                        <div class="relative rounded-full px-3 py-1 text-sm/6
                            text-slate-500 ring-1 ring-slate-900/10 hover:ring-slate-900/20
                            dark:text-neutral-400 dark:ring-white/10 dark:hover:ring-white/20
                            transition-colors">
                            Based in Keswick, Cumbria · Working UK-wide.&nbsp;

                            <a href="/contact"
                               class="font-semibold whitespace-nowrap text-indigo-400 dark:text-orange-400">
                                <span class="absolute inset-0"></span>
                                Get in touch →
                            </a>
                        </div>
                    </div>

                    <!-- Heading -->
                    <h1 id="hero-heading"
                        class="animated text-5xl font-semibold tracking-tight
                        text-pretty text-slate-900 dark:text-white sm:text-7xl">
                        Websites and automation,
                        <span class="text-indigo-400 dark:text-orange-400"> built with intent</span>
                    </h1>

                    <!-- Sub -->
                    <p id="hero-sub"
                       class="animated mt-8 text-lg font-medium text-pretty
                        text-slate-500 dark:text-neutral-400 sm:text-xl/8">
                        Fellside Digital crafts premium, well-designed websites and builds
                        intelligent automation that scales with your business.
                        Bespoke work, from a team that genuinely cares.
                    </p>

                    <!-- CTA -->
                    <div id="hero-cta" class="animated mt-10 flex items-center gap-x-6">
                        <a href="/contact"
                           class="rounded-md bg-indigo-400 dark:bg-orange-400 px-3.5 py-2.5 text-sm font-semibold
                            text-white shadow-xs hover:bg-indigo-400/80 dark:hover:bg-orange-400/80
                            focus-visible:outline-2 focus-visible:outline-offset-2
                            focus-visible:outline-indigo-400 dark:focus-visible:outline-orange-400 transition-colors">
                            Get started
                        </a>

                        <button @onclick="ScrollToPortfolio"
                                class="text-sm font-semibold
                            text-slate-900 hover:text-indigo-400
                            dark:text-white dark:hover:text-orange-400
                            transition-colors flex items-center gap-1">
                            See our work →
                        </button>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <!-- IMAGE PANEL -->
    <div class="bg-slate-100 dark:bg-neutral-800
        lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2
        hero-image-panel">

        <img src="https://images.unsplash.com/photo-1483389127117-b6a2102724ae?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1587&q=80"
             alt="Fellside Digital, our workspace"
             class="aspect-3/2 w-full object-cover lg:aspect-auto lg:h-full" />

    </div>

</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // ── HERO ──────────────────────────────────────────────────────────
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#hero-eyebrow",
            new { distance = 16, duration = 500, startDelay = 200 });
        await JS.InvokeVoidAsync("fellsideAnime.blurClear", "#hero-heading",
            new { duration = 1000, stagger = 80, distance = 12, startDelay = 350 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWords", "#hero-sub",
            new { distance = 24, duration = 700, stagger = 60, startDelay = 900 });
        await JS.InvokeVoidAsync("fellsideAnime.fadeUp", "#hero-cta",
            new { distance = 20, duration = 600, startDelay = 1400 });

    }

    private async Task ScrollToPortfolio() =>
    await JS.InvokeVoidAsync("fellsideScroll.toOfferings", "portfolio");
}
