@using FellsideDigital.Web.Components.Home
@inject IJSRuntime JS

<section id="services"
         class="py-32 px-6 bg-slate-50 dark:bg-neutral-950 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">

        <div>
            <p id="services-label"
               class="animated text-sm font-medium uppercase tracking-widest
                text-slate-400 dark:text-neutral-500">
                Services
            </p>
            <h2 id="services-heading"
                class="animated mt-2 text-3xl font-semibold
                text-slate-900 dark:text-neutral-100">
                Everything your business needs.
            </h2>
            <p id="services-sub"
               class="animated mt-3 text-base text-slate-500 dark:text-neutral-400 max-w-2xl">
                Premium web design and intelligent automation, all under one roof.
            </p>
        </div>

        <div id="services-rows"
             class="mt-16 flex flex-col divide-y divide-slate-200 dark:divide-white/5">

            @foreach (var (svc, index) in Services.Select((s, i) => (s, i)))
            {
                bool reverse = index % 2 != 0;
                string visualId = $"services-visual-{index}";
                string contentId = $"services-content-{index}";
                string tagsId = $"services-tags-{index}";

                <div class="grid md:grid-cols-2 gap-12 py-16 items-center">

                    <!-- Visual Panel -->
                    <div id="@visualId"
                         class="@(reverse ? "md:order-last" : "")
                            rounded-2xl bg-white dark:bg-neutral-900
                            ring-1 ring-slate-200 dark:ring-white/5
                            h-52 flex items-center justify-center overflow-hidden px-8">

                        @switch (svc.Visual)
                        {
                            case ServiceVisual.WorkflowDots:
                                <div class="flex items-center gap-6">
                                    <div class="grid grid-cols-4 gap-2">
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-60"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-60"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-40"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-40"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-20"></div>
                                        <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400 opacity-20"></div>
                                        <div class="w-3 h-3 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <div class="h-2.5 w-24 rounded-full bg-indigo-400/40 dark:bg-orange-400/40"></div>
                                        <div class="h-2.5 w-16 rounded-full bg-indigo-400/25 dark:bg-orange-400/25"></div>
                                        <div class="h-2.5 w-20 rounded-full bg-indigo-400/15 dark:bg-orange-400/15"></div>
                                    </div>
                                </div>
                                break;

                            case ServiceVisual.IntegrationBars:
                                <div class="flex flex-col gap-3 w-2/3">
                                    <div class="h-3 w-full rounded-full bg-indigo-400/40 dark:bg-orange-400/40"></div>
                                    <div class="h-3 w-3/4 rounded-full bg-indigo-400/25 dark:bg-orange-400/25"></div>
                                    <div class="h-3 w-1/2 rounded-full bg-indigo-400/15 dark:bg-orange-400/15"></div>
                                </div>
                                break;

                            case ServiceVisual.AiPulse:
                                <div class="flex items-center gap-2">
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/20 dark:bg-orange-400/20"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/40 dark:bg-orange-400/40"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/60 dark:bg-orange-400/60"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400 dark:bg-orange-400"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/60 dark:bg-orange-400/60"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/40 dark:bg-orange-400/40"></div>
                                    <div class="w-3 h-3 rounded-full bg-indigo-400/20 dark:bg-orange-400/20"></div>
                                </div>
                                break;

                            case ServiceVisual.ReportingChart:
                                <div class="flex items-end gap-2 h-24 w-full px-4">
                                    <div class="flex-1 rounded-t-md bg-indigo-400/40 dark:bg-orange-400/40" style="height:38px"></div>
                                    <div class="flex-1 rounded-t-md bg-indigo-400/40 dark:bg-orange-400/40" style="height:58px"></div>
                                    <div class="flex-1 rounded-t-md bg-indigo-400/40 dark:bg-orange-400/40" style="height:43px"></div>
                                    <div class="flex-1 rounded-t-md bg-indigo-400 dark:bg-orange-400" style="height:77px"></div>
                                    <div class="flex-1 rounded-t-md bg-indigo-400/40 dark:bg-orange-400/40" style="height:62px"></div>
                                </div>
                                break;

                            case ServiceVisual.BrowserMockup:
                                <div class="flex flex-col gap-2 w-2/3">
                                    <div class="h-7 w-full rounded-md bg-slate-100 dark:bg-neutral-800 flex items-center px-3 gap-2">
                                        <div class="w-2 h-2 rounded-full bg-slate-300 dark:bg-neutral-600 flex-shrink-0"></div>
                                        <div class="h-1.5 flex-1 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                                    </div>
                                    <div class="flex gap-3">
                                        <div class="flex flex-col gap-1.5 flex-1 pt-1">
                                            <div class="h-2 rounded-full bg-indigo-400/60 dark:bg-orange-400/60 w-full"></div>
                                            <div class="h-2 rounded-full bg-indigo-400/30 dark:bg-orange-400/30 w-3/4"></div>
                                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-1/2"></div>
                                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-5/6 mt-1"></div>
                                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-2/3"></div>
                                        </div>
                                        <div class="w-20 h-20 rounded-md bg-indigo-400/20 dark:bg-orange-400/20 flex-shrink-0"></div>
                                    </div>
                                </div>
                                break;

                            case ServiceVisual.DesignGrid:
                                <div class="grid grid-cols-3 gap-2 w-48">
                                    <div class="rounded-lg bg-indigo-400 dark:bg-orange-400 aspect-square"></div>
                                    <div class="rounded-lg bg-indigo-400/60 dark:bg-orange-400/60 aspect-square"></div>
                                    <div class="rounded-lg bg-indigo-400/40 dark:bg-orange-400/40 aspect-square"></div>
                                    <div class="rounded-lg bg-slate-200 dark:bg-neutral-700 aspect-square col-span-2"></div>
                                    <div class="rounded-lg bg-indigo-400/20 dark:bg-orange-400/20 aspect-square"></div>
                                </div>
                                break;
                        }

                    </div>

                    <!-- Content Panel -->
                    <div id="@contentId" class="flex flex-col gap-4">
                        <p class="text-sm font-medium uppercase tracking-widest
                                text-slate-400 dark:text-neutral-500">
                            @svc.Number
                        </p>
                        <h3 class="text-2xl font-semibold
                                text-slate-900 dark:text-neutral-100">
                            @svc.Title
                        </h3>
                        <p class="text-base leading-relaxed
                                text-slate-500 dark:text-neutral-400">
                            @svc.Description
                        </p>
                        <div id="@tagsId" class="flex flex-wrap gap-2 mt-1">
                            @foreach (var tag in svc.Tags)
                            {
                                <span class="rounded-full px-3 py-1 text-xs font-medium
                                            bg-slate-100 text-slate-600
                                            dark:bg-neutral-800 dark:text-neutral-300">
                                    @tag
                                </span>
                            }
                        </div>
                    </div>

                </div>
            }

        </div>
    </div>
</section>

@code {

    private enum ServiceVisual
    {
        WorkflowDots,
        IntegrationBars,
        AiPulse,
        ReportingChart,
        BrowserMockup,
        DesignGrid
    }

    private record ServiceRow(
        string Number,
        string Title,
        string Description,
        string[] Tags,
        ServiceVisual Visual
    );

    private readonly List<ServiceRow> Services =
    [
        new(
            Number: "01",
            Title: "Custom Website Design",
            Description: "Beautifully crafted, high-performance websites designed to reflect your brand and convert visitors. No templates — every pixel is built for you.",
            Tags: ["Bespoke design", "Blazor & .NET", "Mobile-first"],
            Visual: ServiceVisual.BrowserMockup
        ),
        new(
            Number: "02",
            Title: "Workflow Automation",
            Description: "Map, streamline, and automate your repetitive internal processes, from approvals and notifications to task handoffs and status updates.",
            Tags: ["Approvals", "Notifications", "Task routing"],
            Visual: ServiceVisual.WorkflowDots
        ),
        new(
            Number: "03",
            Title: "E-Commerce & Web Applications",
            Description: "Full-featured web applications and online stores built from the ground up — custom portals, dashboards, booking systems, and more.",
            Tags: ["E-Commerce", "Client portals", "Custom dashboards"],
            Visual: ServiceVisual.DesignGrid
        ),
        new(
            Number: "04",
            Title: "API & Systems Integration",
            Description: "Break down data silos by connecting your existing tools — CRMs, business systems, databases, and third-party platforms — into a single, unified workflow.",
            Tags: ["CRM", "Business systems", "Third-party APIs"],
            Visual: ServiceVisual.IntegrationBars
        ),
        new(
            Number: "05",
            Title: "AI-Powered Automation",
            Description: "Go beyond rules-based logic. We embed AI into your workflows to handle unstructured data, intelligent decisions, and dynamic task routing.",
            Tags: ["Intelligent routing", "Unstructured data", "Decision engines"],
            Visual: ServiceVisual.AiPulse
        ),
        new(
            Number: "06",
            Title: "Data & Reporting Automation",
            Description: "Eliminate manual reporting. Automatically collect, transform, and deliver accurate insights to the right people at the right time.",
            Tags: ["Dashboards", "Scheduled reports", "Data pipelines"],
            Visual: ServiceVisual.ReportingChart
        ),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Header animations
        await JS.InvokeVoidAsync("fellsideAnime.fadeUpOnScroll", "#services-label");
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsOnScroll", "#services-heading");
        await JS.InvokeVoidAsync("fellsideAnime.fadeUpOnScroll", "#services-sub");

        // Per-row animations, visual and content fly in toward each other
        for (int i = 0; i < Services.Count; i++)
        {
            bool reverse = i % 2 != 0;

            string visualAnim = reverse ? "slideFromRightOnScroll" : "slideFromLeftOnScroll";
            string contentAnim = reverse ? "slideFromLeftOnScroll" : "slideFromRightOnScroll";

            await JS.InvokeVoidAsync($"fellsideAnime.{visualAnim}", $"#services-visual-{i}");
            await JS.InvokeVoidAsync($"fellsideAnime.{contentAnim}", $"#services-content-{i}");
            await JS.InvokeVoidAsync("fellsideAnime.elasticPopOnScroll", $"#services-tags-{i} > span");
        }
    }
}
