@using FellsideDigital.Web.Components.Home
@inject IJSRuntime JS
<section id="faqs"
         class="py-32 px-6 bg-white dark:bg-neutral-900 transition-colors duration-300">
    <div class="max-w-3xl mx-auto space-y-12">
        <div class="text-center">
            <p id="faqs-label"
               class="animated text-sm font-medium uppercase tracking-widest
                      text-slate-400 dark:text-neutral-500">
                FAQs
            </p>
            <h2 id="faqs-heading"
                class="animated mt-2 text-3xl font-semibold
                       text-slate-900 dark:text-neutral-100">
                Common questions, straight answers.
            </h2>
        </div>
        <div id="faqs-list" class="space-y-3">
            @foreach (var faq in HomeData.Faqs)
            {
                bool isOpen = _openFaq == faq.Question;
                <div class="rounded-xl ring-1
                                    bg-slate-50 ring-slate-200
                                    dark:bg-neutral-800/60 dark:ring-white/5
                                    overflow-hidden">
                    <button @onclick="() => Toggle(faq.Question)"
                            class="w-full flex items-center justify-between
                                           px-6 py-5 text-left font-medium
                                           text-slate-800 dark:text-neutral-100
                                           hover:text-indigo-400 dark:hover:text-orange-400 transition-colors">
                        <span>@faq.Question</span>
                        <svg class="size-4 shrink-0 ml-4 transition-transform duration-200
                                            @(isOpen ? "rotate-45" : "")"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </button>
                    @if (isOpen)
                    {
                        <div class="px-6 pb-6 pt-4 text-sm leading-relaxed
                                                    border-t border-slate-200 dark:border-white/5
                                                    text-slate-500 dark:text-neutral-400">
                            @faq.Answer
                        </div>
                    }
                </div>
            }
        </div>
        <p class="text-center text-sm text-slate-500 dark:text-neutral-400">
            Still have questions?
            <a href="/contact" class="text-indigo-400 dark:text-orange-400 hover:underline">Let's talk.</a>
        </p>
    </div>
</section>
@code {
    private string? _openFaq;
    private void Toggle(string question) =>
        _openFaq = _openFaq == question ? null : question;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("fellsideAnime.fadeUpOnScroll", "#faqs-label");
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsOnScroll", "#faqs-heading");
        await JS.InvokeVoidAsync("fellsideAnime.staggeredRevealOnScroll", "#faqs-list");
    }
}
