@page "/contact"
@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions

<PageTitle>Contact Us | Fellside Digital</PageTitle>

<div class="bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300">

    <!-- ═══════════════════════════════════════════════════════════
         HERO — centered, white / neutral-950
    ════════════════════════════════════════════════════════════ -->
    <section class="pt-40 pb-24 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-3xl mx-auto text-center space-y-6">
            <p class="text-sm font-medium uppercase tracking-widest
                      text-slate-400 dark:text-neutral-500">
                Get in touch
            </p>
            <h1 class="text-4xl sm:text-5xl font-semibold leading-tight
                       text-slate-900 dark:text-neutral-100">
                Let's work together.
            </h1>
            <p class="text-base sm:text-lg leading-relaxed
                      text-slate-500 dark:text-neutral-400 max-w-xl mx-auto">
                Every great project starts with a conversation. Tell us what you're looking
                to achieve and we'll come back with a clear plan and a no-obligation quote.
            </p>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         CONTACT CARDS — slate-50 / neutral-950
    ════════════════════════════════════════════════════════════ -->
    <section class="py-20 px-6 bg-slate-50 dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

                <ContactCard Title="Give us a call"
                             Description="Prefer to talk things through? Give us a ring."
                             Href="tel:+447484323505"
                             LinkText="+44 (0) 7484 323 505">
                    <Icon>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07
                                     19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67
                                     A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72
                                     c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91
                                     a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45
                                     c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                        </svg>
                    </Icon>
                </ContactCard>

                <ContactCard Title="Chat on WhatsApp"
                             Description="Send us a message and we'll get back to you quickly."
                             Href="https://wa.me/447484323505"
                             LinkText="Open WhatsApp"
                             Target="_blank">
                    <Icon>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7
                                     8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8
                                     8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5
                                     a8.48 8.48 0 0 1 8 8v.5z" />
                        </svg>
                    </Icon>
                </ContactCard>

                <ContactCard Title="Based in Cumbria"
                             Description="Serving clients across the UK. Happy to meet in person or over video call — whatever works best."
                             Href="https://maps.google.com/?q=Cumbria,+England"
                             LinkText="View on Google"
                             Target="_blank">
                    <Icon>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                    </Icon>
                </ContactCard>

                @if (!string.IsNullOrEmpty(_bookingsUrl))
                {
                    <ContactCardDark Title="Book a discovery call"
                                     Description="Pick a free 30-minute slot and we'll talk through your project."
                                     Href="@_bookingsUrl"
                                     LinkText="Choose a time">
                        <Icon>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.75"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                            </svg>
                        </Icon>
                    </ContactCardDark>
                }

            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         FORM — white / neutral-900, centered, no card wrapper
    ════════════════════════════════════════════════════════════ -->
    <section class="py-32 px-6 bg-white dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-2xl mx-auto space-y-10">

            <!-- Heading -->
            <div class="space-y-3">
                <p class="text-sm font-medium uppercase tracking-widest
                          text-slate-400 dark:text-neutral-500">
                    Tell us about your project
                </p>
                <h2 id="form-heading"
                    class="text-3xl font-semibold text-slate-900 dark:text-neutral-100">
                    Fill in the short form below.
                </h2>
                <p class="text-base leading-relaxed text-slate-500 dark:text-neutral-400">
                    We'll get back to you within one working day with ideas and a no-obligation quote.
                </p>
            </div>

            <!-- Step indicator -->
            <div class="flex items-center">
                @for (int i = 0; i < _steps.Length; i++)
                {
                    var stepIndex = i;
                    bool isActive = stepIndex == _currentStep;
                    bool isDone = stepIndex < _currentStep;

                    <button type="button"
                            @onclick="() => TryGoToStep(stepIndex)"
                            disabled="@(stepIndex > _currentStep)"
                            class="@($"flex items-center gap-2 px-4 py-2 text-sm font-medium transition-colors " +
                                                                 $"{(isActive ? "text-accent" : isDone ? "text-slate-900 dark:text-neutral-100 hover:text-accent" : "text-slate-400 dark:text-neutral-600 cursor-not-allowed")}")">
                    <span class="@($"w-6 h-6 rounded-full flex items-center justify-center text-xs font-semibold transition-colors " +
                                                                 $"{(isActive ? "bg-accent text-white" : isDone ? "bg-accent/20 text-accent" : "bg-slate-200 dark:bg-neutral-800 text-slate-400 dark:text-neutral-600")}")">
                        @if (isDone)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2.5"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 6 9 17l-5-5" />
                                </svg>
                            }
                            else
                            {
                                @(stepIndex + 1)
                            }
                        </span>
                        @_steps[stepIndex]
                    </button>

                    @if (stepIndex < _steps.Length - 1)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-4 h-4 text-slate-300 dark:text-neutral-700 shrink-0"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 18l6-6-6-6" />
                        </svg>
                    }
                }
            </div>

            <div class="border-t border-slate-100 dark:border-white/5"></div>

            <!-- Form fields — open layout, no card -->
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <!-- ── Step 1: Your details ─────────────────── -->
                @if (_currentStep == 0)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Your name
                            </label>
                            <InputText @bind-Value="_model.Name"
                                       placeholder="Jane Smith"
                                       class="@InputClass" />
                            <ValidationMessage For="() => _model.Name" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Email address
                            </label>
                            <InputText @bind-Value="_model.Email"
                                       type="email"
                                       placeholder="jane@example.com"
                                       class="@InputClass" />
                            <ValidationMessage For="() => _model.Email" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Phone
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputText @bind-Value="_model.Phone"
                                       type="tel"
                                       placeholder="+44 7700 000000"
                                       class="@InputClass" />
                        </div>
                    </div>
                }

                <!-- ── Step 2: About you ───────────────────── -->
                @if (_currentStep == 1)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Company or organisation
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputText @bind-Value="_model.Company"
                                       placeholder="Acme Ltd"
                                       class="@InputClass" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                What are you looking for?
                            </label>
                            <InputSelect @bind-Value="_model.ServiceType"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select a service…</option>
                                @foreach (var opt in EnumExtensions.ToOptions<ContactServiceType>())
                                {
                                    <option value="@opt.Value">@opt.Display</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _model.ServiceType" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Approximate budget
                            </label>
                            <InputSelect @bind-Value="_model.Budget"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select a range…</option>
                                @foreach (var opt in EnumExtensions.ToOptions<ContactBudget>())
                                {
                                    <option value="@opt.Value">@opt.Display</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }

                <!-- ── Step 3: Your message ────────────────── -->
                @if (_currentStep == 2)
                {
                    <div class="space-y-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                Tell us about your project
                            </label>
                            <InputTextArea @bind-Value="_model.Message"
                                           rows="6"
                                           placeholder="Describe your idea, goals, timeline, or any questions you have…"
                                           class="@(InputClass + " resize-none")" />
                            <ValidationMessage For="() => _model.Message" class="text-xs text-red-500" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-medium text-slate-700 dark:text-neutral-300">
                                How did you hear about us?
                                <span class="text-slate-400 dark:text-neutral-500 font-normal">(optional)</span>
                            </label>
                            <InputSelect @bind-Value="_model.HowHeard"
                                         class="@(InputClass + " appearance-none")">
                                <option value="">Select…</option>
                                @foreach (var opt in EnumExtensions.ToOptions<ContactHowHeard>())
                                {
                                    <option value="@opt.Value">@opt.Display</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }

                <div class="border-t border-slate-100 dark:border-white/5 mt-8"></div>

                <!-- Nav buttons -->
                <div class="flex items-center justify-between pt-6">
                    @if (_currentStep > 0)
                    {
                        <button type="button" @onclick="PreviousStep"
                                class="inline-flex items-center gap-2 text-sm font-medium
                                               text-slate-500 dark:text-neutral-400
                                               hover:text-slate-900 dark:hover:text-neutral-100 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 12H5M12 19l-7-7 7-7" />
                            </svg>
                            Back
                        </button>
                    }
                    else
                    {
                        <span></span>
                    }

                    @if (_submitted)
                    {
                        <div class="flex items-center gap-2 rounded-xl px-5 py-2.5
                                             bg-accent/10
                                             text-accent text-sm font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6 9 17l-5-5" />
                            </svg>
                            Sent! We'll be in touch within one working day.
                        </div>
                    }
                    else if (_currentStep < _steps.Length - 1)
                    {
                        <button type="button" @onclick="NextStep"
                                class="inline-flex items-center gap-2 rounded-xl px-6 py-2.5
                                               text-sm font-semibold
                                               bg-accent text-white
                                               hover:opacity-90 active:scale-95 transition-all shadow-sm">
                            Next
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </button>
                    }
                    else
                    {
                        <button type="submit" disabled="@_sending"
                                class="inline-flex items-center gap-2 rounded-xl px-6 py-2.5
                                               text-sm font-semibold
                                               bg-accent text-white
                                               hover:opacity-90 active:scale-95
                                               disabled:opacity-50 disabled:cursor-not-allowed
                                               transition-all shadow-sm">
                            @if (_sending)
                            {
                                <svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg"
                                     fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10"
                                            stroke="currentColor" stroke-width="4" />
                                    <path class="opacity-75" fill="currentColor"
                                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                                </svg>
                                <span>Sending…</span>
                            }
                            else
                            {
                                <span>Send message</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            }
                        </button>
                    }
                </div>

            </EditForm>
        </div>
    </section>

</div>
