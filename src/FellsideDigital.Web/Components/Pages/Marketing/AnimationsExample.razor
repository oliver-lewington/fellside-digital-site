@page "/animations-demo"
@inject IJSRuntime JS

<PageTitle>Animation Demo, Fellside Digital</PageTitle>

<HeadContent>
    <style>
        /* RULE: No opacity:0 on animated elements, anime.js owns that.
                   Only exception: .underline-bar and .progress-track fills
                   which are width-driven and safe to pre-hide. */

        .underline-bar {
            display: block;
            height: 2px;
            background: #6366f1;
            width: 0%;
            opacity: 0;
            margin-top: 6px;
        }

        .progress-track {
            background: #1f2937;
            border-radius: 999px;
            height: 8px;
            overflow: hidden;
            width: 100%;
        }

        .progress-fill {
            height: 100%;
            border-radius: 999px;
            background: #6366f1;
            width: 0%;
        }

        /* Cursor blink is handled inline by typewriter() */
    </style>
</HeadContent>

<div class="bg-neutral-950 text-neutral-100 min-h-screen font-sans px-6 py-24 space-y-40">

    <!-- ── 1. WORDS FLOAT UP ─────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 1, Words Float Up</p>
        <h1 id="e1-heading" class="text-5xl md:text-6xl font-bold tracking-tight">
            Custom software built with intent
        </h1>
        <p id="e1-sub" class="text-neutral-400 text-lg">
            Fellside Digital designs and builds reliable web applications
        </p>
    </section>

    <!-- ── 2. CHARS RAIN DOWN ────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 2, Characters Rain Down</p>
        <h2 id="e2-heading" class="text-5xl font-bold tracking-tight">
            Built to last
        </h2>
        <p class="text-neutral-400 text-sm">Each character falls from above, staggered individually.</p>
    </section>

    <!-- ── 3. CHARS RISE UP ──────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 3, Characters Rise Up</p>
        <h2 id="e3-heading" class="text-5xl font-bold tracking-tight">
            Rise to the challenge
        </h2>
        <p class="text-neutral-400 text-sm">Like rain down but from below, subtle rotation included.</p>
    </section>

    <!-- ── 4. TEXT SCRAMBLE ───────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 4, Text Scramble</p>
        <h2 id="e4-heading" class="text-5xl font-bold tracking-tight text-accent">
            Fellside Digital
        </h2>
        <p class="text-neutral-400 text-sm">Characters randomise then snap to real text. Very tech.</p>
        <button class="text-sm uppercase tracking-widest text-neutral-400 hover:text-accent transition border border-neutral-700 hover:border-accent px-5 py-2 rounded-lg"
                @onclick="ReplayScramble">
            ↺ Replay
        </button>
    </section>

    <!-- ── 5. TYPEWRITER ─────────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 5, Typewriter</p>
        <h2 id="e5-heading" class="text-4xl font-bold tracking-tight font-mono">
            We write code that matters.
        </h2>
        <p class="text-neutral-400 text-sm">Characters appear one by one with realistic jitter. Cursor blinks then disappears.</p>
        <button class="text-sm uppercase tracking-widest text-neutral-400 hover:text-accent transition border border-neutral-700 hover:border-accent px-5 py-2 rounded-lg"
                @onclick="ReplayTypewriter">
            ↺ Replay
        </button>
    </section>

    <!-- ── 6. BLUR CLEAR ─────────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 6, Blur Clear</p>
        <h2 id="e6-heading" class="text-5xl font-bold tracking-tight">
            Clarity through great engineering
        </h2>
        <p class="text-neutral-400 text-sm">Text fades in and simultaneously snaps into focus. Subtle and premium.</p>
    </section>

    <!-- ── 7. FLIP IN ────────────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 7, 3D Flip In</p>
        <h2 id="e7-heading" class="text-5xl font-bold tracking-tight">
            Flip the script entirely
        </h2>
        <p class="text-neutral-400 text-sm">Words rotate in on the X axis, dramatic and modern.</p>
    </section>

    <!-- ── 8. WORDS FROM LEFT + UNDERLINE ────────────────────────── -->
    <section class="max-w-3xl mx-auto space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 8, Words From Left + Underline Draw</p>
        <h2 id="e8-heading" class="text-4xl font-semibold">
            Performance-first engineering
        </h2>
        <div class="underline-bar" id="e8-underline"></div>
        <p class="text-neutral-400">Words slide in, then the underline draws itself.</p>
    </section>

    <!-- ── 9. WORDS FROM RIGHT ───────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-right space-y-6">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 9, Words From Right</p>
        <h2 id="e9-heading" class="text-4xl font-semibold">
            Engineered for the long term
        </h2>
        <p class="text-neutral-400 text-sm">Mirror of slide-from-left. Great for alternating layouts.</p>
    </section>

    <!-- ── 10. STAGGERED CARDS (ZOOM IN) ─────────────────────────── -->
    <section class="max-w-5xl mx-auto space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 10, Zoom In (Staggered Cards)</p>
        <div class="grid md:grid-cols-3 gap-6" id="e10-cards">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Foundational</h3>
                <p class="text-neutral-400 text-sm">Clean websites for organisations that value clarity.</p>
                <p class="text-2xl font-bold mt-4">From £450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Software-Driven</h3>
                <p class="text-neutral-400 text-sm">Dynamic content with maintainable architectures.</p>
                <p class="text-2xl font-bold mt-4">Project-based</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Bespoke Systems</h3>
                <p class="text-neutral-400 text-sm">Fully custom applications built around your workflows.</p>
                <p class="text-2xl font-bold mt-4">Custom</p>
            </div>
        </div>
    </section>

    <!-- ── 11. ELASTIC POP ───────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 11, Elastic Pop (Icons / Badges)</p>
        <div id="e11-icons" class="flex justify-center gap-8">
            <div class="w-16 h-16 bg-accent rounded-2xl flex items-center justify-center text-2xl">⚡</div>
            <div class="w-16 h-16 bg-neutral-800 rounded-2xl flex items-center justify-center text-2xl">🔧</div>
            <div class="w-16 h-16 bg-neutral-800 rounded-2xl flex items-center justify-center text-2xl">🚀</div>
            <div class="w-16 h-16 bg-neutral-800 rounded-2xl flex items-center justify-center text-2xl">🎯</div>
        </div>
        <p class="text-neutral-400 text-sm">Spring physics, bouncy, natural, satisfying.</p>
    </section>

    <!-- ── 12. SLIDE FROM LEFT / RIGHT ───────────────────────────── -->
    <section class="max-w-4xl mx-auto space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 12, Slide From Left & Right</p>
        <div class="grid md:grid-cols-2 gap-8">
            <div id="e12-left" class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">← Enters from left</h3>
                <p class="text-neutral-400 text-sm">Great for split-content layouts, left panel and right panel enter from opposite sides.</p>
            </div>
            <div id="e12-right" class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Enters from right →</h3>
                <p class="text-neutral-400 text-sm">The two panels moving toward each other creates a natural, satisfying reveal.</p>
            </div>
        </div>
    </section>

    <!-- ── 13. COUNTERS ───────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 13, Animated Counters</p>
        <div class="grid grid-cols-3 gap-8 text-center">
            <div>
                <p id="stat-1" class="text-5xl font-bold text-accent">0</p>
                <p class="text-neutral-400 text-sm mt-2">Projects delivered</p>
            </div>
            <div>
                <p id="stat-2" class="text-5xl font-bold text-accent">0</p>
                <p class="text-neutral-400 text-sm mt-2">Happy clients</p>
            </div>
            <div>
                <p id="stat-3" class="text-5xl font-bold text-accent">0</p>
                <p class="text-neutral-400 text-sm mt-2">Uptime %</p>
            </div>
        </div>
    </section>

    <!-- ── 14. PROGRESS BARS ─────────────────────────────────────── -->
    <section class="max-w-2xl mx-auto space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 14, Progress Bars</p>
        <div id="e14-bars" class="space-y-5">
            <div>
                <div class="flex justify-between text-sm text-neutral-400 mb-2">
                    <span>Blazor / .NET</span><span>95%</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" id="bar-1"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm text-neutral-400 mb-2">
                    <span>System Architecture</span><span>90%</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" id="bar-2"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm text-neutral-400 mb-2">
                    <span>UI / UX Design</span><span>80%</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" id="bar-3"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm text-neutral-400 mb-2">
                    <span>DevOps & Deployment</span><span>85%</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" id="bar-4"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── 15. STAGGERED LIST ─────────────────────────────────────── -->
    <section class="max-w-2xl mx-auto space-y-8">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Effect 15, Staggered List Reveal</p>
        <ul id="e15-list" class="space-y-4">
            <li class="flex items-start gap-3">
                <span class="text-accent mt-0.5">✓</span><span>Architecture &amp; system design</span>
            </li>
            <li class="flex items-start gap-3">
                <span class="text-accent mt-0.5">✓</span><span>Backend &amp; API development</span>
            </li>
            <li class="flex items-start gap-3">
                <span class="text-accent mt-0.5">✓</span><span>Performance &amp; reliability</span>
            </li>
            <li class="flex items-start gap-3">
                <span class="text-accent mt-0.5">✓</span><span>Ongoing support &amp; maintenance</span>
            </li>
            <li class="flex items-start gap-3">
                <span class="text-accent mt-0.5">✓</span><span>Clear, transparent communication</span>
            </li>
        </ul>
    </section>

    <!-- ── 16. PULSE + FLOAT ─────────────────────────────────────── -->
    <section class="max-w-3xl mx-auto text-center space-y-8 pb-24">
        <p class="text-xs uppercase tracking-widest text-neutral-500">Effect 16, Pulse & Float (Looping)</p>
        <div class="flex justify-center gap-12 items-end">
            <div>
                <div id="pulse-badge" class="inline-block bg-accent text-white text-xs uppercase tracking-widest px-4 py-2 rounded-full font-semibold">
                    Live
                </div>
                <p class="text-neutral-500 text-xs mt-3">Pulse</p>
            </div>
            <div>
                <div id="float-icon" class="text-5xl">🚀</div>
                <p class="text-neutral-500 text-xs mt-3">Float</p>
            </div>
            <div>
                <div id="float-icon-2" class="text-5xl">⚡</div>
                <p class="text-neutral-500 text-xs mt-3">Float (offset)</p>
            </div>
        </div>
        <p class="text-neutral-400 text-sm">Great for live indicators, hero icons, or decorative elements.</p>
    </section>

</div>

@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // ── 1. Words float up, immediate on load
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWords", "#e1-heading", new
        {
            distance = 40,
            duration = 800,
            stagger = 110,
            startDelay = 100
        });
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWords", "#e1-sub", new
        {
            distance = 20,
            duration = 600,
            stagger = 70,
            startDelay = 750
        });

        // ── 2. Chars rain down, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.charsRainDownOnScroll", "#e2-heading", new
        {
            distance = -50,
            rotate = -10,
            duration = 500,
            stagger = 45
        });

        // ── 3. Chars rise up, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.charsRiseUpOnScroll", "#e3-heading", new
        {
            distance = 50,
            rotate = 6,
            duration = 500,
            stagger = 40
        });

        // ── 4. Scramble, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.onVisible", "#e4-heading", "triggerScramble", 0.3);

        // ── 5. Typewriter, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.typewriterOnScroll", "#e5-heading", new
        {
            speed = 45,
            jitter = 25,
            showCursor = true,
            cursorDuration = 2500
        });

        // ── 6. Blur clear, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.blurClearOnScroll", "#e6-heading", new
        {
            duration = 900,
            stagger = 100,
            distance = 8
        });

        // ── 7. Flip in, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.flipInWordsOnScroll", "#e7-heading", new
        {
            duration = 700,
            stagger = 110
        });

        // ── 8. Words from left + underline, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsLeftOnScroll", "#e8-heading", new
        {
            distance = 40,
            duration = 700,
            stagger = 90
        });
        await JS.InvokeVoidAsync("fellsideAnime.drawUnderline", "#e8-underline", new
        {
            duration = 600,
            startDelay = 900
        });

        // ── 9. Words from right, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.fadeInWordsRightOnScroll", "#e9-heading", new
        {
            distance = 40,
            duration = 700,
            stagger = 90
        });

        // ── 10. Zoom in (cards), on scroll
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#e10-cards > div", new
        {
            from = 0.88,
            duration = 650,
            stagger = 120
        });

        // ── 11. Elastic pop, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.elasticPopOnScroll", "#e11-icons > div", new
        {
            stagger = 100
        });

        // ── 12. Slide from left and right, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.slideFromLeftOnScroll", "#e12-left", new
        {
            distance = 60,
            duration = 700
        });
        await JS.InvokeVoidAsync("fellsideAnime.slideFromRightOnScroll", "#e12-right", new
        {
            distance = 60,
            duration = 700
        });

        // ── 13. Counters, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.countUpOnScroll", "#stat-1", 47, new { duration = 1600 });
        await JS.InvokeVoidAsync("fellsideAnime.countUpOnScroll", "#stat-2", 31, new { duration = 1600 });
        await JS.InvokeVoidAsync("fellsideAnime.countUpOnScroll", "#stat-3", 99, new { duration = 2000, suffix = "%" });

        // ── 14. Progress bars, on scroll (staggered delays)
        await JS.InvokeVoidAsync("fellsideAnime.progressBarOnScroll", "#bar-1", 95, new { duration = 1200 });
        await JS.InvokeVoidAsync("fellsideAnime.progressBarOnScroll", "#bar-2", 90, new { duration = 1100, startDelay = 150 });
        await JS.InvokeVoidAsync("fellsideAnime.progressBarOnScroll", "#bar-3", 80, new { duration = 1000, startDelay = 300 });
        await JS.InvokeVoidAsync("fellsideAnime.progressBarOnScroll", "#bar-4", 85, new { duration = 1050, startDelay = 450 });

        // ── 15. Staggered list, on scroll
        await JS.InvokeVoidAsync("fellsideAnime.staggeredRevealOnScroll", "#e15-list", new
        {
            distance = 16,
            duration = 500,
            stagger = 80
        });

        // ── 16. Pulse + float, start immediately (looping)
        await JS.InvokeVoidAsync("fellsideAnime.pulse", "#pulse-badge", new
        {
            scale = 1.08,
            duration = 850
        });
        await JS.InvokeVoidAsync("fellsideAnime.float", "#float-icon", new
        {
            distance = -12,
            duration = 2200
        });
        await JS.InvokeVoidAsync("fellsideAnime.float", "#float-icon-2", new
        {
            distance = -10,
            duration = 2600,
            stagger = 400
        });
    }

    private async Task ReplayScramble()
    {
        await JS.InvokeVoidAsync("fellsideAnime.scrambleText", "#e4-heading", new
        {
            duration = 1200,
            steps = 18
        });
    }

    private async Task ReplayTypewriter()
    {
        // Reset text first so typewriter can re-run
        await JS.InvokeVoidAsync("eval",
            "document.getElementById('e5-heading').innerText = 'We write code that matters.'");
        await JS.InvokeVoidAsync("fellsideAnime.typewriter", "#e5-heading", new
        {
            speed = 45,
            jitter = 25,
            showCursor = true,
            cursorDuration = 2500
        });
    }
}
