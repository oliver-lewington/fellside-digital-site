@page "/"

<PageTitle>Fellside Digital — Bespoke Websites & Intelligent Automation</PageTitle>

<div class="flex flex-col w-full max-w-full overflow-x-hidden
            bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300">

    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-24 sm:py-36 lg:py-44 px-6">
        <div class="grain-overlay" aria-hidden="true"></div>
        <div class="hero-aura" aria-hidden="true">
            <div class="hero-aura-blob"></div>
        </div>

        <div class="relative z-10 max-w-4xl mx-auto text-center">
            <p class="text-xs font-semibold uppercase tracking-widest
                       text-slate-400 dark:text-neutral-500 mb-8">
                Based in Keswick, Cumbria&nbsp;·&nbsp;Working UK-wide
            </p>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight text-balance
                       text-slate-900 dark:text-white">
                Websites and automation,
                <span class="text-accent"> built with intent</span>
            </h1>

            <p class="mt-6 text-lg sm:text-xl text-slate-500 dark:text-neutral-400 max-w-2xl mx-auto text-balance">
                Fellside Digital crafts premium, well-designed websites and builds intelligent
                automation that scales with your business. Bespoke work, from a team that genuinely cares.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/contact"
                   class="rounded-xl bg-accent px-6 py-3 text-sm font-semibold
                          text-white shadow-sm hover:opacity-90 active:scale-95 transition-all">
                    Start the conversation
                </a>
                <a href="#practices"
                   class="inline-flex items-center gap-1.5 text-sm font-semibold
                          text-slate-700 dark:text-neutral-300
                          hover:text-accent transition-colors">
                    See what we do
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <!-- ── TWO PRACTICES ─────────────────────────────────────────────────── -->
    <section id="practices" class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="What we do"
                           Heading="Two practices, one partner."
                           Description="Premium websites and intelligent automation, both done properly." />

            <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6">

                <!-- Websites card — force-light pins --accent to indigo for all children -->
                <div class="card card-cool group force-light
                            rounded-2xl bg-white dark:bg-neutral-900
                            ring-1 ring-slate-200 dark:ring-white/5">
                    <div class="p-8 sm:p-10 flex flex-col h-full">
                        <div class="flex size-11 items-center justify-center rounded-xl
                                    bg-accent/10 mb-6">
                            <svg class="size-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
                            </svg>
                        </div>
                        <p class="text-xs font-semibold uppercase tracking-widest
                                  text-accent mb-2">
                            Website Design &amp; Development
                        </p>
                        <h3 class="text-2xl font-semibold text-slate-900 dark:text-neutral-100 mb-3">
                            Bespoke websites designed to convert
                        </h3>
                        <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed mb-6 flex-1">
                            High-performance, beautifully crafted websites and web applications
                            built around your brand. No templates, no shortcuts — every pixel
                            is built for you.
                        </p>
                        <ul class="space-y-2.5 mb-8">
                            @foreach (var item in _websiteFeatures)
                            {
                                <li class="flex items-start gap-2.5 text-sm text-slate-500 dark:text-neutral-400">
                                    <svg class="size-4 shrink-0 mt-0.5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    @item
                                </li>
                            }
                        </ul>
                        <a href="/websites"
                           class="inline-flex items-center gap-1.5 text-sm font-semibold
                                  text-accent
                                  group-hover:gap-3 transition-all duration-200">
                            Explore website services
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Automation card — force-dark pins --accent to orange for all children -->
                <div class="card card-warm group force-dark
                            rounded-2xl bg-white dark:bg-neutral-900
                            ring-1 ring-slate-200 dark:ring-white/5">
                    <div class="p-8 sm:p-10 flex flex-col h-full">
                        <div class="flex size-11 items-center justify-center rounded-xl
                                    bg-accent/10 mb-6">
                            <svg class="size-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                            </svg>
                        </div>
                        <p class="text-xs font-semibold uppercase tracking-widest
                                  text-accent mb-2">
                            Intelligent Automation
                        </p>
                        <h3 class="text-2xl font-semibold text-slate-900 dark:text-neutral-100 mb-3">
                            Automation that scales with your business
                        </h3>
                        <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed mb-6 flex-1">
                            From eliminating manual processes to embedding AI into your workflows,
                            we build automation that is reliable, maintainable, and built to grow
                            with your operation.
                        </p>
                        <ul class="space-y-2.5 mb-8">
                            @foreach (var item in _automationFeatures)
                            {
                                <li class="flex items-start gap-2.5 text-sm text-slate-500 dark:text-neutral-400">
                                    <svg class="size-4 shrink-0 mt-0.5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    @item
                                </li>
                            }
                        </ul>
                        <a href="/automation"
                           class="inline-flex items-center gap-1.5 text-sm font-semibold
                                  text-accent
                                  group-hover:gap-3 transition-all duration-200">
                            Explore automation services
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ── HOW WE WORK ────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Process"
                           Heading="How we work."
                           Description="Founder-led, no hand-offs. The person you talk to is the person doing the work."
                           Center="true" />

            <div class="mt-12 process-rail">
                <div class="process-rail-line" aria-hidden="true"></div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    @foreach (var (step, idx) in _processSteps.Select((s, i) => (s, i + 1)))
                    {
                        <div class="relative">
                            <div class="relative z-10 flex size-10 items-center justify-center rounded-xl mb-5
                                        bg-white dark:bg-neutral-950
                                        ring-1 ring-slate-200 dark:ring-white/10
                                        shadow-[inset_0_0_0_4px_rgba(129,140,248,0.12)] dark:shadow-[inset_0_0_0_4px_rgba(251,146,60,0.12)]">
                                <span class="text-sm font-bold text-accent">@idx</span>
                            </div>
                            <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">
                                @step.Title
                            </h3>
                            <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">
                                @step.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ── TESTIMONIALS ───────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Client stories"
                           Heading="Trusted by Cumbria and beyond."
                           Center="true" />

            <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
                @foreach (var t in HomeData.Testimonials)
                {
                    <TestimonialCard Quote="@t.Quote" Name="@t.Name" Role="@t.Role" />
                }
            </div>
        </div>
    </section>

    <!-- ── FAQ ────────────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-3xl mx-auto">
            <SectionHeader Label="FAQs"
                           Heading="Common questions."
                           Center="true" />

            <div class="mt-10 space-y-2">
                @foreach (var faq in HomeData.Faqs)
                {
                    bool isOpen = _openFaq == faq.Question;
                    <div class="rounded-xl overflow-hidden
                                ring-1 ring-slate-200 dark:ring-white/5
                                bg-slate-50 dark:bg-neutral-900">

                        <PrimaryButton OnClick="() => ToggleFaq(faq.Question)" OverrideDefaultStyles="true" Class="w-full flex items-center justify-between px-6 py-5 text-left text-sm font-medium hover:text-accent transition-colors">
                            <span>@faq.Question</span>
                            <svg class="size-4 shrink-0 ml-4 transition-transform duration-200
                                @(isOpen ? "rotate-45" : "")"
                                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>
                        </PrimaryButton>

                        @if (isOpen)
                        {
                            <div class="px-6 pb-6 pt-2 text-sm leading-relaxed
                                        border-t border-slate-200 dark:border-white/5
                                        text-slate-500 dark:text-neutral-400">
                                @faq.Answer
                            </div>
                        }
                    </div>
                }
            </div>

            <p class="mt-8 text-center text-sm text-slate-500 dark:text-neutral-400">
                Still have questions?
                <a href="/contact" class="font-medium text-accent hover:underline">Let's talk.</a>
            </p>
        </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────────── -->
    <section class="py-24 px-6 relative overflow-hidden bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="hero-aura" aria-hidden="true">
            <div class="hero-aura-blob"></div>
        </div>
        <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
            <p class="text-sm font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500">
                Ready to get started?
            </p>
            <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-balance text-slate-900 dark:text-white">
                Whether you need a stunning website, intelligent automation, or both!
                <span class="text-accent">Let's build something great.</span>
            </h2>
            <p class="text-base text-slate-500 dark:text-neutral-400">
                No obligation. Just a conversation about what you need.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
                <PrimaryButton Href="/contact" Class="px-7 py-3">Start the conversation</PrimaryButton>
                <PrimaryButton Href="/websites" Color="ButtonColor.Muted" Style="ButtonStyle.Text">
                    See our work →
                </PrimaryButton>
            </div>
        </div>
    </section>

</div>

@code {
    private string? _openFaq;
    private void ToggleFaq(string q) => _openFaq = _openFaq == q ? null : q;

    private static readonly string[] _websiteFeatures =
    [
        "Custom website design & development",
        "E-commerce & client portals",
        "Booking systems & bespoke dashboards",
        "Ongoing support & maintenance",
    ];

    private static readonly string[] _automationFeatures =
    [
        "Workflow & process automation",
        "API & systems integration",
        "AI-powered decision automation",
        "Data pipeline & reporting automation",
    ];

    private record ProcessStep(string Title, string Description);

    private static readonly ProcessStep[] _processSteps =
    [
        new("Discovery call", "We spend time understanding your goals and what success looks like — before a single line of code is written."),
        new("Fixed-price quote", "A clear, itemised proposal with a fixed price and timeline. No hidden fees, no scope creep."),
        new("Build & updates", "We build iteratively, keeping you updated via your dedicated project portal. You always know where things stand."),
        new("Launch & beyond", "We handle the launch and stay on hand. Most clients continue with a retainer — we build things to last."),
    ];
}
