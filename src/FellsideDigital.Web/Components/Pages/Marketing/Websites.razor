@page "/websites"
@using FellsideDigital.Web.Components.Pages

<PageTitle>Website Design &amp; Development — Fellside Digital</PageTitle>

<div class="flex flex-col w-full max-w-full overflow-x-hidden
            bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300">

    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-24 sm:py-32 px-6 bg-white dark:bg-neutral-950">
        <div class="grain-overlay" aria-hidden="true"></div>
        <div class="hero-aura" aria-hidden="true">
            <div class="hero-aura-blob"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto">
            <div class="flex flex-col lg:flex-row lg:items-center gap-12">
                <div class="max-w-2xl">
                    <a href="/"
                       class="inline-flex items-center gap-1.5 text-xs font-medium
                              text-slate-400 dark:text-neutral-500
                              hover:text-slate-600 dark:hover:text-neutral-300 mb-8 transition-colors">
                        <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                        </svg>
                        Back to home
                    </a>
                    <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">
                        Website Design &amp; Development
                    </p>
                    <h1 class="text-5xl sm:text-6xl font-semibold tracking-tight text-balance
                               text-slate-900 dark:text-white mb-6">
                        Beautiful websites that
                        <span class="text-accent"> actually perform</span>
                    </h1>
                    <p class="text-lg text-slate-500 dark:text-neutral-400 leading-relaxed mb-8">
                        Every website we build is crafted from scratch — no page builders, no templates.
                        High-performance, pixel-perfect, and designed around your specific goals.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="/contact"
                           class="rounded-xl bg-accent px-6 py-3 text-sm font-semibold
                                  text-white shadow-sm hover:opacity-90 transition-all text-center">
                            Start your project
                        </a>
                        <a href="#portfolio"
                           class="rounded-xl px-6 py-3 text-sm font-semibold text-center
                                  text-slate-700 dark:text-neutral-200
                                  ring-1 ring-slate-200 dark:ring-white/10
                                  hover:bg-slate-50 dark:hover:bg-white/5 transition-all">
                            See our work
                        </a>
                    </div>
                </div>

                <!-- Browser mockup -->
                <div class="flex-1 hidden lg:block">
                    <div class="rounded-2xl overflow-hidden ring-1 ring-slate-200 dark:ring-white/10 bg-white dark:bg-neutral-900 shadow-2xl">
                        <div class="bg-slate-100 dark:bg-neutral-800 px-4 py-3 flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-400"></div>
                            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
                            <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
                            <div class="flex-1 ml-3 h-5 rounded bg-white dark:bg-neutral-700 flex items-center px-3">
                                <span class="text-xs text-slate-400 dark:text-neutral-500">fellsidedigital.co.uk</span>
                            </div>
                        </div>
                        <div class="p-6 space-y-3">
                            <div class="h-6 w-2/3 rounded-lg bg-accent/60"></div>
                            <div class="h-3 w-full rounded bg-slate-200 dark:bg-neutral-700"></div>
                            <div class="h-3 w-5/6 rounded bg-slate-200 dark:bg-neutral-700"></div>
                            <div class="h-3 w-4/5 rounded bg-slate-100 dark:bg-neutral-800"></div>
                            <div class="mt-5 grid grid-cols-3 gap-3">
                                <div class="rounded-lg bg-accent h-20"></div>
                                <div class="rounded-lg bg-accent/40 h-20"></div>
                                <div class="rounded-lg bg-accent/20 h-20"></div>
                            </div>
                            <div class="mt-3 h-8 w-28 rounded-lg bg-accent"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PORTFOLIO ──────────────────────────────────────────────────────── -->
    <section id="portfolio" class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Our work"
                           Heading="What we've built."
                           Description="A selection of projects we've delivered for clients across the UK." />

            <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach (var project in HomeData.Projects)
                {
                    <div class="group rounded-2xl bg-white dark:bg-neutral-900
                                ring-1 ring-slate-200 dark:ring-white/5
                                hover:ring-accent/40
                                hover:shadow-lg transition-all duration-200 overflow-hidden">
                        <!-- Mockup area -->
                        <div class="bg-slate-100 dark:bg-neutral-800 h-44 flex items-center justify-center px-8">
                            <div class="w-full max-w-xs rounded-xl ring-1 ring-slate-200 dark:ring-white/10 bg-white dark:bg-neutral-900 overflow-hidden shadow-md">
                                <div class="bg-slate-200 dark:bg-neutral-700 h-5 flex items-center px-3 gap-1.5">
                                    <div class="w-2 h-2 rounded-full bg-red-400/70"></div>
                                    <div class="w-2 h-2 rounded-full bg-amber-400/70"></div>
                                    <div class="w-2 h-2 rounded-full bg-emerald-400/70"></div>
                                </div>
                                <div class="p-3 space-y-1.5">
                                    <div class="h-2 w-1/2 rounded bg-accent/50"></div>
                                    <div class="h-2 w-full rounded bg-slate-200 dark:bg-neutral-700"></div>
                                    <div class="h-2 w-4/5 rounded bg-slate-200 dark:bg-neutral-700"></div>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <!-- Tags -->
                            <div class="flex flex-wrap gap-1.5 mb-3">
                                @foreach (var tag in project.Tags)
                                {
                                    <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                                                 bg-slate-100 text-slate-600
                                                 dark:bg-neutral-800 dark:text-neutral-400">@tag</span>
                                }
                            </div>
                            <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100
                                       group-hover:text-accent transition-colors mb-1">
                                @project.Title
                            </h3>
                            <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">
                                @project.Description
                            </p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ── BENTO: CAPABILITIES ────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="About us"
                           Heading="Design-led, and built to last."
                           Description="We obsess over the details — from performance and accessibility to typography and hover states." />

            <div class="mt-12 flex flex-col lg:flex-row gap-3 items-stretch">

                <!-- LEFT: Disciplines -->
                <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5
                            rounded-[18px] overflow-hidden flex flex-col
                            w-full lg:w-[300px] lg:flex-shrink-0">
                    <div class="bg-slate-50 dark:bg-neutral-800 flex flex-col items-center justify-center gap-6 p-8" style="min-height:300px;">
                        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:7px;">
                            @foreach (var (on, opacity) in _dotPattern)
                            {
                                <div class="rounded-full @(on ? $"bg-accent opacity-{opacity}" : "bg-slate-200 dark:bg-neutral-600")"
                                     style="width:8px;height:8px;"></div>
                            }
                        </div>
                        <div class="flex flex-col gap-2.5 w-full">
                            @foreach (var (label, width) in _disciplines)
                            {
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-slate-400 dark:text-neutral-500">@label</span>
                                    <div class="bg-slate-200 dark:bg-neutral-700 h-1 rounded-full overflow-hidden">
                                        <div class="bg-accent h-full rounded-full"
                                             style="width:@(width)%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="p-8">
                        <p class="text-xs font-medium uppercase tracking-widest text-accent">What we do</p>
                        <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-neutral-100">Two practices, one partner</p>
                        <p class="mt-2 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">Premium websites and intelligent automation, both done properly.</p>
                    </div>
                </div>

                <!-- MIDDLE: Two stacked cards -->
                <div class="flex flex-col gap-3 flex-1 min-w-0">

                    <!-- 100% Bespoke -->
                    <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 rounded-[18px] overflow-hidden flex flex-col flex-1">
                        <div class="bg-slate-50 dark:bg-neutral-800 flex items-center justify-center" style="min-height:160px;">
                            <div class="text-center px-8 py-6">
                                <p class="text-accent text-6xl font-medium leading-none">
                                    100%
                                </p>
                                <p class="text-sm text-slate-500 dark:text-neutral-400 mt-2">Bespoke. No templates, no guesswork.</p>
                            </div>
                        </div>
                        <div class="px-8 py-6">
                            <p class="text-xs font-medium uppercase tracking-widest text-accent">Our approach</p>
                            <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-neutral-100">Built around your business</p>
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 rounded-[18px] overflow-hidden flex flex-col flex-1">
                        <div class="bg-slate-50 dark:bg-neutral-800 flex items-center justify-center" style="min-height:160px;">
                            <div class="flex flex-col items-center gap-4 py-6">
                                <div class="relative w-16 h-16 flex items-center justify-center">
                                    <div class="animate-ping rounded-full ring-1 ring-accent/20 absolute w-16 h-16" style="animation-duration:2.4s;"></div>
                                    <div class="animate-ping rounded-full ring-1 ring-accent/30 absolute w-11 h-11" style="animation-duration:1.8s;animation-delay:0.4s;"></div>
                                    <div class="bg-accent/10 ring-1 ring-accent/40 rounded-full w-7 h-7 flex items-center justify-center">
                                        <span class="rounded-full bg-green-500 w-2 h-2 block"></span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <span class="rounded-full bg-green-500 w-1.5 h-1.5 flex-shrink-0 block"></span>
                                    <span class="text-xs text-slate-500 dark:text-neutral-400">Remote-first. Always reachable.</span>
                                </div>
                            </div>
                        </div>
                        <div class="px-8 py-6">
                            <p class="text-xs font-medium uppercase tracking-widest text-accent">UK-wide</p>
                            <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-neutral-100">Based in Keswick, working everywhere</p>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Website delivery pipeline -->
                <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5
                            rounded-[18px] overflow-hidden flex flex-col
                            w-full lg:w-[300px] lg:flex-shrink-0">
                    <div class="bg-slate-50 dark:bg-neutral-800 flex items-center justify-center p-8" style="min-height:300px;">
                        <div class="flex flex-col items-start w-full space-y-0">
                            @foreach (var (icon, label, isLast) in _deliveryPipeline)
                            {
                                <div class="flex items-center gap-3">
                                    <div class="bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 w-9 h-9 rounded-[10px] flex-shrink-0 flex items-center justify-center">
                                        @((MarkupString)icon)
                                    </div>
                                    <span class="text-sm text-slate-500 dark:text-neutral-400">@label</span>
                                </div>
                                @if (!isLast)
                                {
                                    <div class="bg-slate-200 dark:bg-neutral-700 w-px h-4 ml-[17px]"></div>
                                }
                            }
                        </div>
                    </div>
                    <div class="p-8">
                        <p class="text-xs font-medium uppercase tracking-widest text-accent">How we deliver</p>
                        <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-neutral-100">Discovery to launch</p>
                        <p class="mt-2 text-sm leading-relaxed text-slate-500 dark:text-neutral-400">Every stage tracked in your project portal.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WEBSITE SERVICES ───────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Services"
                           Heading="Everything a website project needs."
                           Description="From the initial design concept to long-term hosting and support — all under one roof." />

            <div class="mt-16 flex flex-col divide-y divide-slate-200 dark:divide-white/5">
                @foreach (var (svc, index) in _websiteServices.Select((s, i) => (s, i)))
                {
                    bool reverse = index % 2 != 0;
                    <div class="grid md:grid-cols-2 gap-12 py-16 items-center">

                        <!-- Visual panel -->
                        <div class="@(reverse ? "md:order-last" : "")
                                    rounded-2xl bg-white dark:bg-neutral-900
                                    ring-1 ring-slate-200 dark:ring-white/5
                                    h-52 flex items-center justify-center overflow-hidden px-8">
                            @((MarkupString)svc.Visual)
                        </div>

                        <!-- Content panel -->
                        <div class="flex flex-col gap-4">
                            <p class="text-sm font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500">
                                @svc.Number
                            </p>
                            <h3 class="text-2xl font-semibold text-slate-900 dark:text-neutral-100">
                                @svc.Title
                            </h3>
                            <p class="text-base leading-relaxed text-slate-500 dark:text-neutral-400">
                                @svc.Description
                            </p>
                            <div class="flex flex-wrap gap-2 mt-1">
                                @foreach (var tag in svc.Tags)
                                {
                                    <span class="rounded-full px-3 py-1 text-xs font-medium
                                                 bg-slate-100 text-slate-600
                                                 dark:bg-neutral-800 dark:text-neutral-300">
                                        @tag
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────────── -->
    <section class="py-24 px-6 relative overflow-hidden bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="hero-glow opacity-20" aria-hidden="true"></div>
        <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
            <p class="text-sm font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500">
                Ready for a new website?
            </p>
            <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-balance text-slate-900 dark:text-white">
                Let's build something
                <span class="text-accent"> you're proud of.</span>
            </h2>
            <p class="text-base text-slate-500 dark:text-neutral-400">
                Tell us about your project and we'll come back with a clear plan and fixed price.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
                <a href="/contact"
                   class="rounded-xl bg-accent px-7 py-3 text-sm font-semibold
                          text-white shadow-lg hover:opacity-90 transition-all">
                    Get a quote
                </a>
                <a href="/automation"
                   class="text-sm font-medium text-slate-500 dark:text-neutral-400
                          hover:text-accent transition-colors">
                    Also need automation? →
                </a>
            </div>
        </div>
    </section>

</div>

@code {
    private static readonly (bool on, string opacity)[] _dotPattern =
    [
        (true,"100"),(false,""),(true,"100"),(false,""),(true,"40"),(false,""),(true,"100"),
        (false,""),(true,"100"),(false,""),(true,"100"),(false,""),(true,"100"),(false,""),
        (true,"60"),(false,""),(true,"40"),(false,""),(true,"60"),(false,""),(true,"40"),
        (true,"40"),(false,""),(false,""),(false,""),(true,"40"),(false,""),(false,""),
        (false,""),(false,""),(true,"20"),(false,""),(true,"20"),(false,""),(false,""),
    ];

    private static readonly (string label, int width)[] _disciplines =
    [
        ("Website design", 92),
        ("Workflow automation", 90),
        ("Web applications", 85),
        ("AI automation", 82),
        ("API integration", 74),
    ];

    private static readonly (string icon, string label, bool isLast)[] _deliveryPipeline =
    [
        ("""<svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>""", "Discovery & scoping", false),
        ("""<svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>""", "Design & prototyping", false),
        ("""<svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>""", "Build & test", false),
        ("""<svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/></svg>""", "Launch & deploy", false),
        ("""<svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>""", "Ongoing support", true),
    ];

    private record WebsiteService(string Number, string Title, string Description, string[] Tags, string Visual);

    private static readonly WebsiteService[] _websiteServices =
    [
        new(
            Number: "01",
            Title: "Custom Website Design",
            Description: "Beautifully crafted, high-performance websites designed to reflect your brand and convert visitors. No templates — every pixel is built for you.",
            Tags: ["Bespoke design", "Blazor & .NET", "Mobile-first"],
            Visual: """
                <div class="flex flex-col gap-2 w-2/3">
                    <div class="h-7 w-full rounded-md bg-slate-100 dark:bg-neutral-800 flex items-center px-3 gap-2">
                        <div class="w-2 h-2 rounded-full bg-slate-300 dark:bg-neutral-600 flex-shrink-0"></div>
                        <div class="h-1.5 flex-1 rounded-full bg-slate-200 dark:bg-neutral-700"></div>
                    </div>
                    <div class="flex gap-3">
                        <div class="flex flex-col gap-1.5 flex-1 pt-1">
                            <div class="h-2 rounded-full bg-accent/60 w-full"></div>
                            <div class="h-2 rounded-full bg-accent/30 w-3/4"></div>
                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-1/2"></div>
                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-5/6 mt-1"></div>
                            <div class="h-2 rounded-full bg-slate-200 dark:bg-neutral-700 w-2/3"></div>
                        </div>
                        <div class="w-20 h-20 rounded-md bg-accent/20 flex-shrink-0"></div>
                    </div>
                </div>
            """
        ),
        new(
            Number: "02",
            Title: "E-Commerce & Web Applications",
            Description: "Full-featured web applications and online stores built from the ground up — custom portals, dashboards, booking systems, and more.",
            Tags: ["E-Commerce", "Client portals", "Custom dashboards"],
            Visual: """
                <div class="grid grid-cols-3 gap-2 w-48">
                    <div class="rounded-lg bg-accent aspect-square"></div>
                    <div class="rounded-lg bg-accent/60 aspect-square"></div>
                    <div class="rounded-lg bg-accent/40 aspect-square"></div>
                    <div class="rounded-lg bg-slate-200 dark:bg-neutral-700 aspect-square col-span-2"></div>
                    <div class="rounded-lg bg-accent/20 aspect-square"></div>
                </div>
            """
        ),
        new(
            Number: "03",
            Title: "Ongoing Support & Maintenance",
            Description: "We don't disappear after launch. Retainer packages cover hosting, updates, backups, monitoring, and priority support — so your site keeps performing.",
            Tags: ["Hosting", "Updates", "Priority support"],
            Visual: """
                <div class="flex flex-col gap-3 items-center">
                    <div class="flex items-center gap-3">
                        <div class="flex size-10 items-center justify-center rounded-xl bg-emerald-50 dark:bg-emerald-400/10 ring-1 ring-emerald-200 dark:ring-emerald-400/20">
                            <div class="size-2.5 rounded-full bg-emerald-400"></div>
                        </div>
                        <span class="text-sm text-slate-500 dark:text-neutral-400">Site online</span>
                    </div>
                    <div class="flex flex-col gap-1.5 w-40">
                        <div class="h-1.5 rounded-full bg-emerald-400/80 w-full"></div>
                        <div class="h-1.5 rounded-full bg-emerald-400/50 w-5/6"></div>
                        <div class="h-1.5 rounded-full bg-emerald-400/30 w-4/5"></div>
                    </div>
                    <span class="text-xs text-slate-400 dark:text-neutral-500">99.9% uptime</span>
                </div>
            """
        ),
    ];
}
