@page "/Portal/Websites"
@attribute [Authorize]
@layout PortalLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions
@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared

<PageTitle>My Websites — Fellside Digital Portal</PageTitle>

<div class="flex flex-col flex-1 min-h-0 gap-5">

    <!-- Page header -->
    <div class="shrink-0 flex items-center justify-between">
        <div>
            <p class="text-xs font-semibold text-accent-hover0 uppercase tracking-widest mb-1">Websites</p>
            <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Your websites</h1>
            <p class="mt-0.5 text-sm text-gray-500 dark:text-neutral-400">
                Every site we've built or are building for you.
            </p>
        </div>
        @if (_websites?.Count > 0)
        {
            <div class="hidden sm:flex items-center gap-2 rounded-xl bg-gray-100 dark:bg-white/5 px-4 py-2">
                <span class="text-2xl font-bold text-gray-900 dark:text-white">@_websites.Count</span>
                <span class="text-xs text-gray-500 dark:text-neutral-400">project@(_websites.Count == 1 ? "" : "s")</span>
            </div>
        }
    </div>

    <!-- Content area -->
    @if (_websites is null)
    {
        <div class="flex-1 min-h-0 overflow-y-auto">
            <div class="grid sm:grid-cols-2 gap-5 auto-rows-[minmax(280px,1fr)] animate-pulse">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="rounded-2xl bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/5"></div>
                }
            </div>
        </div>
    }
    else if (!_websites.Any())
    {
        <div class="flex-1 min-h-0 flex items-center justify-center">
            <div class="text-center max-w-sm">
                <div class="mx-auto mb-6 flex size-16 items-center justify-center rounded-2xl
                            bg-accent-hover text-accent">
                    <svg class="size-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900 dark:text-white">No websites yet</h3>
                <p class="mt-2 text-sm text-gray-500 dark:text-neutral-400 leading-relaxed">
                    Your websites will appear here once your project manager gets them set up.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="flex-1 min-h-0 overflow-y-auto">
            <div class="grid sm:grid-cols-2 gap-5 auto-rows-[minmax(280px,1fr)]">
                @foreach (var project in _websites)
                {
                    <div class="group flex flex-col rounded-2xl bg-white dark:bg-neutral-900
                                border border-gray-200/80 dark:border-white/5
                                shadow-sm hover:shadow-md hover:border-indigo-200
                                overflow-hidden transition-all duration-200">

                        <!-- Coloured top accent -->
                        <div class="h-[3px] w-full shrink-0 @StatusAccent(project.Status)"></div>

                        <div class="flex flex-col flex-1 p-6 gap-5">

                            <!-- Header row -->
                            <div class="flex items-start gap-4">
                                <div class="flex size-11 shrink-0 items-center justify-center rounded-xl
                                            bg-accent-hover
                                            text-accent-hover0">
                                    <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-start justify-between gap-2">
                                        <h2 class="text-base font-bold text-gray-900 dark:text-white leading-snug truncate">
                                            @project.Name
                                        </h2>
                                        <StatusBadge CssClasses="@BadgeHelpers.ProjectStatusBadge(project.Status)"
                                                     Label="@project.Status.DisplayName()" />
                                    </div>
                                    <p class="mt-0.5 text-xs text-gray-400 dark:text-neutral-500">
                                        Started @project.CreatedAt.ToLocalTime().ToString("d MMMM yyyy")
                                    </p>
                                </div>
                            </div>

                            <!-- Description -->
                            <p class="flex-1 text-sm text-gray-600 dark:text-neutral-300 leading-relaxed line-clamp-2">
                                @project.Description
                            </p>

                            <!-- Progress steps -->
                            <ProgressSteps Steps='@(new[] { "Scoping", "Building", "Live" })'
                                           CurrentStep="@StatusToStep(project.Status)"
                                           Variant="@StatusToVariant(project.Status)"
                                           OverrideLabel="@StatusToLabel(project.Status)" />

                            <!-- Footer -->
                            <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-white/5">
                                <div class="flex items-center gap-1.5 text-xs text-gray-400 dark:text-neutral-500">
                                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                    </svg>
                                    @project.Invoices.Count invoice@(project.Invoices.Count == 1 ? "" : "s")
                                </div>
                                <div class="flex items-center gap-2">
                                    @if (!string.IsNullOrEmpty(project.ProjectUrl))
                                    {
                                        <a href="@project.ProjectUrl" target="_blank" rel="noopener noreferrer"
                                           class="inline-flex items-center gap-1.5 rounded-lg
                                                  bg-accent-hover
                                                  text-accent
                                                  px-3 py-1.5 text-xs font-semibold
                                                  hover:bg-indigo-100 transition-colors">
                                            <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                            </svg>
                                            Visit site
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(project.PreviewUrl))
                                    {
                                        <NavLink href="@($"/Portal/Projects/{project.Id}")"
                                                 class="inline-flex items-center gap-1.5 rounded-lg
                                                        bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-neutral-300
                                                        px-3 py-1.5 text-xs font-semibold
                                                        hover:bg-gray-200 dark:hover:bg-white/10 transition-colors">
                                            Preview
                                        </NavLink>
                                    }
                                    <NavLink href="@($"/Portal/Projects/{project.Id}")"
                                             class="text-xs font-medium text-gray-400 dark:text-neutral-500
                                                    hover:text-gray-900 dark:hover:text-white transition-colors">
                                        Details →
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private static int StatusToStep(ProjectStatus s) => s switch
    {
        ProjectStatus.Pending    => 0,
        ProjectStatus.InProgress => 1,
        ProjectStatus.Blocked    => 1,
        ProjectStatus.OnHold     => 1,
        ProjectStatus.Completed  => 3,
        _                        => 0,
    };

    private static string StatusToVariant(ProjectStatus s) => s switch
    {
        ProjectStatus.Completed => "success",
        ProjectStatus.Blocked   => "blocked",
        ProjectStatus.OnHold    => "paused",
        _                       => "default",
    };

    private static string? StatusToLabel(ProjectStatus s) => s switch
    {
        ProjectStatus.Blocked => "Blocked",
        ProjectStatus.OnHold  => "On Hold",
        _                     => null,
    };

    private static string StatusAccent(ProjectStatus s) => s switch
    {
        ProjectStatus.InProgress => "bg-gradient-to-r from-blue-400 to-accent",
        ProjectStatus.Completed  => "bg-gradient-to-r from-emerald-400 to-teal-400",
        ProjectStatus.Blocked    => "bg-gradient-to-r from-red-400 to-rose-400",
        ProjectStatus.OnHold     => "bg-gradient-to-r from-amber-400 to-orange-400",
        _                        => "bg-gray-200 dark:bg-white/10",
    };
}
