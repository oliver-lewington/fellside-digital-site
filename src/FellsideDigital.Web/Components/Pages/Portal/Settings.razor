@page "/Portal/Settings"
@attribute [Authorize]
@layout PortalLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Components.Layout

<PageTitle>Settings — Fellside Digital Portal</PageTitle>

<!-- Page header -->
<div class="mb-8">
    <p class="text-xs font-semibold text-indigo-500 dark:text-orange-400 uppercase tracking-widest mb-1">Account</p>
    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Settings</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">Manage your profile and account preferences.</p>
</div>

<div class="space-y-8 max-w-4xl">

    <!-- Personal information -->
    <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-white/5">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Personal information</h2>
            <p class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400">Update your name and display details.</p>
        </div>
        <div class="px-6 py-6">
            @if (!string.IsNullOrEmpty(_profileSuccess))
            {
                <div class="mb-5 flex items-center gap-3 rounded-xl bg-emerald-50 dark:bg-emerald-400/10 px-4 py-3 ring-1 ring-emerald-200 dark:ring-emerald-400/20">
                    <svg class="size-4 shrink-0 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <p class="text-sm text-emerald-700 dark:text-emerald-400">@_profileSuccess</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(_profileError))
            {
                <div class="mb-5 flex items-center gap-3 rounded-xl bg-red-50 dark:bg-red-400/10 px-4 py-3 ring-1 ring-red-200 dark:ring-red-400/20">
                    <svg class="size-4 shrink-0 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    <p class="text-sm text-red-700 dark:text-red-400">@_profileError</p>
                </div>
            }
            <EditForm Model="ProfileInput" OnValidSubmit="SaveProfileAsync">
                <DataAnnotationsValidator />
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-6 sm:max-w-xl">
                    <div class="sm:col-span-3">
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">First name</label>
                        <InputText @bind-Value="ProfileInput.FirstName" class="@InputClass" />
                        <ValidationMessage For="() => ProfileInput.FirstName" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>
                    <div class="sm:col-span-3">
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">Last name</label>
                        <InputText @bind-Value="ProfileInput.LastName" class="@InputClass" />
                        <ValidationMessage For="() => ProfileInput.LastName" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>
                    <div class="col-span-full">
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">Email address</label>
                        <input type="email" value="@_email" disabled
                               class="block w-full rounded-xl bg-gray-100 dark:bg-white/5 px-3.5 py-2.5 text-sm text-gray-400 dark:text-neutral-500 ring-1 ring-inset ring-gray-200 dark:ring-white/5 cursor-not-allowed" />
                        <p class="mt-1.5 text-xs text-gray-400 dark:text-neutral-500">Contact support to change your email address.</p>
                    </div>
                </div>
                <div class="mt-6">
                    <button type="submit" disabled="@_savingProfile"
                            class="inline-flex items-center gap-2 rounded-xl bg-indigo-400 dark:bg-orange-400 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90 disabled:opacity-60 disabled:cursor-not-allowed transition-all">
                        @if (_savingProfile)
                        {
                            <svg class="size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Saving…</span>
                        }
                        else
                        {
                            <span>Save changes</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Change password -->
    <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-100 dark:border-white/5">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Change password</h2>
            <p class="mt-0.5 text-xs text-gray-500 dark:text-neutral-400">Keep your account secure with a strong password.</p>
        </div>
        <div class="px-6 py-6">
            @if (!string.IsNullOrEmpty(_passwordSuccess))
            {
                <div class="mb-5 flex items-center gap-3 rounded-xl bg-emerald-50 dark:bg-emerald-400/10 px-4 py-3 ring-1 ring-emerald-200 dark:ring-emerald-400/20">
                    <svg class="size-4 shrink-0 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <p class="text-sm text-emerald-700 dark:text-emerald-400">@_passwordSuccess</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(_passwordError))
            {
                <div class="mb-5 flex items-center gap-3 rounded-xl bg-red-50 dark:bg-red-400/10 px-4 py-3 ring-1 ring-red-200 dark:ring-red-400/20">
                    <svg class="size-4 shrink-0 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    <p class="text-sm text-red-700 dark:text-red-400">@_passwordError</p>
                </div>
            }
            <EditForm Model="PasswordInput" OnValidSubmit="ChangePasswordAsync">
                <DataAnnotationsValidator />
                <div class="space-y-5 sm:max-w-md">
                    <div>
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">Current password</label>
                        <InputText type="password" @bind-Value="PasswordInput.CurrentPassword" class="@InputClass" />
                        <ValidationMessage For="() => PasswordInput.CurrentPassword" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">New password</label>
                        <InputText type="password" @bind-Value="PasswordInput.NewPassword" class="@InputClass" />
                        <ValidationMessage For="() => PasswordInput.NewPassword" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">Confirm new password</label>
                        <InputText type="password" @bind-Value="PasswordInput.ConfirmPassword" class="@InputClass" />
                        <ValidationMessage For="() => PasswordInput.ConfirmPassword" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>
                </div>
                <div class="mt-6">
                    <button type="submit" disabled="@_changingPassword"
                            class="inline-flex items-center gap-2 rounded-xl bg-indigo-400 dark:bg-orange-400 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90 disabled:opacity-60 disabled:cursor-not-allowed transition-all">
                        @if (_changingPassword)
                        {
                            <svg class="size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Updating…</span>
                        }
                        else
                        {
                            <span>Update password</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

</div>
