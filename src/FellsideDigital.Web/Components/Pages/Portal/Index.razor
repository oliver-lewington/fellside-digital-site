@page "/Portal"
@attribute [Authorize]
@layout PortalLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.Web.Components.Pages.Portal.Overview
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout

<PageTitle>Overview — Fellside Digital Portal</PageTitle>

@if (_loading)
{
    <div class="flex flex-col flex-1 gap-5 min-h-0 animate-pulse">
        <div class="shrink-0 space-y-2">
            <div class="h-3 w-16 rounded bg-gray-100 dark:bg-white/10"></div>
            <div class="h-7 w-56 rounded-lg bg-gray-100 dark:bg-white/10"></div>
            <div class="h-4 w-72 rounded bg-gray-100 dark:bg-white/10"></div>
        </div>
        <div class="shrink-0 relative overflow-hidden rounded-[20px] bg-gray-100 dark:bg-white/5 h-[200px]"></div>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-3.5 shrink-0">
            @for (var i = 0; i < 3; i++) { <div class="h-24 rounded-2xl bg-gray-100 dark:bg-white/5"></div> }
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-5 flex-1">
            <div class="rounded-2xl bg-gray-100 dark:bg-white/5 min-h-[200px]"></div>
            <div class="rounded-2xl bg-gray-100 dark:bg-white/5"></div>
        </div>
    </div>
}
else if (_projects.Count == 0)
{
    <div class="flex flex-col flex-1 items-center justify-center text-center py-16">
        <div class="inline-flex size-16 items-center justify-center rounded-2xl bg-gray-50 dark:bg-white/5 mb-4">
            <svg class="size-7 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.75" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
            </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">No projects yet</h2>
        <p class="text-sm text-gray-400 dark:text-neutral-500 mt-1 max-w-xs">
            Your project manager will set these up shortly.
        </p>
        @* TODO: empty state CTA — link to enquiry / onboarding once that flow exists *@
    </div>
}
else if (_projects.Count == 1)
{
    <SingleProjectOverview Project="@_projects[0]"
                           FirstName="@_firstName" />
}
else
{
    <MultiProjectOverview Projects="@_projects"
                          RecentInvoices="@_invoices"
                          Activity="@_recentActivity"
                          FirstName="@_firstName" />
}
