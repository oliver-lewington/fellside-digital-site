@page "/animation-test"
@inject IJSRuntime JS

<PageTitle>Animation Test</PageTitle>

<div class="bg-neutral-950 text-neutral-100 min-h-screen px-6 py-24 space-y-24">

    <!-- ── TEST A: Bare cards (known working baseline) ── -->
    <section class="max-w-5xl mx-auto space-y-4">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Test A — Bare cards (baseline)</p>
        <div id="test-a" class="grid grid-cols-3 gap-6">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">Card 1</div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">Card 2</div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">Card 3</div>
        </div>
    </section>

    <!-- ── TEST B: Add lots of text ── -->
    <section class="max-w-5xl mx-auto space-y-4">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Test B — With text content</p>
        <div id="test-b" class="grid grid-cols-3 gap-6">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
        </div>
    </section>

    <!-- ── TEST C: Add flex flex-col ── -->
    <section class="max-w-5xl mx-auto space-y-4">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Test C — flex flex-col added</p>
        <div id="test-c" class="grid grid-cols-3 gap-6">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
        </div>
    </section>

    <!-- ── TEST D: Add cursor-pointer + group + hover classes ── -->
    <section class="max-w-5xl mx-auto space-y-4">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Test D — cursor-pointer + group + hover</p>
        <div id="test-d" class="grid grid-cols-3 gap-6">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6
                        hover:ring-indigo-400/40 hover:shadow-lg transition-all duration-300 flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6
                        hover:ring-indigo-400/40 hover:shadow-lg transition-all duration-300 flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6
                        hover:ring-indigo-400/40 hover:shadow-lg flex flex-col">
                <h3 class="text-xl font-semibold mb-2">Card Title</h3>
                <p class="text-neutral-400 text-sm">Some description text sitting inside the card to add height.</p>
                <p class="text-2xl font-bold mt-4">£450</p>
            </div>
        </div>
    </section>

    <!-- ── TEST E: Full real card (no overflow-hidden) ── -->
    <section class="max-w-5xl mx-auto space-y-4">
        <p class="text-xs uppercase tracking-widest text-neutral-500 text-center">Test E — Full card, no overflow-hidden</p>
        <div id="test-e" class="grid grid-cols-3 gap-6">
            @foreach (var _ in Enumerable.Range(0, 3))
            {
                <div class="group cursor-pointer rounded-2xl
                            bg-slate-800 ring-1 ring-white/10
                            hover:ring-indigo-400/40 hover:shadow-lg
                            transition-all duration-300 flex flex-col">
                    <div class="flex flex-wrap gap-2 px-6 pt-6">
                        <span class="rounded-full px-2.5 py-0.5 text-xs font-medium bg-neutral-700 text-neutral-300">Tag One</span>
                        <span class="rounded-full px-2.5 py-0.5 text-xs font-medium bg-neutral-700 text-neutral-300">Tag Two</span>
                    </div>
                    <div class="px-6 pt-4 pb-2 flex-1">
                        <h3 class="text-lg font-semibold text-neutral-100">Card Title</h3>
                        <p class="mt-1 text-sm text-neutral-400">Description text that adds some height to the card body.</p>
                        <ul class="mt-4 space-y-2">
                            <li class="flex items-start gap-2 text-sm text-neutral-400"><span class="text-indigo-400">✓</span> Feature one</li>
                            <li class="flex items-start gap-2 text-sm text-neutral-400"><span class="text-indigo-400">✓</span> Feature two</li>
                            <li class="flex items-start gap-2 text-sm text-neutral-400"><span class="text-indigo-400">✓</span> Feature three</li>
                        </ul>
                    </div>
                    <div class="px-6 pb-6 mt-6">
                        <span class="text-sm font-semibold text-indigo-400">Learn more →</span>
                    </div>
                </div>
            }
        </div>
    </section>

</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var opts = new { from = 0.88, duration = 650, stagger = 120 };

        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#test-a > div", opts);
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#test-b > div", opts);
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#test-c > div", opts);
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#test-d > div", opts);
        await JS.InvokeVoidAsync("fellsideAnime.zoomInOnScroll", "#test-e > div", opts);
    }
}
