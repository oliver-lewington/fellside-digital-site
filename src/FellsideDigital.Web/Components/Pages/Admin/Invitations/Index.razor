@page "/Admin/Invitations"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared

<PageTitle>Client Invitations — Fellside Digital Admin</PageTitle>

<PageHeader Eyebrow="Admin" Title="Client Invitations" Description="Send invitation links to onboard new clients.">
    <Actions>
        <PrimaryButton Href="/Admin/Invitations/Create">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            New invitation
        </PrimaryButton>
    </Actions>
</PageHeader>

<AlertBanner Message="@_successMessage" Variant="accent" Class="mb-6" />
<AlertBanner Message="@_copiedMessage" Variant="success" Class="mb-6" />

@if (_invitations is null)
{
    <div class="animate-pulse space-y-3">
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-12"></div>
        @for (int i = 0; i < 4; i++)
        {
            <div class="rounded-xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-16"></div>
        }
    </div>
}
else if (_invitations.Count == 0)
{
    <EmptyState Padding="p-14"
                IconContainerClass="size-12 rounded-2xl mb-4"
                Title="No invitations yet"
                Subtitle="Send an invitation to onboard your first client.">
        <Icon>
            <svg class="size-6 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
        </Icon>
        <Actions>
            <a href="/Admin/Invitations/Create"
               class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-500 dark:text-orange-400 hover:underline">
                Create an invitation →
            </a>
        </Actions>
    </EmptyState>
}
else
{
    <CardSection>
        <table class="min-w-full divide-y divide-gray-100 dark:divide-white/5">
            <thead>
                <tr class="bg-gray-50/80 dark:bg-white/[0.02]">
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Client</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden sm:table-cell">Company</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden md:table-cell">Service</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden lg:table-cell">Expires</th>
                    <th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                @foreach (var inv in _invitations)
                {
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-white/[0.02] transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-gray-100 dark:bg-white/5 text-xs font-semibold text-gray-600 dark:text-neutral-400">
                                    @(inv.FirstName.Length > 0 ? inv.FirstName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">@inv.FirstName @inv.LastName</p>
                                    <p class="text-xs text-gray-500 dark:text-neutral-400">@inv.Email</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 hidden sm:table-cell">
                            <span class="text-sm text-gray-700 dark:text-neutral-300">@inv.CompanyName</span>
                        </td>
                        <td class="px-6 py-4 hidden md:table-cell">
                            <span class="text-sm text-gray-500 dark:text-neutral-400">@inv.ServiceType</span>
                        </td>
                        <td class="px-6 py-4">
                            <StatusBadge CssClasses="@BadgeHelpers.InvitationStatusBadge(inv.Status)"
                                         Label="@inv.Status.ToString()" />
                        </td>
                        <td class="px-6 py-4 hidden lg:table-cell">
                            <span class="text-sm text-gray-500 dark:text-neutral-400">
                                @inv.ExpiresAt.ToLocalTime().ToString("d MMM yyyy")
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            @if (inv.Status == InvitationStatus.Pending)
                            {
                                <div class="flex items-center justify-end gap-3">
                                    <button @onclick="() => CopyLink(inv)"
                                            class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-500 dark:text-orange-400 hover:text-indigo-600 dark:hover:text-orange-300 transition-colors">
                                        <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
                                        </svg>
                                        Copy link
                                    </button>
                                    <span class="text-gray-200 dark:text-white/10">|</span>
                                    <button @onclick="() => RevokeAsync(inv.Id)"
                                            class="text-xs font-medium text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors">
                                        Revoke
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </CardSection>
}
